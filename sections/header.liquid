{%- liquid
  assign rtl = false

  if settings.lang_direction contains request.locale.iso_code
    assign rtl = true
  endif

  assign transparent = false
  if section.settings.enable_on_homepage and template.name == 'index'
   assign transparent = true
  endif 

  if section.settings.enable_on_collection_page and template.name == 'collection'
    assign transparent = true
  endif
%}
{%- style -%}
{% if section.settings.sticky_header_type != "none" %}
  .shopify-section.section-header {
    position: sticky;
    z-index: 41;
  }
  .shopify-section.section-header:has(>.mini-cart-open) {
    z-index: 60;
  }
{% endif %}
.header-logo-width {
  width: {{ section.settings.logo_width_mobile }}px;
}
.section-{{ section.id }}-padding {
  padding-top: calc({{ section.settings.padding_top }}px * var(--mobile-padding-ratio));
  padding-bottom: calc({{ section.settings.padding_bottom }}px * var(--mobile-padding-ratio));
}
{% if section.settings.sticky_header_type == "reduce-logo-size" %}
  .reduce-logo-size .header-logo-width {
    transform: scale({{ section.settings.reduce_logo_by }}%);
    transition: none;
  }
  .header-logo-width {
    transition: transform 0.3s linear;
  }
{% endif %}

.dark .header-bottom {
  background: rgba(var(--color-background));
  color: rgba(var(--color-text-header));
}
{%- if transparent -%}
    section:first-child {
      margin-top: 0;
    }
    .maximize-theme:not(.dark) .sticky-header-content {
      {% if section.settings.shadow_color.alpha != 0.0 %}
        background: linear-gradient(to top, transparent 0%, rgba({{ section.settings.shadow_color.red }} {{ section.settings.shadow_color.green }} {{ section.settings.shadow_color.blue }} / {{ section.settings.shadow | times: 0.01 }}) 100%);
      {% else %}
        background: transparent;
      {% endif %}
    }
    .dark .sticky-header-content {
      {% if section.settings.shadow_color_dark.alpha != 0.0 %}
        background: linear-gradient(to top, transparent 0%, rgba({{ section.settings.shadow_color_dark.red }} {{ section.settings.shadow_color_dark.green }} {{ section.settings.shadow_color_dark.blue }} / {{ section.settings.shadow | times: 0.01 }}) 100%);
      {% else %}
        background: transparent;
      {% endif %}
    }
    .maximize-theme:not(.dark) .transparent-header:not(:hover) .sticky-header-content:not(.sticky-header-active):not(:has(.toggle-menu.is-open)) {
      {% unless section.settings.text_link_color_light.alpha == 0.0 %}
        --color-highlight: {{ section.settings.text_link_color_light.red }} {{ section.settings.text_link_color_light.green }} {{ section.settings.text_link_color_light.blue }} / {{ section.settings.text_link_color_light.alpha }};
      {% endunless %}
    }
    .dark .transparent-header:not(:hover) .sticky-header-content:not(.sticky-header-active):not(:has(.toggle-menu.is-open)) {
      {%- unless section.settings.text_link_color_dark.alpha == 0.0 -%}
        --color-highlight: {{ section.settings.text_link_color_dark.red }} {{ section.settings.text_link_color_dark.green }} {{ section.settings.text_link_color_dark.blue }} / {{ section.settings.text_link_color_dark.alpha }};
      {% endunless %}
    }
    .maximize-theme:not(.dark) .transparent-header:not(:hover) .sticky-header-content:not(.sticky-header-active):not(:has(.toggle-menu.is-open)) header {
      {% unless section.settings.text_color_light.alpha == 0.0 %}
        color: {{ section.settings.text_color_light }};
      {% endunless %}
    }
    .dark .transparent-header:not(:hover) .sticky-header-content:not(.sticky-header-active):not(:has(.toggle-menu.is-open)) header {
      {% unless section.settings.text_color_dark.alpha == 0.0 %}
        color: {{ section.settings.text_color_dark }};
      {% else %}
        color: rgba(var(--color-text-header));
      {% endunless %}
      
    }
  {%- endif -%}
@media screen and (min-width: 1024px) {
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .header-logo-width {
    width: {{ section.settings.logo_width }}px;
  }
}
{%- endstyle -%}

<div 
  id="x-header-container" 
  class="z-[41] relative"
  {% if section.settings.sticky_header_type != "none" %}
    :class="$store.xMiniCart.isOpen && 'mini-cart-open'"
  {% elsif settings.cart_type == 'drawer' %}
    :class="$store.xMiniCart.isOpen && 'mini-cart-open'"
  {% endif %}
>
  <div id="x-header"
    class="x-header gradient max-w-[100vw] {% if transparent %}transparent-header{% endif %} "
    x-init='$store.xHeaderMenu.handleInitHeader("shopify-section-{{ section.id }}", "{{ section.settings.sticky_header_type }}", {{ transparent }}, "{{ section.settings.logo_position }}")'
    {% if section.settings.sticky_header_type != "none" %}
      data-is-sticky="true"
    {% endif %}
    @scroll.window="$store.xHeaderMenu.handleStickyHeader();{% if section.settings.sticky_header_type == 'on-scroll-up' %} $store.xHeaderMenu.handleOnScrollUpSticky(){% endif %}"

    {% if section.settings.sticky_header_type == 'always' or section.settings.sticky_header_type == 'reduce-logo-size' %}
      x-intersect="$store.xHeaderMenu.setHeaderHeightVariable()"
    {% endif %}
  >
    <div 
      id="x-header-content"
      class="x-header-content opacity-main-header sticky-header-content px-0{% if transparent %} w-full absolute disable-transparent-collection z-20{% endif %}"
      :class="{ 'background-header sticky-header-active': $store.xHeaderMenu.isSticky }"
      {% if transparent %}
        @click="$store.xHeaderMenu.clickedHeader = true"
        @click.away="$store.xHeaderMenu.clickedHeader = false"
        x-on:mouseover="$store.xHeaderMenu.addTransparentHover($el); $store.xHeaderMenu.showLogoTransparent = false"
        @mouseleave="!$store.xHeaderMenu.isSticky && !$store.xMobileNav.show && $store.xHeaderMenu.removeTransparentHover($el); $store.xMobileNav.show ? $store.xHeaderMenu.showLogoTransparent = false : $store.xHeaderMenu.showLogoTransparent = true"
      {% endif %}
      x-intersect.once="$store.xHeaderMenu.setTopStickyHeader(); requestAnimationFrame(() => $el.classList.remove('opacity-main-header'));"
      @load.window="requestAnimationFrame(() => $el.classList.remove('opacity-main-header'));"
    >
      <header 
        class="h-full section-{{ section.id }}-padding {{ section.settings.section_width }} lg:px-0 relative lg:static{% if section.settings.section_width == 'full-width-padded' %} mx-0{% endif %}"
        {% if section.settings.menu != blank or section.blocks.size > 0 %}
          {% if section.settings.desktop_menu_selection == "hover" %}
            x-on:mouseleave="$store.xHeaderMenu.hideMenu('main-menu-nav')"
          {% endif %}
          @keydown.escape.stop="$store.xHeaderMenu.hideMenu('main-menu-nav'); $store.xMobileNav.close(); $store.xFocusElement.removeTrapFocus(); $store.xHeaderMenu.focusFirstItem($event.target);"
        {% endif %}
      >
        <div class="header-top {{ section.settings.logo_position }} grid {% if section.settings.logo_position == "compact" %}lg:flex gap-7.5{% else %}lg:grid gap-x-5 lg:gap-x-10 xl:gap-x-20{% endif %} justify-between {{ section.settings.section_width }} items-center">
          <div class="header-mobile-toggle lg:hidden flex items-center gap-1">
            <button class="header-mobile-toggle-icon icon cursor-pointer flex items-center w-6 h-6 md:h-7 {% if rtl %} rotate-180 {% endif %} pr-1 py-1" @click="$store.xMobileNav.toggle()" aria-label="{{ 'header.toggle_mobile' | t }}">
              <span class="w-full translate-y-0" x-show="!$store.xMobileNav.show">{% render 'icon-all', icon: 'icon-hamburger' %}</span>
              <span x-show="$store.xMobileNav.show" class="px-0.5 py-0.5 translate-y-0" x-cloak>{% render 'icon-all', icon: 'icon-close' %}</span>
            </button>
            <div class="relative">{%- render 'header-search', minimal: true, type: "mobile" -%}</div>
          </div>
          {%- capture logo_header -%}
            <div class="header-logo">
              {%- if request.page_type == 'index' and section.settings.logo_h1 -%}
                <h1 class="h1-logo">
              {%- endif -%}
                <a class="logo-link flex justify-center" href="{{ routes.root_url }}" aria-label="{{ 'header.logo' | t }}">
                  {%- if section.settings.logo_dark != blank or section.settings.logo_dark_mobile != blank -%}
                    {%- liquid
                      if section.settings.logo_dark_mobile != blank
                        assign image_url_mobile = section.settings.logo_dark_mobile
                      else
                        assign image_url_mobile = section.settings.logo_dark
                      endif
                    -%}
                    <span class="header-logo-width logo-image logo-dark hidden dark:inline-block dark:relative">
                      {% if section.settings.logo_transparent and transparent %}
                        {%- render 'header-logo-transparent', transparent: transparent, logo_transparent: section.settings.logo_transparent, imageUrlMobile: image_url_mobile, imageUrlDesktop: section.settings.logo_dark -%}
                      {% else %}
                        {%- render 'header-logo',
                          imageUrlMobile: image_url_mobile,
                          imageUrlDesktop: section.settings.logo_dark,
                          logo_width: section.settings.logo_width,
                          logo_width_mobile: section.settings.logo_width_mobile
                        -%}
                      {% endif %}
                    </span>
                  {%- else -%}
                    <span class="header-logo-width {% unless section.settings.logo_position == 'logo-on-top' %} lg:text-left rtl:lg:text-right{% endunless %} logo-text text-center p-break-words h2 text-theme-text hidden dark:inline-block dark:relative">{{ shop.name }}</span>
                  {%- endif -%}
                  {%- if section.settings.logo != blank or section.settings.logo_mobile != blank -%}
                    {%- liquid
                      if section.settings.logo_mobile != blank
                        assign image_url_mobile = section.settings.logo_mobile
                      else
                        assign image_url_mobile = section.settings.logo
                      endif
                    -%}
                    <span class="header-logo-width logo-image logo-light relative dark:hidden">
                      {% if section.settings.logo_transparent and transparent %}
                        {%- render 'header-logo-transparent', transparent: transparent, logo_transparent: section.settings.logo_transparent, imageUrlMobile: image_url_mobile, imageUrlDesktop: section.settings.logo -%}
                      {% else %}
                        {%- render 'header-logo',
                          imageUrlMobile: image_url_mobile,
                          imageUrlDesktop: section.settings.logo,
                          logo_width: section.settings.logo_width,
                          logo_width_mobile: section.settings.logo_width_mobile
                        -%}
                      {% endif %}
                    </span>
                  {% else %}
                    <span class="header-logo-width logo-text text-center {% unless section.settings.logo_position == 'logo-on-top' %} lg:text-left rtl:lg:text-right{% endunless %} p-break-words h2 text-theme-text block dark:hidden">{{ shop.name }}</span>
                  {% endif %}
                </a>
              {%- if request.page_type == 'index' and section.settings.logo_h1 -%}
                </h1>
              {%- endif -%}
            </div>
          {%- endcapture -%}

          <div class="header-item [grid-area:header-left] hidden lg:flex items-center {% if section.settings.logo_position == 'compact' %}flex-1 min-w-[33%]{% endif  %}">
            <div 
              class="flex items-center"
              x-intersect.once="$store.xHelper.setPosition('#DrawerMenuDesktopPosition', '#DrawerMenuDesktop')"
            >
              <div 
                id="DrawerMenuDesktopPosition" class="empty:hidden{% if rtl %} ml-3{% else %} mr-3{% endif %}" 
              ></div>
              {%- if section.settings.logo_position == 'compact' or section.settings.logo_position == "logo-on-side" -%}
                {{- logo_header -}}
              {%- endif -%}
            </div>
            {%- if section.settings.logo_position == 'compact' -%}
              {%- render 'main-menu', desktop_motion: section.settings.desktop_menu_selection, rtl: rtl -%}
            {%- endif -%}
            {%- if section.settings.logo_position == 'logo-on-top' -%}
              <div class="header-center w-full max-w-[500px]">{% render "header-search", type: "desktop" %}</div>
            {%- endif -%}
          </div>
          <div class="w-full [grid-area:header-center] {% if section.settings.logo_position == 'compact' %} lg:hidden{% endif %}">
            <div class="{% if section.settings.logo_position == 'logo-on-side' %}lg:hidden{% endif %}">
              {{- logo_header -}}
            </div>
            {% if section.settings.logo_position == "logo-on-side" %}
              <div class="w-full hidden lg:block">
                {%- render 'header-search', type: "desktop" -%}
              </div>
            {% endif %}
          </div>
          <div class="header-item [grid-area:header-right] flex items-center justify-end gap-5">
            {% if settings.theme_mode_enabled %}
              <div class="hidden lg:block">
                {% render 'theme-mode-toggle', device: "desktop" %}
              </div>
            {% endif %}
            <div class="x-header-store-selector-desktop self-center lg:block hidden empty:hidden lg:max-w-[200px]"></div>
            <div class="hidden lg:flex items-center gap-5 empty:hidden">
              {%- if section.settings.logo_position == 'compact' -%}
                {%- render 'header-search', minimal: true, type: "desktop" -%}
              {%- endif -%}
              {%- if shop.customer_accounts_enabled -%}
                <div 
                  class="header-account_menu-bar relative" x-data="{'open': false}"
                  @click.away="open = false"
                  @keyup.esc="open = false;"
                >
                  <button 
                    class="header-icon-account hidden lg:flex gap-1 relative items-center justify-center lg:max-w-[200px]"
                    aria-label="Icon account"
                    @click="open =!open"
                    @keyup.esc="open = false"
                  >
                    <span class="w-6 h-6 icon shrink-0">
                      {% render 'icon-all', icon: 'icon-account' %}
                    </span>
                    {% if customer %}
                      <span class="flex gap-2.5 font-semibold items-center">
                        <span class="h7 text-left rtl:text-right">
                          {{ customer.name }}
                        </span>
                        <span class="inline-block w-2.5 h-1.5 shrink-0">{% render "icon-all", icon: "icon-caret" %}</span>
                      </span>
                    {% endif %}
                  </button>
                  <ul class="account__menu-bar-content shadow-medium absolute top-full rounded-corners-md left-1/2 mt-3.5 p-2 z-30 w-40 bg-gradient color-bg-[rgba(var(--color-background))] color-text-[rgba(var(--color-text-header),0.8)] border-t dropdown-anm origin-top"
                    :class="open && 'is-open'"
                    x-bind:inert="!open"
                  >
                    {% if customer %}
                      <li class="text-small hover:color-text-[rgba(var(--color-highlight))] font-normal rounded-corners-md{% if request.path == routes.account_url %} color-text-[rgba(var(--color-highlight))]{% endif %}">
                        <a class="w-full inline-block" href="{{ routes.account_url }}">
                          {{ 'customer.my_account' | t }}
                        </a>
                      </li>
                      <li class="text-small hover:color-text-[rgba(var(--color-highlight))] font-normal rounded-corners-md{% if request.path == routes.account_addresses_url %} color-text-[rgba(var(--color-highlight))]{% endif %}">
                        <a class="w-full inline-block" href="{{ routes.account_addresses_url }}">
                          {{ 'customer.my_address' | t }}
                        </a>
                      </li>
                      <li class="text-small hover:color-text-[rgba(var(--color-highlight))] font-normal rounded-corners-md">
                        <div class="cursor-pointer" tabindex="0" @click="window.location.href='{{ routes.account_logout_url }}'">
                          {{ 'customer.log_out' | t }}
                        </div>
                      </li>
                    {% else %}
                        <li class="text-small hover:color-text-[rgba(var(--color-highlight))] font-normal rounded-corners-md{% if request.path == routes.account_login_url %} color-text-[rgba(var(--color-highlight))]{% endif %}">
                          <a class="w-full inline-block" href="{{ routes.account_login_url }}">
                            {{ 'customer.log_in' | t }}
                          </a>
                        </li>
                        <li class="text-small hover:color-text-[rgba(var(--color-highlight))] font-normal rounded-corners-md{% if request.path == routes.account_register_url %} color-text-[rgba(var(--color-highlight))]{% endif %}">
                          <a class="w-full inline-block" href="{{ routes.account_register_url }}">
                            {{ 'customer.create_account' | t }}
                          </a>
                        </li>
                    {% endif %}
                  </ul>
                </div>
              {%- endif -%}
            </div>
            <div class="flex gap-4 items-center empty:hidden">
              {%- unless settings.hide_cart -%}
                <div class="relative">
                  <div class="header-icon-cart cursor-pointer relative {% if cart == empty %} cart-empty{% endif %}">
                    <a
                      id="cart-icon"
                      class="relative"
                      aria-controls="CartDrawer"
                      aria-expanded="false"
                      aria-label="icon-cart"
                      role="button"
                      tabindex="0"
                      @click.prevent="$store.xMiniCart.handleOpen();"
                      @keyup.enter="$store.xMiniCart.handleOpen();"
                    >
                    <span class="w-6 h-6 lg:w-7 lg:h-7 px-0.5 py-0.5 inline-block icon color-text-[rgba(var(--color-heading))] translate-y-0">
                      {% render 'icon-cart', icon: settings.cart_icon %}
                    </span>

                        <div id="cart-icon-bubble" x-init="$store.xCartHelper.currentItemCount = {{ cart.item_count }}" class="relative -left-0.5 rtl:left-0 rtl:-right-0.5">
                          <div class="cart-bubble__container empty:hidden color-bg-[rgba(var(--color-cart))] color-text-[rgba(var(--color-cart-text))] h-5 w-5 lg:h-6 lg:w-6 rounded-full text-x-small" data-count-item="{{ cart.item_count }}">
                            {%- unless cart == empty -%}
                              {%- if cart.item_count < 100 -%}
                                <span class="h-full flex items-center justify-center" aria-hidden="true">{{ cart.item_count }}</span>
                              {%- else -%}
                                <span class="h-full flex items-center justify-center">99+</span>
                              {%- endif -%}
                            {%- endunless -%}
                          </div>
                        </div>
                    </a>
                  </div>
                </div>
              {%- endunless -%}
            </div>
          </div>
        </div>
        {%- if section.settings.logo_position != 'compact' -%}
          <div class="header-bottom flex justify-center{% if section.settings.section_width != "full-width-padded" %} md:mx-auto{% endif %} {{ section.settings.section_width }}">
            {%- render 'main-menu', desktop_motion: section.settings.desktop_menu_selection, rtl: rtl -%}
          </div>
        {%- endif -%}

        {% comment %} Mobile header {% endcomment %}
        <div 
          id="x-header-mobile" 
          class="x-header-mobile lg:hidden w-full h-full" 
          x-bind:class="$store.xMobileNav.show && 'active'"
          x-intersect.once="$store.xHelper.setPosition('#DrawerMenuMobilePosition', '#DrawerMenuMobile');"
        >
          <div 
            class="header-mobile-overlay absolute -z-[1] w-full cursor-pointer h-full header-h-screen left-0 top-full duration-header-menu" 
            @click="$store.xMobileNav.close()"
            x-bind:class="$store.xMobileNav.show ? 'opacity-100 opacity' : 'opacity-0 opacity pointer-events-none'"
            x-cloak
          ></div>
          <div 
            x-cloak
            class="modal-container z-40 w-full max-w-screen-md overflow-hidden absolute top-full ease-out duration-header-menu {% if rtl %} right-0{% else %}left-0{% endif %} header-h-screen"
          >
            <div class="header-mobile-drawer__container h-full">
              <div class="main-nav-mobile h-full flex flex-col pb-3">
                <div 
                  class="mobile-header-toolbar flex lg:hidden text-center justify-between color-bg-[rgba(var(--color-button))] color-text-[rgba(var(--color-button-text))] p-4 items-center gap-4" 
                  x-cloak
                >
                  {% if customer %}
                    <div class="mobile-account-info text-start"><span>{{ 'header.hello_msg' | t }}, </span><span>{{ customer.name }}</span></div>
                  {% else %}
                    <div class="header-welcome-msg text-start p-break-words"><span>{{ 'header.welcome_msg' | t }} {{ shop.name }}</span></div>
                  {% endif %}
                  <div class="mobile-header-toolbar flex gap-1.5 items-center">
                    {% comment %} Login icon {% endcomment %}
                    {%- if shop.customer_accounts_enabled -%}
                      <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
                        aria-label="{{ 'customer.log_in' | t }}"
                        class="header-icon-account rounded-full color-bg-[rgba(var(--color-button-text),0.06)] relative flex items-center justify-center">
                        <span class="inline-block icon w-[38px] h-[38px] p-2.5">
                          {% render 'icon-all', icon: 'icon-account' %}
                        </span>
                      </a>
                    {%- endif -%}
                    {% comment %} Icon theme mode {% endcomment %}
                    {% if settings.theme_mode_enabled %}
                      {% render 'theme-mode-toggle', device: "mobile" %}
                    {% endif %}
                  </div>
                </div>
                <div
                  id="menu-navigation"
                  x-show="$store.xMobileNav.show"
                  class="h-full flex-1 relative overflow-hidden"
                  :class="$store.xMobileNav.currentMenuLinks.length == 0 ? ' overflow-y-auto' : 'overflow-hidden'"
                >
                  <div class="h-full w-full scrollbar-body scrollbar overflow-y-auto">
                    <div 
                      id="menu-level-0"
                      class="menu-parent w-full h-full" 
                    >
                      <div 
                        id="DrawerMenuMobilePosition"
                      ></div>

                      {% if section.settings.menu.links != blank or section.blocks.size > 0 %}
                        <div class="main-menu-lv0 pt-5 pb-5 px-4 border-b">
                          {% if section.settings.display_menu_title %}
                            <div class="mobile-main-menu-title h4 flex items-center gap-2 mb-3">
                              <span class="inline-block w-4 shrink-0">{% render "icon-all", icon: "icon-menu" %}</span>
                              <h4 class="p-break-words">{{ 'header.main_menu.text' | t }}</h4>
                            </div>
                          {% endif %}
                          <ul class="h5">
                            {%- if section.settings.menu.links != blank -%}a
                              {%- render 'mobile-main-menu',
                                links: section.settings.menu.links,
                                start_level: 0,
                                start_id: '',
                                rtl: rtl
                              -%}
                            {%- endif -%}
                            {% for block in section.blocks %}
                              {% if block.settings.enable_on_mobile %}
                                {% if block.type != "button" and block.settings.heading != blank %}
                                  <li>
                                    {% render 'mobile-mega-menu', block: block, start_level: 0, rtl: rtl %}
                                  </li>
                                {% elsif block.type == "button" %}
                                  {% unless block.settings.button_label == blank %}
                                    <li>
                                      <div class="button-menu">
                                        {% render 'button', button_style: block.settings.button_style, button_label: block.settings.button_label, button_link: block.settings.button_link, open_new_window_button: block.settings.open_new_window, class: 'px-2.5 py-2 !block w-fit' %}
                                      </div>
                                    </li>
                                  {% endunless %}
                                {% endif %}
                              {% endif %}
                            {% endfor %}
                          </ul>
                        </div>
                      {% endif %}

                      {% comment %} Show utility bar section{% endcomment %}
                      <div class="main-nav-mobile-bottom mt-auto pt-4 flex flex-col px-4 font-normal" style="--color-background: var(--color-background)">
                        <div class="x-header-store-selector-mobile w-full self-center"></div>
                        <div id="main-nav-mobile-toolbar" class="main-nav-mobile-toolbar" x-init="$store.xMobileNav.moveElement()">
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </header>
      
      {% unless template == 'cart' %}
        {% render 'cart-drawer', transparent: transparent %}
      {% endunless %}
      {% render "section-divider" %}
    </div>
  </div>
</div>
<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if section.settings.logo %}
      "logo": {{ section.settings.logo | image_url: width: section.settings.logo.width | prepend: "https:" | json }},
    {% endif %}
    "sameAs": [
      {{ settings.social_twitter_link | json }},
      {{ settings.social_facebook_link | json }},
      {{ settings.social_pinterest_link | json }},
      {{ settings.social_instagram_link | json }},
      {{ settings.social_tiktok_link | json }},
      {{ settings.social_tumblr_link | json }},
      {{ settings.social_snapchat_link | json }},
      {{ settings.social_youtube_link | json }},
      {{ settings.social_vimeo_link | json }}
    ],
    "url": {{ request.origin | append: page.url | json }}
  }
</script>
{%- if request.page_type == 'index' -%}
  {% assign potential_action_target = request.origin | append: routes.search_url | append: "?q={search_term_string}" %}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ potential_action_target | json }},
        "query-input": "required name=search_term_string"
      },
      "url": {{ request.origin | append: page.url | json }}
    }
  </script>
{%- endif -%}
