{% liquid
  assign is_enable_sticky_atc = false
  assign buy_buttons_block = section.blocks | where: 'type', 'buy_buttons'
  assign sticky_add_to_cart_style = section.settings.sticky_add_to_cart_style

  if buy_buttons_block.size > 0
    if sticky_add_to_cart_style != 'none'
      assign is_enable_sticky_atc = true
    endif
  endif
%}

{% style %}
  .section--{{ section.id }} {
    padding-top: calc({{ section.settings.padding_top }}px * var(--mobile-padding-ratio));
    padding-bottom: calc({{ section.settings.padding_bottom }}px * var(--mobile-padding-ratio));
  }
  @media (min-width: 768px) {
    .section--{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{% if section.settings.show_breadcrumbs %}
  <div id="Breadcrumbs__{{ section.id }}" class="{{ section.settings.section_width }}">
    <div class="media-full-width">
      {% render 'breadcrumbs', show_image_banner: false %}
    </div>
  </div>
{% endif %}

{%- if section.settings.show_section_divider -%}
  <div class="section-divider {% if section.settings.section_width == 'full-width' %} xs:pl-0 xs:pr-0{% endif %}{{ section.settings.section_width }}">
    <div class="divider m-auto border-t border-solid color-border-[rgba(var(--color-line-and-border))]"></div>
  </div>
{%- endif -%}

<div
  class="main-product__container relative section--{{ section.id }} {{ section.settings.section_width }} media-{{ section.settings.desktop_media_width }}"
  {% if is_enable_sticky_atc %}
    x-init="$store.stickyATC.handleInit('{{ section.id }}')"
  {% endif %}
  {% if product != blank %}x-intersect.once='$store.xProductRecently.setProduct("{{ product.id }}")'{% endif %}
>
  <main-product
      class="relative main-product__container--{{ section.id }}"
      data-section-id="{{ section.id }}"
      data-enabled-sticky-content="{{ section.settings.enable_sticky_content }}"
  >
    {% render 'product-template',
      section: section,
      product: product,
      is_product_page: true,
      is_enable_sticky_atc: is_enable_sticky_atc
    %}
  </main-product>
</div>
<script
  src="{{ 'product-recommendations.js' | asset_url }}"
  defer
></script>
<script
  src="{{ 'recently-viewed.js' | asset_url }}"
  defer
></script>
<script
  src="{{ 'product-form.js' | asset_url }}"
  defer
></script>

<script
    src="{{ 'product-info.js' | asset_url }}"
    defer
></script>
