<div class="template-404 full-width text-center pt-20 pb-20 md:pt-40 md:pb-40 color-{{ section.settings.color_scheme_light }} dark-color-{{ section.settings.color_scheme_dark }}">
  {% if section.settings.image != blank %}
    {% assign image_alt = section.settings.image.alt | escape %}
    {% render 'image',
      img: section.settings.image,
      img_class: "template-404__img rounded-corners img-not-found inline-block h-full lg:w-full object-cover mb-7 lg:mb-14 w-5/6 md:w-2/3 max-w-[578px]",
      alt: image_alt,
      img_width: section.settings.image.width,
      sizes: "(min-width: 1024px) 600px, (min-width: 768px) 50vw, 100vw",
      use_focal_point: true
    %}
  {% else %}
    <div class="template-404__subtext ltr">
      <div class="template-404__content__title-1st">4</div>
      <div class="template-404__content__title-2nd">0</div>
      <div class="template-404__content__title-3rd">4</div>
    </div>
  {% endif %}
  <div class="template-404__content">
    <h1 
      class="template-404__content__heading heading--{{ section.id }} heading-{{ section.settings.heading_size }} title h2 font-semibold mb-2 anm-fade-element"
      x-intersect.once="$el.classList.add('is-visible')"
    >
      {% if section.settings.heading != blank %}
        {% assign heading = section.settings.heading %}
      {% else %}
        {% assign heading = 'templates.404.title' | t %}
      {% endif %}
      {{ heading }}
    </h1>
    {% if section.settings.text != blank %}
      <div class="template-404__content__text rte mt-2.5 anm-fade-element" x-intersect.once="$el.classList.add('is-visible')">
        {{ section.settings.text }}
      </div>
    {% endif %}
    <div class="template-404__content__link mt-3">
      <a href="{{ routes.all_products_collection_url }}" class="text-link inline-text-link">{{ 'general.continue_shopping' | t }}</a>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "t:main_page.name",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:global.image.image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:global.text.heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:global.text.heading_size",
      "options": [
        {
          "value": "small",
          "label": "t:global.size.small"
        },
        {
          "value": "medium",
          "label": "t:global.size.medium"
        },
        {
          "value": "large",
          "label": "t:global.size.large"
        }
      ],
      "default": "medium"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:global.text.text"
    },
    {
      "type": "header",
      "content": "t:global.header.colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme_light",
      "default": "scheme-1",
      "label": "t:global.colors.color_scheme_light"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme_dark",
      "default": "scheme-2",
      "label": "t:global.colors.color_scheme_dark"
    }
  ]
}
{% endschema %}