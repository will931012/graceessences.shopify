{% style %}
  .section-{{ section.id }} {
    padding-top: calc({{ section.settings.padding_top }}px * var(--mobile-padding-ratio));
    padding-bottom: calc({{ section.settings.padding_bottom }}px * var(--mobile-padding-ratio));
    gap: calc({{ section.settings.spacing }}px * var(--mobile-padding-ratio));
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      gap: {{ section.settings.spacing }}px;
    }
  }
{% endstyle %}

{% render 'section-divider' %}

<div 
  class="section-grid__wrapper relative section-{{ section.id }} {{ section.settings.section_width }} rounded-corners-container color-{{ section.settings.color_scheme_light }} dark-color-{{ section.settings.color_scheme_dark }} flex
    {%- if section.settings.mobile_direction == 'horizontal' %} flex-row{% else %} flex-col{% endif -%}
    {%- if section.settings.desktop_direction == 'horizontal' %} md:flex-row{% else %} md:flex-col{% endif -%}"
>
  {% if section.settings.desktop_background_image != blank or section.settings.mobile_background_image != blank %}
    {% liquid 
      assign class_img = 'overflow-hidden top-0 left-0 w-full h-full opacity-' | append: section.settings.overlay_opacity

      assign mobile_cover_image = section.settings.mobile_background_image
      assign desktop_image = section.settings.desktop_background_image
      if desktop_image == blank
        assign desktop_image = mobile_cover_image
      endif
      assign desktop_sizes = '(min-width: 768px) 100vw, 100vw'
    %}
    <picture class="inset-0 absolute">
      <source
        media="(max-width: 767px)"
        srcset="
          {{ mobile_cover_image | image_url: width: '400x' }} 400w,
          {{ mobile_cover_image | image_url: width: '600x' }} 600w,
          {{ mobile_cover_image | image_url: width: '800x' }} 800w
        "
        width="{{ mobile_cover_image.width }}"
        height="{{ mobile_cover_image.height }}"
      >
      {{- desktop_image | image_url: width: desktop_image.width | image_tag: loading: 'lazy', widths: '720,900,1080,1200,1400,1600,1800,2000,2200', is: 'lazy-image', class: class_img, sizes: desktop_sizes -}}
    </picture>
  {% endif %}
  {% content_for 'block', id: 'header-static', type: '_group' %}
  {% content_for 'block', id: 'items-list-static', type: '_items-list' %}
  {% content_for 'blocks' %}
</div>
