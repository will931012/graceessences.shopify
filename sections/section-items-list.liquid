      "type": "header",
      "content": "t:item_list.appearance"
    },
    {
      "type": "select",
      "label": "t:item_list.background_media",
      "id": "background_media",
      "options": [
        {
          "label": "None",
          "value": "none"
        },
        {
          "label": "Image",
          "value": "image"
        }
