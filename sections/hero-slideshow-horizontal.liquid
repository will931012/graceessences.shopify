{% liquid
  assign block_first = section.blocks | first
  if block_first.settings.image != blank
    assign image_adapt = block_first.settings.image
  endif

  assign is_rtl = false
  if settings.lang_direction contains request.locale.iso_code
    assign is_rtl = true
  endif

  assign enable_slider = false
  if section.blocks.size > 1
    assign enable_slider = true
  endif

  assign auto_play = false
  assign default_slide_change_duration = 0.3
  assign default_slide_animation_delay = 'delay-150'
  if section.settings.auto_play > 0 and section.blocks.size > 1
    assign auto_play = true 
    if section.settings.transition_effect == 'slide'
      assign default_slide_animation_delay = 'delay-75'
    endif
  endif
%}
{% style %}
  .section--{{ section.id }} {
    padding-top: calc({{ section.settings.padding_top }}px * var(--mobile-padding-ratio));
    padding-bottom: calc({{ section.settings.padding_bottom }}px * var(--mobile-padding-ratio));
  }
  .mobile-{{ section.id }}-natural {
    {%- if block_first and block_first.settings.image_mobile != blank -%}
      height:0;
      padding-bottom: {{ 1 | divided_by: block_first.settings.image_mobile.aspect_ratio | times: 100 }}%;
    {%- else -%}
      height: 550px;
    {%- endif -%}
  }
  @media (min-width: 768px) {
    .section--{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
    .desktop-{{ section.id }}-natural {
      {%- if image_adapt -%}
        height:0;
        padding-bottom: {{ 1 | divided_by: image_adapt.aspect_ratio | times: 100 }}%;
      {%- else -%}
        height: 650px;
      {%- endif -%}
    }
  }

  .section--{{ section.id }}.full-width-padded .rounded-corners-container,
  .page-width .rounded-corners-container {
    border-radius: 0;
  }

{% endstyle %}

<div  class="{{ section.settings.section_width }} section--{{ section.id }} color-{{ section.settings.color_scheme_light }} dark-color-{{ section.settings.color_scheme_dark }} bg-transparent
  ">
  {% if section.blocks.size > 0 %}
    <div 
      class="relative overflow-hidden promotion 
        {%- if section.settings.section_width == 'full-width' %} media-full-width {% else %} rounded-corners w-full{% endif -%}
        {%- if section.settings.desktop_height == "natural" %} md:h-0 desktop-{{ section.id }}-natural{% else %} md:max-h-[100vh] md:promotion:h-[{{ section.settings.desktop_height }}] md:promotion:pb-0{% endif -%}
        {%- if section.settings.mobile_height == "natural" %}{% if block_first.settings.image_mobile != blank %} h-0 mobile-{{ section.id }}-natural{% else %} h-[550px]{% endif %}{% else %} h-[{{ section.settings.mobile_height }}]{% endif -%}
    ">
      <div
        class="hero-banner-horizontal__wrapper w-full h-full enable-effect-hover slider-nav-animation slider-item-snapstart swiffy-slider absolute top-0 bottom-0
          {%- if section.blocks.size > 1 %} cursor-grab{% endif -%}
          {%- if is_rtl %} rtl{% endif -%}
        "
        style="--swiffy-slider-item-gap: 0px;"
        x-intersect.once="
          $store.xSwiffy.load($el, {
            'isLoop': true,
            'effect': '{{ section.settings.transition_effect }}',
            'speed': {{ section.settings.auto_play | times: 1000 }},
            'handleArrow': true,
            'paginationBar': '{{ section.settings.pagination_style }}',
            'resize': true,
            'autoPlay': {{ auto_play }},
            'autoPause':{%- if section.settings.pause_on_hover %} true{% else %} false{% endif -%},
            'breakPoints': {
              '0': { slidesPerView: 1},
              '768': { 'slidesPerView': 1 }
            }
          });
        "
        data-effect="{{ section.settings.transition_effect }}"
        {% if auto_play %}
          x-data="{isHovered: false}"
          {% if section.settings.pause_on_hover %}
            @mouseenter="isHovered = true"
            @mouseleave="isHovered = false"
          {% endif %}
        {% endif %}
      >
        {% if section.settings.show_navigation_arrows and section.settings.pagination_style != 'image' and section.blocks.size > 1 %}
          {% render 'slider-navigation-button' %}
        {% endif %}
        <div 
          class="slider-container overflow-y-hidden hide-scrollbar slider-item-show1 will-change-transform
            {%- unless section.settings.section_width == 'full-width' %} rounded-corners {% endunless -%}"
          data-mobile-gap="0px"
          data-desktop-gap="0px"
        >
          {% for block in section.blocks %}
            {% liquid
              assign media_loading = 'lazy'
              if forloop.index == 1
                assign media_loading = 'eager'
              endif
            %}
            {%- assign position = block.settings.content_position | split: '-' -%}
            <div
              class="overlay-banner__item-wrapper w-full h-full slide-item block-{{ block.id }} color-{{ block.settings.color_scheme_light }} dark-color-{{ block.settings.color_scheme_dark }} color-scheme-block"
              data-swiffy-index="{{ forloop.index }}"
              x-data="{active_effect: false}" 
              {% if section.settings.transition_effect == "slide" or enable_slider == false %} 
                x-intersect:leave.threshold.1="active_effect = false"
                x-intersect.threshold.75="active_effect = true" 
              {% endif %}
              {{ block.shopify_attributes }}
            >
              {% if section.settings.transition_effect != "slide" and enable_slider %}
                <div x-intersect.half="active_effect = true" x-intersect:leave.threshold.1="active_effect = false" class="absolute top-0 left-0 w-full h-full hidden active-slide-fade"></div>
              {% endif %}
              <div class="w-full h-full relative overflow-hidden">
                <div class="scheme-image-overlay absolute top-0 left-0 bottom-0 right-0 z-10 opacity-{{ block.settings.overlay_opacity }}"></div>
                <div class="absolute top-0 left-0 w-full h-full overflow-hidden">
                  {% render 'media',
                    cover_image: block.settings.image,
                    mobile_cover_image: block.settings.image_mobile,
                    section: section,
                    sizes: '100vw',
                    class: '',
                    is_full_height: false,
                    show_placeholder_image: true,
                    slideshow: true,
                    media_loading: media_loading
                  %}
                </div>
              </div>
              <div class="hero-slide__content-wrapper absolute top-0 left-0 w-full h-full z-10">
                <div 
                  class="overlay-banner__text relative block-text--{{ block.id }} w-full transition px-5 py-5 padding-slideshow-content z-20 h-full
                    {%- if position[1] == 'center' %} md:flex md:flex-col md:items-center md:justify-{{ position[0] }}{% endif -%}"
                >
                  <div 
                    class="flex flex-col h-full justify-center md:justify-between gap-5 max-w-full text-{{ block.settings.content_alignment -}}
                      {%- if position[1] == 'center' %} md:h-auto md:gap-8
                      {%- elsif position[1] == 'right' %} md:gap-20 md:flex-row-reverse md:h-full md:items-{{ position[0] }} ltr
                      {%- else %} md:gap-20 md:flex-row md:h-full md:items-{{ position[0] }} ltr{% endif %}"
                  >
                    {% if block.settings.image_link != blank %}
                      <a
                        href="{{ block.settings.image_link }}"
                        {% if block.settings.open_new_window_image %}
                          target="_blank"
                        {% endif %}
                        class="slide-image-link absolute top-0 left-0 bottom-0 right-0 z-[19] opacity-0"
                      >
                        {{- block.settings.image_link -}}
                      </a>
                    {% endif %}
                    <div :class="active_effect && 'active'" class="hero-slide__text-content h-fit relative z-20
                      {%- unless position[1] == 'center' %} md:flex-0 min-w-[200px]
                      {%- if block.settings.product_1 != blank or block.settings.product_2 != blank or block.settings.alternative_image_1 != blank or block.settings.alternative_image_2 != blank %} md:w-full{% endif -%}{% endunless -%}
                      {%- if is_rtl %} rtl{% endif -%}"
                    >
                      <div class="flex flex-col gap-0.5{% if block.settings.button_label_1 != blank or block.settings.button_label_2 != blank %} heading-content-spacing{% endif %}">
                        {%- if block.settings.subheading != blank -%}
                          <p class="sub-heading-{{ block.id }} h6 subheading p-break-words anm-text-overlay-slide {{ default_slide_animation_delay }}" :class="active_effect && 'is-visible'">
                            {{ block.settings.subheading | escape }}
                          </p>
                        {%- endif -%}
                        {%- if block.settings.heading != blank -%}
                          <{{ block.settings.heading_tag }} 
                            class="h2 heading-{{ block.id }} p-break-words block heading-{{ block.settings.heading_size }} anm-text-overlay-slide {{ default_slide_animation_delay }}"
                            :class="active_effect && 'is-visible'"
                          >
                            {% render 'text-highlight',
                              id: block.id,
                              text: block.settings.heading,
                              highlight_effect: block.settings.highlight_effect,
                              text_transform: block.settings.text_transform,
                              disable_animation_fade: true
                            %}
                          </{{ block.settings.heading_tag }}>
                        {% endif %}
                        {%- if block.settings.text != blank -%}
                          <div class="p-break-words pointer-events-auto rte image-treatment-text text-large anm-text-overlay-slide {{ default_slide_animation_delay }}" :class="active_effect && 'is-visible'">
                            {% render 'text-highlight',
                              id: block.id,
                              text: block.settings.text,
                              highlight_effect: block.settings.highlight_effect,
                              text_transform: block.settings.text_transform,
                              disable_animation_fade: true,
                              allow_html: true
                            %}
                          </div>
                        {%- endif -%}
                      </div>

                      {%- if block.settings.button_label_1 != blank or block.settings.button_label_2 != blank -%}
                        {% liquid 
                          assign class_button = "text-" | append: block.settings.content_alignment
                          assign content_alignment = block.settings.content_alignment
                          if is_rtl
                            if block.settings.content_alignment == 'right'
                              assign content_alignment = 'left'
                            else
                              assign content_alignment = 'right'
                            endif
                          endif
                          if block.settings.button_label_1 != blank and block.settings.button_label_2 != blank
                            if block.settings.button_style_1 != "text-link" and block.settings.button_style_2 == "text-link"
                              assign button_padding = true
                            endif
                            if block.settings.button_style_1 == "text-link" and block.settings.button_style_2 != "text-link"
                              assign button_padding = true
                            endif
                          endif
                        %}
                        {% if button_padding %}
                          {% style %}
                            .buttons-{{ block.id }} .button-no-padding {
                              --button-padding-y-mobile: 10px;
                              --button-padding-y-desktop: 16px;
                              line-height: 1.4;
                            }
                          {% endstyle %}
                        {% endif %}
                        <div 
                          class="buttons-{{ block.id }} pointer-events-auto inline-flex flex-wrap gap-1 md:gap-2 p-break-words justify-{{ content_alignment }} anm-text-overlay-slide {{ default_slide_animation_delay }} items-center text-{{ block.settings.content_alignment }}"
                          :class="active_effect && 'is-visible'"
                        >
                          {%- if block.settings.button_label_1 != blank -%}
                            {% render 'button',
                              button_style: block.settings.button_style_1,
                              button_label: block.settings.button_label_1,
                              button_link: block.settings.button_link_1,
                              open_new_window_button: block.settings.open_new_window_button_1,
                              button_size: 'button-large',
                              class: class_button
                            %}
                          {%- endif -%}
                          {%- if block.settings.button_label_2 != blank -%}
                            {% render 'button',
                              button_style: block.settings.button_style_2,
                              button_label: block.settings.button_label_2,
                              button_link: block.settings.button_link_2,
                              open_new_window_button: block.settings.open_new_window_button_2,
                              button_size: 'button-large',
                              class: class_button 
                            %}
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                    </div>
                    {%- if block.settings.product_1 != blank or block.settings.product_2 != blank or block.settings.alternative_image_1 != blank or block.settings.alternative_image_2 != blank -%}
                      {% liquid
                        assign overlay_banner_size = 1
                        if block.settings.alternative_image_1 != blank or block.settings.product_1 != blank
                          if block.settings.alternative_image_2 != blank or block.settings.product_2 != blank
                            assign overlay_banner_size = 2
                          endif
                        endif
                      %}
                      <div 
                        :class="active_effect && 'active'" 
                        class="overlay-banner__media-group relative md:h-full justify-{{ block.settings.content_alignment }} z-20
                          {%- if position[1] == 'center' %} md:inline-block{% else %} md:inline-flex{% endif -%}
                          {%- if is_rtl %} rtl{% endif -%}"
                      >
                        <div 
                          class="inline-flex w-full min-w-[200px] md:min-w-[300px] lg:min-w-[400px]
                            {%- if overlay_banner_size == 2 %} max-w-[300px]{% else %} max-w-[250px]{% endif -%}
                            {%- if position[1] == 'center' and overlay_banner_size == 2 %} md:max-w-[800px]{% else %} md:max-w-[400px]{% endif -%}"
                        >
                          <div
                            :class="active_effect && 'active'"
                            class=" md:flex-1 md:basis-1/3 md:mx-0 relative swiffy-slider slider-nav-visible slider-nav-autopause slider-nav-animation slider-nav-touch pointer-events-none
                              {%- if overlay_banner_size == 2 %} mx-5{% endif -%}
                              {%- if position[1] == 'center' %} md:text-{{ block.settings.content_alignment -}}{% endif -%}"
                            x-intersect.once="
                              $store.xSwiffy.load($el, {
                                'mediaQuery': 'min',
                                'gap': '10px',
                                'breakPoints': {
                                  '0': { slidesPerView: 1},
                                  '768': { 'slidesPerView': 1 }
                                }
                              });
                            "
                          >
                            <div 
                              class="slider-container pointer-events-auto md:pointer-events-none hide-scrollbar gap-2.5
                                {%- if position[1] == 'center' %} md:inline-flex md:w-full{% else %} md:flex{% endif -%}
                                {%- if position[1] == 'center' %} md:flex-row md:justify-center{% else %} md:justify-{{ position[0] }} md:flex-col{% endif -%}"
                            >
                              {% if block.settings.alternative_image_1 != blank or block.settings.product_1 != blank %}
                                <div 
                                  class="slide-item pointer-events-auto max-h-[140px] md:max-h-[200px] overflow-hidden relative rounded-corners anm-text-overlay-slide {{ default_slide_animation_delay -}}
                                    {%- if position[1] == 'center' %} md:flex-1 md:max-h-[none]{% endif -%}
                                    {%- if block.settings.product_1 != blank %} color-{{ settings.color_schemes_light }} dark-color-{{ settings.color_schemes_dark }}{% else %} color-{{ section.settings.color_scheme_light }} dark-color-{{ section.settings.color_scheme_dark }}{% endif %}"
                                    :class="active_effect && 'is-visible'"
                                >
                                  {% if block.settings.product_1 != blank %}
                                    <div class="w-full h-full gradient product-card__wrapper p-2.5 md:p-5 overflow-hidden rounded-corners max-h-[140px] md:max-h-[200px]">
                                      {% render 'card-product-hero-banner',
                                        product: block.settings.product_1,
                                        show_rating: block.settings.show_product_rating_1,
                                        info_alignment: block.settings.overlay_alignment,
                                        info_position: block.settings.overlay_position,
                                        color_scheme_light: block.settings.color_scheme_light,
                                        color_scheme_dark: block.settings.color_scheme_dark 
                                      %}
                                    </div>
                                  {% elsif block.settings.alternative_image_1 != blank %}
                                    {% if block.settings.overlay_heading_color_1.alpha != 0.0 %}
                                      {% style %}
                                        .block-{{ block.id }} .overlay-group__first {
                                          --color-heading: {{ block.settings.overlay_heading_color_1.red }} {{ block.settings.overlay_heading_color_1.green }} {{ block.settings.overlay_heading_color_1.blue }} / {{ block.settings.overlay_heading_color_1.alpha }};
                                          --color-heading-no-alpha: {{ block.settings.overlay_heading_color_1.red }} {{ block.settings.overlay_heading_color_1.green }} {{ block.settings.overlay_heading_color_1.blue }};
                                        }
                                      {% endstyle %}
                                    {% endif %}
                                    <div class="overlay-group__first h-full w-full relative max-h-[140px] md:max-h-[200px]">
                                      <div class="h-full w-full">
                                        <div class="absolute top-0 left-0 bottom-0 right-0 z-10 scheme-image-overlay opacity-{{ block.settings.overlay_opacity_1 }} rounded-corners"></div>
                                        {% render 'image', img_class: 'overlay-group__first-image w-full h-full rounded-corners object-cover', img: block.settings.alternative_image_1, image_mobile: block.settings.alternative_image_1, alt: block.settings.alternative_image.alt, use_focal_point: true, sizes: "(min-width: 768px) 400px, 300px" %}
                                      </div>

                                      <div class="top-0 left-0 absolute z-10 w-full h-full p-5 md:px-[45px] md:py-[35px] text-{{ block.settings.overlay_alignment }} flex flex-col justify-{{ block.settings.overlay_position }}">
                                        {% if block.settings.image_link_1 != blank %}
                                          <a
                                            class="absolute top-0 left-0 bottom-0 right-0 z-0 bg-transparent"
                                            href="{{ block.settings.image_link_1 }}"
                                            {% if block.settings.open_new_window_1 %}
                                              target="_blank"
                                            {% endif %}
                                          ></a>
                                        {% endif %}
                                        {%- if block.settings.image_subheading_1 != blank -%}
                                          <p class="sub-heading-{{ block.id }} subheading p-break-words relative z-10">
                                            {{ block.settings.image_subheading_1 | escape }}
                                          </p>
                                        {%- endif -%}
                                        {%- if block.settings.image_heading_1 != blank -%}
                                          <p class="heading-{{ block.id }} h3 p-break-words block mt-1 relative z-10">
                                            {{ block.settings.image_heading_1 | escape }}
                                          </p>
                                        {% endif %}
                                      </div>
                                    </div>
                                  {% endif %}
                                </div>
                              {% endif %}

                              {% if block.settings.alternative_image_2 != blank or block.settings.product_2 != blank %}
                                <div 
                                  class="slide-item pointer-events-auto h-full overflow-hidden relative max-h-[140px] md:max-h-[200px] rounded-corners anm-text-overlay-slide {{ default_slide_animation_delay -}}
                                    {%- if position[1] == 'center' %} md:flex-1{% endif -%}
                                    {%- if block.settings.product_2 != blank %} color-{{ settings.color_schemes_light }} dark-color-{{ settings.color_schemes_dark }}{% else %} color-{{ section.settings.color_scheme_light }} dark-color-{{ section.settings.color_scheme_dark }}{% endif %}"
                                    :class="active_effect && 'is-visible'"
                                >
                                  {% if block.settings.product_2 != blank %}
                                    <div class="w-full h-full gradient product-card__wrapper p-2.5 md:p-5 overflow-hidden rounded-corners max-h-[140px] md:max-h-[200px]">
                                      {% render 'card-product-hero-banner',
                                        product: block.settings.product_2,
                                        show_rating: block.settings.show_product_rating_2,
                                        info_alignment: block.settings.overlay_alignment,
                                        info_position: block.settings.overlay_position,
                                        color_scheme_light: block.settings.color_scheme_light,
                                        color_scheme_dark: block.settings.color_scheme_dark 
                                      %}
                                    </div>
                                  {% elsif block.settings.alternative_image_2 != blank %}
                                    {% if block.settings.overlay_heading_color_2.alpha != 0.0 %}
                                      {% style %}
                                        .block-{{ block.id }} .overlay-group__first {
                                          --color-heading: {{ block.settings.overlay_heading_color_2.red }} {{ block.settings.overlay_heading_color_2.green }} {{ block.settings.overlay_heading_color_2.blue }} / {{ block.settings.overlay_heading_color_2.alpha }};
                                          --color-heading-no-alpha: {{ block.settings.overlay_heading_color_2.red }} {{ block.settings.overlay_heading_color_2.green }} {{ block.settings.overlay_heading_color_2.blue }};
                                        }
                                      {% endstyle %}
                                    {% endif %}
                                    <div class="overlay-group__second h-full w-full relative max-h-[140px] md:max-h-[200px]">
                                      <div class="w-full h-full">
                                        <div class="absolute top-0 left-0 bottom-0 right-0 z-10 scheme-image-overlay opacity-{{ block.settings.overlay_opacity_2 }} rounded-corners"></div>
                                        {% render 'image',
                                          img_class: 'overlay-group__secondary-image w-full h-full rounded-corners object-cover',
                                          img: block.settings.alternative_image_2,
                                          image_mobile: block.settings.alternative_image_2,
                                          alt: block.settings.alternative_image.alt,
                                          use_focal_point: true,
                                          sizes: "(min-width: 768px) 400px, 300px"
                                        %}
                                        <div class="top-0 left-0 absolute z-10 w-full h-full p-5 md:px-[45px] md:py-[35px] text-{{ block.settings.overlay_alignment }} flex flex-col justify-{{ block.settings.overlay_position }}">
                                          {% if block.settings.image_link_2 %}
                                            <a
                                              class="absolute top-0 left-0 bottom-0 right-0 z-0 bg-transparent"
                                              href="{{ block.settings.image_link_2 }}"
                                              {% if block.settings.open_new_window_2 %}
                                                target="_blank"
                                              {% endif %}
                                            ></a>
                                          {% endif %}
                                          {%- if block.settings.image_subheading_2 != blank -%}
                                            <p class="sub-heading-{{ block.id }} subheading p-break-words relative z-10">
                                              {{ block.settings.image_subheading_2 | escape }}
                                            </p>
                                          {%- endif -%}
                                          {%- if block.settings.image_heading_2 != blank -%}
                                            <p class="heading-{{ block.id }} h3 p-break-words block mt-1 relative z-10">
                                              {{ block.settings.image_heading_2 | escape }}
                                            </p>
                                          {% endif %}
                                        </div>
                                      </div>
                                    </div>
                                  {% endif %}
                                </div>
                              {% endif %}
                            </div>
                            {% if overlay_banner_size == 2 %}
                              <button
                                class="slider-nav slider-nav-pre is-visible w-9 pointer-events-auto absolute min-w-[36px] pl-3 pr-3 pt-3 pb-3 cursor-pointer duration-300 inline-block md:hidden -left-8 rotate-90"
                                aria-label="{{ 'accessibility.prev_button' | t }}"
                                x-on:touchend="$event.stopPropagation();"
                                x-on:click="$event.stopPropagation();"
                              >
                                {% render 'icon-all', icon: 'icon-caret' %}
                              </button>
                              <button
                                class="slider-nav slider-nav-next is-visible w-9 pointer-events-auto absolute min-w-[36px] pl-3 pr-3 pt-3 pb-3 cursor-pointer duration-300 inline-block md:hidden left-auto -right-8 -rotate-90"
                                aria-label="{{ 'accessibility.next_button' | t }}"
                                x-on:touchend="$event.stopPropagation();"
                                x-on:click="$event.stopPropagation();"
                              >
                                {% render 'icon-all', icon: 'icon-caret' %}
                              </button>
                            {% endif %}
                          </div>
                        </div>
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
        {% capture loading_progress %}
          {% if auto_play %}
            {% style %}
              .section--{{ section.id }} .progress-ring__progress.active {
                animation: drawRing {{ section.settings.auto_play | minus: default_slide_change_duration }}s linear forwards;
              }
            {% endstyle %}
            <div class="slider-autoplay-loading active" :class="isHovered && 'hovered'">
              <svg class="progress-ring" viewBox="0 0 26 26">
                <circle
                  class="progress-ring__background opacity-50"
                  cx="13"
                  cy="13"
                  r="11.5"
                  stroke="rgba(var(--color-heading))"
                  stroke-width="2"
                  fill="none"
                />
                <circle
                  class="progress-ring__progress"
                  x-intersect:leave="$el.classList.remove('active')"
                  x-intersect:enter="$el.classList.add('active')"  
                  cx="13"
                  cy="13"
                  r="11.5"
                  stroke="rgba(var(--color-heading))"
                  stroke-width="2"
                  fill="none"
                  stroke-linecap="round"
                />
              </svg>
            </div>
          {% endif %}
        {% endcapture %}
        {% if section.blocks.size > 1 %}
          {% if section.settings.pagination_style == 'number_bar' %}
            <div class="slider-indicators right-auto z-20 justify-center items-center w-fit absolute bottom-0 left-1/2 -translate-x-1/2">
              <span class="current-active-index h6 absolute border-0 bg-transparent h-auto w-auto rtl:-right-5 ltr:-left-5"> 1 </span>
              {% for block in section.blocks %}
                <button aria-label="slider-indicators-{{ forloop.index }}" class="slider-indicator !border-x-0 w-10 {% if forloop.index == 1 %}active{% endif %}"></button>
              {% endfor %}
              <span class="total-slide h6 absolute border-0 bg-transparent h-auto w-auto rtl:-left-5 ltr:-right-5">
                {{ section.blocks.size }}
              </span>
            </div>
            {{ loading_progress }}
          {% elsif section.settings.pagination_style == 'image' %}
            {% if auto_play %}
              {% style %}
                .section--{{ section.id }} .pagination-image-ovelay.active:not(.hovered) {
                  transition: transform {{ section.settings.auto_play | minus: default_slide_change_duration }}s linear;
                  transform: translateX(0%);
                }
              {% endstyle %}
            {% endif %}
            <div class="image-pagination-wrapper absolute z-20 bottom-2.5 right-0 w-fit flex gap-1.5 items-center justify-center md:justify-end px-2.5 active">
              <custom-button>
                <button
                  type="button"
                  name="previous"
                  class="button-secondary arrow-prev w-10 h-12 md:h-[60px] md:w-12 pagination-arrow rounded-corners relative overflow-hidden color-bg-[rgba(var(--color-secondary-button-no-alpha),0.4)]"
                  aria-label="{{ 'accessibility.prev_button' | t }}"
                >
                  <span class="inline-block rtl:rotate-0 rotate-180 w-full h-full px-3 md:px-4">{% render 'icon-all', icon: 'icon-nav-arrow' %}</span>
                </button>
              </custom-button>
              <div class="pagination-image-wrapper relative overflow-hidden rounded-corners">
                {% for block in section.blocks %}
                  {% liquid
                    assign image_loading = 'loading'
                    if forloop.index == 1
                      assign image_loading = 'eager'
                    endif

                    assign image_url_mobile = block.settings.image
                    if block.settings.image_mobile != blank
                      assign image_url_mobile = block.settings.image_mobile
                    endif
                  %}
                  <div class="pagination-active-image overflow-hidden relative z-10 w-24 h-12 md:w-32 md:h-[60px]{% if forloop.index == 2 %} active{% endif %}">
                    {% if block.settings.image != blank or block.settings.image_mobile %}
                      {%- if block.settings.image != blank -%}
                        {% assign default_image_alt = 'accessibility.default_alt' | t %}
                        <picture>
                          <source
                            srcset="{{ image_url_mobile | image_url: width: 375 }} 375w,
                              {{ image_url_mobile | image_url: width: 450 }} 450w,
                              {{ image_url_mobile | image_url: width: 750 }} 750w,
                              {{ image_url_mobile | image_url: width: 900 }} 900w,
                              {{ image_url_mobile | image_url: width: 1100 }} 1100w,
                              {{ image_url_mobile | image_url: width: 1500 }} 1500w"
                            media="(max-width: 767px)"
                            width="{{ image_url_mobile.width }}"
                            height="{{ image_url_mobile.height }}"
                          />
                          <img
                            class="w-full image-hover object-cover rounded-corners h-full{% if block.settings.image == blank %} md:hidden{% endif %}"
                            srcset="{{ block.settings.image | image_url: width: 450 }} 450w,
                            {{ block.settings.image | image_url: width: 750 }} 750w,
                            {{ block.settings.image | image_url: width: 900 }} 900w,
                            {{ block.settings.image | image_url: width: 1100 }} 1100w,
                            {{ block.settings.image | image_url: width: 1500 }} 1500w,
                            {{ block.settings.image | image_url }} {{ block.settings.image.width }}w"
                            src="{{ block.settings.image | image_url: width: 1500 }}"
                            alt="{{ block.settings.image.alt | default: default_image_alt | escape }}"
                            loading="lazy"
                            sizes="200px"
                            width="{{ block.settings.image.width }}"
                            height="{{ block.settings.image.height }}"
                            style="object-position: {{ block.settings.image.presentation.focal_point }}"
                          >
                        </picture>
                      {% endif %}
                      {%- if block.settings.image_mobile != blank and block.settings.image == blank -%}
                        <div class="w-full h-full rounded-corners object-cover hidden md:block overflow-hidden">
                          {% render 'placeholder-image', image_type: 'slide' %}
                        </div>
                        {{ block.settings.image_mobile 
                        | image_url: width: 1780 
                        | image_tag: loading: image_loading, sizes: 200, widths: '375, 450, 750, 900, 1100, 1500, 1780', class: 'md:hidden w-full image-hover object-cover rounded-corners h-full' }}
                      {% endif %}
                    {% else %}
                      <div class="relative w-full h-full rounded-corners object-cover overflow-hidden">
                        {% render 'placeholder-image', image_type: 'slide' %}
                        <div class="absolute top-0 left-0 w-full h-full image-treatment-overlay opacity-[6%]"></div>
                      </div>
                    {% endif %}
                  </div>
                {% endfor %}
                {% if auto_play %}
                  <div class="pagination-image-ovelay" x-intersect.once="$el.classList.add('active')" :class="isHovered && 'hovered'"></div>
                {% endif %}
              </div>
              <custom-button>
                <button
                  type="button"
                  name="next"
                  class="button-secondary arrow-next w-10 h-12 md:h-[60px] md:w-12 pagination-arrow rounded-corners relative overflow-hidden color-bg-[rgba(var(--color-secondary-button-no-alpha),0.4)]"
                  aria-label="{{ 'accessibility.next_button' | t }}"
                >
                  <span class="h-full w-full inline-block">
                    <span class="inline-block rtl:rotate-180 w-full h-full px-3 md:px-4">{% render 'icon-all', icon: 'icon-nav-arrow' %}</span>
                  </span>
                </button>
              </custom-button>
            </div>
          {% else %}
            {{ loading_progress }}
          {% endif %}
        {% endif %}
      </div>
    </div>
  {% endif %}
</div>
{% schema %}
