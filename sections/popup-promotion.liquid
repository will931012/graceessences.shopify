{%- liquid
  if section.settings.show_for_guests_only and shop.customer_accounts_enabled and customer.id != blank
    assign show_popup = false
  else
    assign show_popup = true
  endif

  assign show_countdown = false

  for block in section.blocks
    if block.type == 'countdown_timer'
      assign show_countdown = true
      assign block_countdown = block
    endif
  endfor

  if settings.lang_direction contains request.locale.iso_code
    assign is_rtl = true
  else
    assign is_rtl = false
  endif
-%}
{% capture popup_animation %}
  {% if section.settings.popup_position contains 'left' %}
    x-transition:enter-start="opacity-0 translate-y-1/3 md:translate-y-0 md:-translate-x-1/3"
    x-transition:enter-end="opacity-100 translate-y-0 md:translate-x-0"
    x-transition:leave-end="opacity-0 translate-y-1/3 md:translate-y-0 md:-translate-x-1/3"
  {% elsif section.settings.popup_position contains 'right' %}
    x-transition:enter-start="opacity-0 translate-y-1/3 md:translate-y-0 md:translate-x-1/3"
    x-transition:enter-end="opacity-100 translate-y-0 md:translate-x-0"
    x-transition:leave-end="opacity-0 translate-y-1/3 md:translate-y-0 md:translate-x-1/3"
  {% else %}
    x-transition:enter-start="opacity-0 translate-y-1/3"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 translate-y-1/3"
  {% endif %}
{% endcapture %}
{% if show_popup %}
  <div 
    x-data='xPopups({
      "sectionId": "{{ section.id }}",
      "name": "popup-promotion",
      "delays": {{ section.settings.delay }},
      "delayDays": {{ section.settings.reappear_after }},
      "show_popup": {{ show_popup }},
      "showOnMobile": {{ section.settings.show_on_mobile }},
      "schedule_enabled": {{ section.settings.schedule_enabled }},
      "showCountdown": {{ show_countdown }},
      "overlay": {{ settings.show_popup_overlay }},
      "showMinimal": {{ section.settings.enable_desktop }},
      "showMinimalMobile": {{ section.settings.enable_mobile }},
      "default_style": "{{ section.settings.default_style }}",
      "default_style_mobile": "{{ section.settings.default_style_mobile }}"
    })'
  >
    <template x-teleport="#maximize-popup">
      {% if show_countdown %}
        {%- capture countdown_popup -%}
          {
            "blockId": "{{ block_countdown.id }}",
            "schedule_enabled": {{ section.settings.schedule_enabled | default: false }},
            "timezone": {{ block_countdown.settings.timezone | default: 0 }},
            "start_year": {{ block_countdown.settings.start_year | default: 0 }},
            "start_month": {{ block_countdown.settings.start_month | default: 0 }},
            "start_day": {{ block_countdown.settings.start_day | default: 0 }},
            "start_hour": {{ block_countdown.settings.start_hour | default: 0 }},
            "start_minute": {{ block_countdown.settings.start_minute | default: 0 }},
            "end_year": {{ block_countdown.settings.end_year | default: 0 }},
            "end_month": {{ block_countdown.settings.end_month | default: 0 }},
            "end_day": {{ block_countdown.settings.end_day | default: 0 }},
            "end_hour": {{ block_countdown.settings.end_hour | default: 0 }},
            "end_minute": {{ block_countdown.settings.end_minute | default: 0 }}
          }
        {%- endcapture -%}
      {% endif %}
      <div 
        id="PromoPopup__Container__{{ section.id }}"
        x-cloak 
        class="promo-popup__container
        {%- if settings.edges_type == 'rounded_corners' %} rounded-[20px]{% endif -%}"
        {%- unless settings.show_popup_overlay %}
          x-effect="show ? setTimeout(() => $el.classList.add('popup-shadow', 'transition-shadow'), 500) : $el.classList.remove('popup-shadow', 'transition-shadow')"
        {% endunless -%}
        {% if show_countdown and request.design_mode == false %} x-show="show && enable"{% else %} x-show="show"{% endif %}
      >
        <div id="PopupFullWidth-{{ section.id }}" class="w-full md:w-auto md:absolute md:z-[60] md:promotion-alignment--{{ section.settings.popup_position }} pointer-events-auto
          {%- unless section.settings.show_on_mobile %} hidden md:block{% endunless -%}"
        >
          <div 
            class="popup-content p-0 md:min-h-[unset] max-h-[unset] m-[unset] w-full color-{{ section.settings.color_scheme_light }} dark-color-{{ section.settings.color_scheme_dark }}
            {%- if section.settings.image %} md:w-[750px] lg:w-[810px]{% else %} min-w-[300px] max-w-[510px]{% endif -%}
            {%- if settings.edges_type == 'rounded_corners' %} rounded-[20px] overflow-hidden{% endif -%}
            {%- unless settings.show_popup_overlay %} popup-shadow{% endunless -%}"
            {% if request.design_mode %} x-init="show && load();" {% else %} x-init="load()" {% endif %}
            {% if show_countdown and request.design_mode == false %} x-show="show && enable" {% else %} x-show="show" {% endif %}
            {% if settings.show_popup_overlay %}@click.outside="close();"{% endif %}
            {{ popup_animation }}
            {% unless section.settings.enable_desktop and section.settings.default_style == 'minimal' %}
              data-is-first-load="true"
            {% else %}
              data-is-first-load="false"
            {% endunless %}
             x-intersect.full="handleFocusPopup()"
             @keyup.escape="$store.xFocusElement.removeTrapFocus(); close();"
          >
            <button id="ClosePromotionPopup__{{ section.id }}" 
              class="modal__button-close-absolute md:top-3 md:ltr:right-3 md:rtl:left-3"
              @click.prevent.stop="$store.xFocusElement.removeTrapFocus(); close();"
              aria-label="{{ 'accessibility.close' | t }}"
            >
              <span class="button__close icon-close-medium-desktop icon-close-medium-mobile">{%- render 'icon-all', icon: 'icon-close' -%}</span>
            </button>
            <div 
              class="max-h-[none] pt-11 md:pt-[54px] pb-4
                {%- if section.settings.image != blank %} md:pb-[54px]{% else %} md:pb-8{% endif -%}
                {%- if is_rtl -%} ltr{% endif -%}
                {%- if section.settings.image != blank %} flex-col flex md:flex-row{% endif -%}
                {%- if section.settings.content_position == 'right' %} flex-col-reverse md:flex-row-reverse{% endif -%}
              "
            >
              <div class="flex-1 promotion--has-image:w-[54%] max-h-[calc(75vh-96px)] md:max-h-[85vh] 2xl:max-h-[77vh] content-text-{{ section.id }} {% if is_rtl %} rtl{% endif %} text-{{ section.settings.content_alignment }} ltr overflow-y-scroll scrollbar-body scrollbar-visible px-4 md:px-8 w-full py-0.5">
                <div id="x-promotion-{{ section.id }}" class="promotion anm-fade-element" x-intersect.once="$el.classList.add('is-visible')"
                  {% if show_countdown %}
                    x-data="{ loading: true, textLoad: '-', days: 0, hours: 0, minutes: 0, seconds: 0 }"
                    x-countdown-data='{{ countdown_popup }}'
                    x-intersect='$nextTick(() => {
                                if (!{{ section.settings.show_on_mobile }} && window.innerWidth < 768) return;
                                $store.xHelper.countdown({{ countdown_popup }}, (canShow, s, m, h, d) => {
                                  days = d;
                                  hours = h;
                                  minutes = m;
                                  seconds = s;
                                  loading = false;
                                })
                              })' 
                  {% endif %}
                >
                  {%- for block in section.blocks -%}
                    {% case block.type %}
                      {%- when 'heading' -%}
                        {% assign minimal_default_text = block.settings.heading %}
                        {%- if block.settings.heading != blank or block.settings.subheading != blank -%}
                          <div class="promo-popup__heading block-{{ section.id }}{% unless forloop.last %} mb-4{% endunless %}" {{ block.shopify_attributes }}>
                            {%- style -%}
                              .maximize-theme:not(.dark) .heading-{{ section.id }} {
                              {%- if block.settings.heading_color.alpha != 0 -%}
                                color: {{ block.settings.heading_color }};
                                --color-heading: {{ block.settings.heading_color.red }} {{ block.settings.heading_color.green }} {{ block.settings.heading_color.blue }} / {{ block.settings.heading_color.alpha }};
                              {%- else -%}
                                color: rgba(var(--color-heading))
                              {%- endif -%}
                              }
                              .maximize-theme:not(.dark) .subheading-{{ section.id }} {
                              {%- if block.settings.heading_color.alpha != 0 -%}
                                color: rgba({{ block.settings.heading_color.red }} {{ block.settings.heading_color.green }} {{ block.settings.heading_color.blue }} / 0.6);
                              {%- else -%}
                                color: rgba(var(--color-heading-no-alpha) / 0.6)
                              {%- endif -%}
                              }
                              .dark .heading-{{ section.id }} {
                              {%- if block.settings.heading_color_dark.alpha != 0 -%}
                                color: {{ block.settings.heading_color_dark }};
                                --color-heading: {{ block.settings.heading_color_dark.red }} {{ block.settings.heading_color_dark.green }} {{ block.settings.heading_color_dark.blue }} / {{ block.settings.heading_color_dark.alpha }};
                              {%- else -%}
                                color: rgba(var(--color-heading));
                              {%- endif -%}
                              }
                              .maximize-theme.dark .subheading-{{ section.id }} {
                              {%- if block.settings.heading_color_dark.alpha != 0 -%}
                                color: rgba({{ block.settings.heading_color_dark.red }} {{ block.settings.heading_color_dark.green }} {{ block.settings.heading_color_dark.blue }} / 0.6);
                              {%- else -%}
                                color: rgba(var(--color-heading-no-alpha) / 0.6)
                              {%- endif -%}
                              }
                              .maximize-theme:not(.dark) .heading-minimal-{{ section.id }} {
                              font-weight: var(--font-heading-weight);
                              {%- if block.settings.heading_color.alpha != 0 -%}
                                color: {{ block.settings.heading_color }};
                              {%- endif -%}
                              }
                              .dark .heading-minimal-{{ section.id }} {
                              {%- if block.settings.heading_color_dark.alpha != 0 -%}
                                color: {{ block.settings.heading_color_dark }};
                              {%- endif -%}
                              }
                            {%- endstyle -%}
                            {%- if block.settings.subheading != blank -%}
                              <p class="promo-popup__heading__subheading subheading-{{ section.id }} subheading">{{ block.settings.subheading }}</p>
                            {%- endif -%}
                            {%- if block.settings.heading != blank -%}
                              <p class="promo-popup__heading__heading h2 heading-{{ section.id }} p-break-words heading-{{ block.settings.heading_size }} mt-0.5">
                                {% render 'text-highlight',
                                  id: block.id,
                                  text: block.settings.heading,
                                  highlight_effect: block.settings.highlight_effect,
                                  text_transform: block.settings.text_transform
                                %}
                              </p>
                            {%- endif -%}
                          </div>
                        {%- endif -%}
                      {%- when 'text' -%}
                        {% if block.settings.text != blank %}
                          {% if block.settings.coupon_code != blank and block.settings.text contains 'coupon_code' %}
                            {% style %}
                              .block-{{ section.id }}.rte p {
                                display: inline;
                              }
                              {%- if block.settings.coupon_color.alpha != 0 -%}
                                .maximize-theme:not(.dark) .promo-popup__container .border-text-{{ block.id }} {
                                  --color-highlight: {{ block.settings.coupon_color.red }} {{ block.settings.coupon_color.green }} {{ block.settings.coupon_color.blue }} / {{ block.settings.coupon_color.alpha }};
                                }
                              {%- endif -%}
                              
                              {%- if block.settings.coupon_color_dark.alpha != 0 -%}
                                .dark .promo-popup__container .border-text-{{ block.id }} {
                                  --color-highlight: {{ block.settings.coupon_color_dark.red }} {{ block.settings.coupon_color_dark.green }} {{ block.settings.coupon_color_dark.blue }} / {{ block.settings.coupon_color_dark.alpha }};
                                }
                              {%- endif -%}
  
                            {% endstyle %}
                            {% capture coupon_code %}
                              <div 
                                :title="copySuccess?'{{ 'general.global.copied' | t }}':'{{ 'general.global.copy_code' | t }}'" 
                                x-data='xCouponCode'
                                x-on:click="copyCode()"
                                @keyup.enter="copyCode()"
                                tabindex="0"
                                class="button-coupon--{{ block.id }} border-text-{{ block.id }} color-text-[rgba(var(--color-highlight))] color-border-[rgba(var(--color-highlight))] mx-1 cursor-pointer border rounded-full border-dashed overflow-hidden items-center w-fit inline-flex btn--{{ block.id }} none_transition empty:hidden center px-2 py-1 md:pl-3 md:pr-2.5"
                              >
                                <span class="leading-none h-[1em] coupon-code" x-intersect.once="$el.classList.add('is-visible')" x-ref="code_value">
                                  {{ block.settings.coupon_code | escape }}
                                </span>
                                <div class="ml-3 flex items-center">
                                  <span class="min-w-[12px] min-h-[12px] h-[1em] w-[1em]" x-cloak x-show="!copySuccess"
                                    x-transition:enter="transition-all absolute ease-in-out duration-300"
                                    x-transition:enter-start="opacity-0 absolute translate-y-full"
                                    x-transition:enter-end="opacity-100 absolute translate-y-0"
                                    x-transition:leave="transition-all absolute ease-in-out duration-300"
                                    x-transition:leave-end="opacity-0 absolute -translate-y-full"
                                  >
                                    {% render 'icon-all', icon: 'icon-copy' %}
                                  </span>
                                  <span class="min-w-[12px] min-h-[12px] h-[1em] w-[1em]" x-cloak x-show="copySuccess"
                                    x-transition:enter="transition-all ease-in-out duration-300"
                                    x-transition:enter-start="opacity-0 translate-y-full"
                                    x-transition:enter-end="opacity-100 translate-y-0"
                                    x-transition:leave="transition ease-in-out duration-300"
                                    x-transition:leave-end="opacity-0 -translate-y-full"
                                  >
                                    {% render 'icon-all', icon: 'icon-check' %}
                                  </span>
                                </div>
                              </div>
                            {% endcapture %}
                          {% else %}
                            {% capture coupon_code %}
                            {% endcapture %}
                          {% endif %}
                          {% assign text = block.settings.text | replace: "coupon_code", coupon_code %}
                          <div class="promo-popup__text block-{{ section.id }} color-text-[rgba(var(--color-text))] p-break-words rte leading-tight rte {% unless forloop.last %} mb-4{% endunless %}"
                            {{ block.shopify_attributes }}
                          >
                            {{ text }}
                          </div>
                          {% if block.settings.coupon_code != blank and block.settings.text contains 'coupon_code' %}
                            <script src="{{ 'coupon-code.js' | asset_url }}" defer></script>
                          {% endif %}
                        {% endif %}
                      {%- when 'button' -%}
                        {%- style -%}
                          .maximize-theme:not(.dark) .button.button--{{ block.id }} {
                            {%- if block.settings.button_text_color.alpha != 0.0 -%}
                              --color-button-text: {{ block.settings.button_text_color.red }} {{ block.settings.button_text_color.green }} {{ block.settings.button_text_color.blue }} / {{ block.settings.button_text_color.alpha }};
                              --color-button-text-no-alpha: {{ block.settings.button_text_color.red }} {{ block.settings.button_text_color.green }} {{ block.settings.button_text_color.blue }};
                            {%- endif -%}
                            {%- if block.settings.button_color.alpha != 0.0 -%}
                              --color-button: {{ block.settings.button_color.red }} {{ block.settings.button_color.green }} {{ block.settings.button_color.blue }} / {{ block.settings.button_color.alpha }};
                            {%- endif -%}
                          }
                          .dark .button.button--{{ block.id }} {
                            {%- if block.settings.button_text_color_dark.alpha != 0.0 -%}
                              --color-button-text: {{ block.settings.button_text_color_dark.red }} {{ block.settings.button_text_color_dark.green }} {{ block.settings.button_text_color_dark.blue }} / {{ block.settings.button_text_color_dark.alpha }};
                              --color-button-text-no-alpha: {{ block.settings.button_text_color_dark.red }} {{ block.settings.button_text_color_dark.green }} {{ block.settings.button_text_color_dark.blue }};
                            {%- endif -%}
                            {%- if block.settings.button_color_dark.alpha != 0.0 -%}
                              --color-button: {{ block.settings.button_color_dark.red }} {{ block.settings.button_color_dark.green }} {{ block.settings.button_color_dark.blue }} / {{ block.settings.button_color_dark.alpha }};
                            {%- endif -%}
                          }
                        {%- endstyle -%}
                        {%- if block.settings.button_label != blank -%}
                          <div {% unless forloop.last %} class="mb-4"{% endunless %}>
                            {% assign class_button = 'promo-popup__button button--' |  append: block.id |  append: ' cursor-pointer pointer-events-auto pt-3.5 pb-3.5'%}
                            {% render 'button',
                              button_style: "primary",
                              button_label: block.settings.button_label,
                              button_link: block.settings.button_link,
                              open_new_window_button: block.settings.open_new_window,
                              class: class_button
                            %}
                          </div>
                        {%- endif -%}
                      {%- when 'countdown_timer' -%}
                        {%- style -%}
                          .maximize-theme:not(.dark) #promo-popup__countdown__wrapper__{{ section.id }} {
                            {%- if block.settings.background_color.alpha != 0 -%}
                              --color-button: {{ block.settings.background_color.red }} {{ block.settings.background_color.green }} {{ block.settings.background_color.blue }} / {{ block.settings.background_color.alpha }};
                            {%- endif -%}
                            {%- if block.settings.time_color.alpha != 0 -%}
                              --color-button-text: {{ block.settings.time_color.red }} {{ block.settings.time_color.green }} {{ block.settings.time_color.blue }} / {{ block.settings.time_color.alpha }};
                            {%- endif -%}
                          }
                          .maximize-theme.dark #promo-popup__countdown__wrapper__{{ section.id }} {
                            {%- if block.settings.background_color_dark.alpha != 0 -%}
                              --color-button: {{ block.settings.background_color_dark.red }} {{ block.settings.background_color_dark.green }} {{ block.settings.background_color_dark.blue }} / {{ block.settings.background_color_dark.alpha }};
                            {%- endif -%}
                            {%- if block.settings.time_color_dark.alpha != 0 -%}
                              --color-button-text: {{ block.settings.time_color_dark.red }} {{ block.settings.time_color_dark.green }} {{ block.settings.time_color_dark.blue }} / {{ block.settings.time_color_dark.alpha }};
                            {%- endif -%}
                          }
                        {%- endstyle -%}
                        {% assign class_block_countdown = 'countdown-timer__item flex flex-col justify-center items-center countdown-timer__item__' | append: block.id %}
                        <div 
                          id="promo-popup__countdown__wrapper__{{ section.id }}"
                          class="block-{{ section.id }} x-countdown w-full flex justify-{{ section.settings.content_alignment }}{% unless forloop.last %} mb-4{% endunless %}"
                          {{ block.shopify_attributes }}
                        >
                          <div id="promo-popup__countdown x-popup-countdown-{{ block.id }}"
                              class="x-content-popup-countdown countdown-timer__wrapper countdown-timer__{{ block.settings.text_size }} flex items-center gap-1">
                            <div class="promo-popup__countdown__days {{ class_block_countdown }}">
                              <span x-html="loading?textLoad:days"></span>
                            </div>
                            <div class="countdown-colons-{{ block.id }} countdown-timer__colon h-3 w-1 will-change-transform">{% render 'icon-all', icon: 'colons' %}</div>
                            <div class="promo-popup__countdown__hrs {{ class_block_countdown }}">
                              <span x-html="loading?textLoad:hours"></span>
                            </div>
                            <div class="countdown-colons-{{ block.id }} countdown-timer__colon h-3 w-1 will-change-transform">{% render 'icon-all', icon: 'colons' %}</div>
                            <div class="promo-popup__countdown__mins {{ class_block_countdown }}">
                              <span x-html="loading?textLoad:minutes"></span>
                            </div>
                            <div class="countdown-colons-{{ block.id }} countdown-timer__colon h-3 w-1 will-change-transform">{% render 'icon-all', icon: 'colons' %}</div>
                            <div class="promo-popup__countdown__secs {{ class_block_countdown }}">
                              <span x-html="loading?textLoad:seconds"></span>
                            </div>
                          </div>
                        </div>
                      {%- when 'email_form' -%}
                        <div x-data="{ email: '', error: validateEmail('') }" {{ block.shopify_attributes }} class="promo-popup__email-form{% unless forloop.last %} mb-4{% endunless %}">
                          {%- assign newsletter_form_id = 'newsletter-' | append: section.id -%}
                          {%- form 'customer', id: newsletter_form_id -%}
                            {%- unless form.posted_successfully? -%}
                              <input type="hidden" name="contact[tags]" value="newsletter">
                              <div class="flex text-field__wrapper text-field__has-button{% if is_rtl %} rtl{% endif %}">
                                <div class="text-field__content">
                                  <input
                                    id="Email--{{ section.id }}"
                                    type="email"
                                    name="contact[email]"
                                    class="text-field__input"
                                    value="{% if customer %}{{ customer.email }}{% endif %}"
                                    aria-required="true"
                                    autocorrect="off"
                                    autocapitalize="off"
                                    autocomplete="email"
                                    placeholder="{{ 'newsletter.label' | t }}"
                                    x-model="email"
                                    @input.debounce.500ms="error = validateEmail(email)"
                                    required
                                  >
                                  <label 
                                    for="Email--{{ section.id }}"
                                    class="text-field__label" 
                                  >
                                    {{ 'newsletter.label' | t }}
                                  </label>
                                </div>
                                <custom-button>
                                  <button 
                                    type="submit" 
                                    class="button button-primary flex justify-end items-center px-3 py-2 cursor-pointer"
                                    name="commit" 
                                    aria-label="{{ 'newsletter.button_label' | t }}"
                                    :disabled="error.isError === true"
                                  >
                                    {% assign button_label = 'newsletter.button_label' | t %}
                                    {% render 'button-label', button_label: button_label, show_button_style: 'primary' %}
                                  </button>
                                </custom-button>
                              </div> 
                              <div 
                                id="{{ newsletter_form_id }}__validation"
                                class="flash-message error-message mt-1"
                                x-show="error.isError === true && error.isInvalid === true"
                              >
                                <p>{{ 'products.product.recipient.message_email_invalid' | t }}</p>
                              </div>
                            {%- else -%}
                              <div 
                                id="Newsletter__Success--{{ section.id }}"
                                class="newsletter-message flash-message success-message text-x-small text-left w-full mt-4{% unless forloop.last %} mb-4{% endunless %} focus:shadown-none focus-visible:outline-none focus:outline-none focus-visible:shadow-none rounded-corners-md"
                                tabindex="-1" 
                                autofocus
                              >
                                <p>{{ 'newsletter.success' | t }}</p>
                              </div>
                            {%- endunless -%}
                            {%- if form.errors -%}
                              <div 
                                id="Newsletter__Error--{{ section.id }}"
                                class="newsletter-message flash-message error-message text-x-small text-left w-full mt-4{% unless forloop.last %} mb-4{% endunless %} focus:shadown-none focus-visible:outline-none focus:outline-none focus-visible:shadow-none rounded-corners-md"
                              >
                                <p>{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</p>
                              </div>
                            {%- endif -%}
                          {%- endform -%}
                        </div>
                      {%- when 'social-icons' -%}
                        <ul class="block-{{ section.id }} md:flex flex-wrap justify-{{ section.settings.content_alignment }}{% unless forloop.last %} mb-4{% endunless %}
                          {%- unless block.settings.show_on_mobile %} hidden{% else %} flex{% endunless -%}" 
                          {{ block.shopify_attributes }}
                        >
                          {%- render 'social-icons', custom_class: ' w-7.5 h-7.5 p-[5px]' -%}
                        </ul>
                    {% endcase %}
                  {%- endfor -%}
                </div>
              </div>
              {%- if section.settings.image != blank -%}
                <div class="hidden md:block w-1/2 relative overflow-hidden md:-mt-[54px]
                  {%- if section.settings.image != blank %} md:-mb-[54px]{% else %} md:-mb-8{% endif -%}">
                  {%- capture sizes -%} (min-width: {{ settings.page_width }}px) calc((1000px) / 2) , (min-width: 768px) calc((100vw) / 2), 100vw
                  {%- endcapture -%}
                  {% liquid
                    assign default_image_alt = 'accessibility.default_alt' | t
                    assign image_alt = section.settings.image | default: default_image_alt
                  %}
                  {{ section.settings.image | image_url: width: 1500 | image_tag: loading: "lazy", sizes: sizes, widths: '450, 750, 900, 1100, 1500, 1780, 2000, 3000, 3840', class: 'h-full w-full object-cover z-0 absolute inset-0 image-hover', alt: image_alt }}
                </div>
              {%- endif -%}
            </div>
          </div>
        </div>
      </div>
    </template>
    {% if section.settings.enable_desktop or section.settings.enable_mobile %}
      {% liquid 
        assign class_show_minimal = ' '
        unless section.settings.enable_desktop
          assign class_show_minimal = 'md:hidden '
        else 
          assign class_show_minimal = 'md:flex '
        endunless
        if section.settings.enable_mobile == false or section.settings.show_on_mobile == false
          assign class_show_minimal = class_show_minimal | append: 'hidden '
        else
          assign class_show_minimal = class_show_minimal | append: 'flex '
        endif
      %}
      <template x-teleport="#popup-minimal-{{ settings.position_minimal }}">
        <div 
          x-show="showMinimal" 
          x-cloak
        >
          <div 
            class="relative mb-2 {{ class_show_minimal }}" 
            x-show="showMinimal" 
            x-cloak
            x-transition:enter="transition-all ease-in-out duration-300"
            x-transition:enter-start="opacity-0 transform md:-translate-x-1/3 translate-y-1/3 md:translate-y-0"
            x-transition:enter-end="opacity-100 transform md:translate-x-0 translate-y-0"
            x-transition:leave="transition-all ease-in-out duration-300"
            x-transition:leave-end="opacity-0 transform md:translate-x-1/3 translate-y-1/3 md:translate-y-0"
            @keyup.escape="closeMinimal()"
          >
            <div 
              class="w-full p-2 md:p-3 ltr:pl-3 rtl:pr-3 md:ltr:pl-4 md:rtl:pr-4 !bg-gradient-no-alpha color-{{ section.settings.color_scheme_light }} dark-color-{{ section.settings.color_scheme_dark }} hover:cursor-pointer shadow-small rounded-corners{% if settings.edges_type == 'rounded_corners' %} rounded-[10px] overflow-hidden{% endif %}"
              aria-label="{{ 'products.modal.label' | t }}"
              @click.prevent="clickMinimal()"
              @keyup.enter="clickMinimal()"
              tabindex="0"
            >
              <div class="modal-title-wrapper gap-3">
                <div class="grow flex items-center">
                  <div class="content-text-{{ section.id }} leading-5">
                    {% if section.settings.minimal_subtitle != blank %}
                      <p class="text-[85%] anm-fade-element" x-intersect.once="$el.classList.add('is-visible')">{{ section.settings.minimal_subtitle }}</p>
                    {% endif %}
                    {% if section.settings.minimal_title != blank %}
                      <p class="heading-minimal-{{ section.id }} anm-fade-element" x-intersect.once="$el.classList.add('is-visible')">{{ section.settings.minimal_title }}</p>
                    {% endif %}
                    {% if section.settings.minimal_subtitle == blank and section.settings.minimal_title == blank %}
                      <p class="heading-minimal-{{ section.id }} anm-fade-element" x-intersect.once="$el.classList.add('is-visible')">
                        {% if minimal_default_text != blank %}
                          {{ minimal_default_text | remove: '[' | remove: ']' }}
                        {% else %}
                          {{ 'sections.popup.popup_minimal' | t }}
                        {% endif %}
                      </p>
                    {% endif %}
                  </div>
                </div>
                <button aria-label="{{ 'accessibility.close' | t }}"
                  class="cursor-pointer h-fit content-text-{{ section.id }} {{ class_show_minimal }}"
                  @click.prevent.stop="closeMinimal()"
                  @keyup.enter.stop
                >
                  <span class="button__close icon-close-xsmall-desktop icon-close-xsmall-mobile">
                    {% render 'icon-all', icon: 'icon-close' %}
                  </span>
                </button>
              </div>
            </div>
          </div>
        </div>
      </template>
    {% endif %}
  </div>
  <script src="{{ 'popup.js' | asset_url }}" defer></script>
  <script src="{{ 'coupon-code.js' | asset_url }}" defer></script>
{% endif %}
