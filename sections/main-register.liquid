{%  liquid 
if settings.lang_direction contains request.locale.iso_code
  assign is_rtl = true
else
  assign is_rtl = false
endif
%}
{% style %}
  .section--{{ section.id }} {
    padding-top: calc({{ section.settings.padding_top }}px * var(--mobile-padding-ratio));
    padding-bottom: calc({{ section.settings.padding_bottom }}px * var(--mobile-padding-ratio));
  }
  @media (min-width: 768px) {
    .section--{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}
<div class="section--{{ section.id }} px-5">
  <h1 class="h2 text-center mb-5 md:mb-7.5 font-bold anm-fade-element" x-intersect.once="$el.classList.add('is-visible')">{{ 'customer.register.title' | t }}</h1>
  {%- form 'create_customer' -%}
    {%- if form.errors -%}
      {% capture check_notice %}
        <div class="flash-message error-message w-full mb-4 flex flex-wrap items-center max-w-[600px] pt-3.5 pb-3.5 ml-auto mr-auto focus:shadown-none focus-visible:outline-none focus:outline-none focus-visible:shadow-none">
          <h2 class="text-large w-full max-w-[600px] ml-auto mr-auto outline-none" tabindex="-1" autofocus>
            <span>
              {% render 'icon-all', icon: 'icon-error', enable_customer_page: true %}
            </span>
            {{ 'templates.contact.form.error_heading' | t }}
          </h2>
          <ul class="w-full max-w-[600px] ml-auto mr-auto pl-12 rtl:pl-0 rtl:pr-12">
            {%- for field in form.errors -%}
              <li class="list-disc">
                {%- if field == 'form' -%}
                  {{ form.errors.messages[field] }}
                {%- else -%}
                  <a href="#RegisterForm-{{ field }}" class="error-field">
                    {{ form.errors.translated_fields[field] | capitalize }}
                    {{ form.errors.messages[field] }}
                  </a>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {% endcapture %}
      {{ check_notice }}
    {%- endif -%}
    <div class="text-field__wrapper mx-auto mb-2.5 max-w-[600px]">
      <input
        id="RegisterForm-FirstName"
        class="text-field__input"
        type="text"
        name="customer[first_name]"
        {% if form.first_name %}value="{{ form.first_name }}"{% endif %}
        autocomplete="given-name"
        placeholder="{{ 'customer.register.first_name' | t }}"
      >
      <label
        for="RegisterForm-FirstName"
        class="text-field__label"
      >
        {{ 'customer.register.first_name' | t }}
      </label>
    </div>
    <div class="text-field__wrapper max-w-[600px] mx-auto mb-2.5">
      <input
        id="RegisterForm-LastName"
        class="text-field__input"
        type="text"
        name="customer[last_name]"
        {% if form.last_name %}value="{{ form.last_name }}"{% endif %}
        autocomplete="family-name"
        placeholder="{{ 'customer.register.last_name' | t }}"
      >
      <label
        for="RegisterForm-LastName"
        class="text-field__label"
      >
        {{ 'customer.register.last_name' | t }}
      </label>
    </div>
    <div class="text-field__wrapper max-w-[600px] mx-auto mb-2.5">
      <input
        id="RegisterForm-email"
        class="text-field__input"
        type="email"
        name="customer[email]"
        {% if form.email %} value="{{ form.email }}"{% endif %}
        spellcheck="false" 
        autocapitalize="off" 
        autocomplete="email" 
        aria-required="true"
        required="required" 
        {% if form.errors contains 'email' %}
          aria-invalid="true"
          aria-describedby="RegisterForm-email-error"
        {% endif %}
        placeholder="{{ 'customer.register.email' | t }}"
      >
      <label
        for="RegisterForm-email"
        class="text-field__label"
      >
        {{ 'customer.register.email' | t }}
      </label>
    </div>
    {%- if form.errors contains 'email' -%}
      <span id="RegisterForm-email-error" class="color-text-[rgba(var(--error-message-color))] block text-xx-small mt-0.5 w-full max-w-[600px] mr-auto ml-auto mb-2.5">
        <span class="ml-0.5 -mt-2">{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}.</span>
      </span>
    {%- endif -%}
    <div class="text-field__wrapper max-w-[600px] mx-auto">
      <input
        id="RegisterForm-password"
        class="text-field__input"
        type="password"
        name="customer[password]"
        aria-required="true"
        required="required"
        {% if form.errors contains 'password' %}
          aria-invalid="true"
          aria-describedby="RegisterForm-password-error"
        {% endif %}
        placeholder="{{ 'customer.register.password' | t }}"
      >
      <label
        for="RegisterForm-password"
        class="text-field__label"
      >
        {{ 'customer.register.password' | t }}
      </label>
    </div>
    {%- if form.errors contains 'password' -%}
      <span id="RegisterForm-password-error" class="color-text-[rgba(var(--error-message-color))] block text-xx-small mt-2.5 w-full max-w-[600px] mr-auto ml-auto">
        <span class="ml-0.5 -mt-2">{{ form.errors.translated_fields['password'] | capitalize }} {{ form.errors.messages['password'] }}</span>
      </span>
    {%- endif -%}
    <div class="w-full flex justify-center">
      <custom-button>
        <button class="button button-primary w-full block mr-auto ml-auto max-w-[600px] pt-2.5 pb-2.5 md:pt-3 md:pb-3 mt-5 md:mt-[30px] leading-normal">
          {% assign button_label = 'customer.register.submit' | t %}
          {% render 'button-label', button_label: button_label, show_button_style: 'primary' %}
        </button>
      </custom-button>
    </div>
  {%- endform -%}
</div>
{% schema %}
{
  "name": "t:main_register.name",
  "settings": [
    {
      "type": "header",
      "content": "t:global.header.section_layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:global.section.top_padding",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:global.section.bottom_padding",
      "default": 52
    }
  ]
}
{% endschema %}
