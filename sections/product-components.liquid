{% liquid
  if section.settings.custom_image_mobile != blank
    assign mobile_img_wrapper = section.settings.custom_image_mobile
  elsif section.settings.custom_image != blank
    assign mobile_img_wrapper = section.settings.custom_image
  elsif section.settings.section_product
    assign mobile_img_wrapper = section.settings.section_product.featured_image  
  else 
    assign mobile_img_wrapper = false
  endif

  if section.settings.custom_image != blank
    assign desktop_img_wrapper = section.settings.custom_image
  elsif section.settings.section_product
    assign desktop_img_wrapper = section.settings.section_product.featured_image
  else 
    assign desktop_img_wrapper = false
  endif


  assign title_link = false
  assign section_text = section.settings.text
  if section.settings.section_product
    assign title_link = section.settings.section_product.url
    if section.settings.section_product.description != blank and section.settings.show_product_description
      assign section_text = section.settings.section_product.description
    endif
  endif

  if mobile_img_wrapper
    assign image_ratio_mobile = 1 | divided_by: mobile_img_wrapper.aspect_ratio | times: 100 | default: 56.25
  endif
  if desktop_img_wrapper
    assign image_ratio_desktop = 1 | divided_by: desktop_img_wrapper.aspect_ratio | times: 100 | default: 56.25
  endif

  assign section_id_for_class = section.id
  if request.visual_preview_mode
    assign section_id_for_class = section_id_for_class | replace: '=', '\='
  endif
%}
{% assign default_image_alt = 'accessibility.default_alt' | t %}
{% style %}
  .section--{{ section_id_for_class }} {
    padding-top: calc({{ section.settings.padding_top }}px * var(--mobile-padding-ratio));
    padding-bottom: calc({{ section.settings.padding_bottom }}px * var(--mobile-padding-ratio));
  }
  {% if section.settings.hotspot_color_light.alpha != 0.0 %}
    .maximize-theme:not(.dark) .section--{{ section_id_for_class }} .hotspot-{{ section_id_for_class }} {
      --gradient-background: rgba({{ section.settings.hotspot_color_light.red }} {{ section.settings.hotspot_color_light.green }} {{ section.settings.hotspot_color_light.blue }} / {{ section.settings.hotspot_color_light.alpha }});
    }
  {% endif %}
  {% if section.settings.hotspot_color_dark.alpha != 0.0 %}
    .dark .section--{{ section_id_for_class }} .hotspot-{{ section_id_for_class }} {
      --gradient-background: rgba({{ section.settings.hotspot_color_dark.red }} {{ section.settings.hotspot_color_dark.green }} {{ section.settings.hotspot_color_dark.blue }} / {{ section.settings.hotspot_color_dark.alpha }});
    }
  {% endif %}
  @media screen and (max-width: 767px) {
    .product-components__image.mobile-{{ section_id_for_class }} {
      padding-bottom: {{ image_ratio_mobile }}%;
    }
  }
  @media screen and (min-width: 768px) {
    .section--{{ section_id_for_class }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
    .product-components__image.desktop-{{ section_id_for_class }} {
      padding-bottom: {{ image_ratio_desktop }}%;
    }
  }
{% endstyle %}

{% render 'section-divider' %}

<div class="product-components section--{{ section.id }} {{ section.settings.section_width }} rounded-corners-container color-{{ section.settings.color_scheme_light }} dark-color-{{ section.settings.color_scheme_dark }}">
  <div class="product-components__wrapper flex gap-[var(--spacing-between-heading-and-content)]{% if section.settings.image_position == "top" %} flex-col-reverse{% else %} flex-col{% endif %}">
    {% if section.settings.heading != blank or section.settings.subheading != blank or section_text != blank or section.settings.button_label != blank or section.settings.show_product_description and section.settings.section_product %}
      <div class="product-components__header text-{{ section.settings.content_alignment }} flex flex-col gap-0.5 p-break-words">
        {% if section.settings.subheading != blank %}
          <p class="product-components__subheading subheading anm-fade-element" x-intersect.once="$el.classList.add('is-visible')">
            {{ section.settings.subheading }}
          </p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <{{ section.settings.heading_tag }} class="product-component__heading heading-{{ section.settings.heading_size }} anm-fade-element" x-intersect.once="$el.classList.add('is-visible')">
            {{ section.settings.heading }}
          </{{ section.settings.heading_tag }}>
        {% endif %}
        {% if section_text != blank or section.settings.button_label != blank or section.settings.button_label != blank %}
          <div class="product-components__content section-text-content--{{ section.id }}">
            {% if section_text != blank %}
              {%- render 'truncate-text',
                number_of_lines_shown: section.settings.number_of_lines_shown,
                currentId: section.id,
                content: section_text,
                text_alignment: section.settings.content_alignment,
                text_alignment_mobile: section.settings.content_alignment,
                read_more_label: section.settings.read_more_label,
                see_less_label: section.settings.see_less_label 
              -%}
            {% endif %}
            {% if section.settings.button_label != blank %}
              {% liquid
                assign button_link = title_link
                if section.settings.button_link != blank
                  assign button_link = section.settings.button_link
                endif
              %}
              {% render 'button',
                button_style: section.settings.button_style,
                button_label: section.settings.button_label,
                button_link: button_link,
                open_new_window_button: section.settings.open_new_window,
                class: 'w-fit mt-5'
              %}
            {% endif %}
          </div>
        {% endif %}
      </div>
    {% endif %}
    <div class="product-components__image-wrapper" x-data="{ hasPopupOpened: false, timeout: {} }">
      <div
        class="product-components__image relative
          {%- if section.settings.mobile_height == 'natural' %} h-0 mobile-{{ section.id }}{% else %} h-[{{ section.settings.mobile_height }}]{% endif -%}
          {%- if section.settings.desktop_height == 'natural' %} md:h-0 desktop-{{ section.id }}{% else %} md:h-[{{ section.settings.desktop_height }}] md:max-h-[100vh]{% endif -%}
        "
        :class="hasPopupOpened ? 'z-30' : 'z-20'"
      >
        <div class="absolute w-full h-full rounded-corners overflow-hidden">
          {%- if desktop_img_wrapper -%}
            <picture>
              <source
                srcset="{{ mobile_img_wrapper | image_url: width: 375 }} 375w,
                  {{ mobile_img_wrapper | image_url: width: 450 }} 450w,
                  {{ mobile_img_wrapper | image_url: width: 750 }} 750w,
                  {{ mobile_img_wrapper | image_url: width: 900 }} 900w,
                  {{ mobile_img_wrapper | image_url: width: 1100 }} 1100w,
                  {{ mobile_img_wrapper | image_url: width: 1500 }} 1500w"
                media="(max-width: 767px)"
                width="{{ mobile_img_wrapper.width }}"
                height="{{ mobile_img_wrapper.height }}"
              />
              <img
                src="{{ desktop_img_wrapper | image_url: width: 2000 }}"
                alt="{{ desktop_img_wrapper.alt | default: default_image_alt | escape }}"
                sizes="(min-width: 768px)
                  {%- if section.settings.section_width == 'page-width' %} calc({{ settings.page_width }}px + 64px){% elsif section.settings.section_width == 'full-width-padded' %} calc(100vw - 64px){% else %} 100vw{% endif -%}, 100vw"
                srcset="
                  {{ desktop_img_wrapper | image_url: width: 450 }} 450w,
                  {{ desktop_img_wrapper | image_url: width: 750 }} 750w,
                  {{ desktop_img_wrapper | image_url: width: 900 }} 900w,
                  {{ desktop_img_wrapper | image_url: width: 1100 }} 1100w,
                  {{ desktop_img_wrapper | image_url: width: 1500 }} 1500w,
                  {{ desktop_img_wrapper | image_url: width: 1780 }} 1780w,
                  {{ desktop_img_wrapper | image_url: width: 2000 }} 2000w,
                  {{ desktop_img_wrapper | image_url: width: 3000 }} 3000w,
                  {{ desktop_img_wrapper | image_url: width: 3840 }} 3840w
                "
                width="{{ desktop_img_wrapper.width }}"
                height="{{ desktop_img_wrapper.height }}"
                class="h-full w-full object-cover"
              >
            </picture>
          {%- else -%}
            {%- if mobile_img_wrapper -%}
              <img
                srcset="{{ mobile_img_wrapper | image_url: width: 375 }} 375w,
                {{ mobile_img_wrapper | image_url: width: 450 }} 450w,
                {{ mobile_img_wrapper | image_url: width: 750 }} 750w,
                {{ mobile_img_wrapper | image_url: width: 900 }} 900w,
                {{ mobile_img_wrapper | image_url: width: 1100 }} 1100w,
                {{ mobile_img_wrapper | image_url: width: 1500 }} 1500w"
                sizes="100vw"
                src="{{ mobile_img_wrapper | image_url: width: 750 }}"
                alt="{{ mobile_img_wrapper.alt | default: default_image_alt | escape }}"
                class="h-full w-full object-cover md:hidden"
                loading="lazy"  
                width="{{ mobile_img_wrapper.width }}"
                height="{{ mobile_img_wrapper.height }}"
                style="object-position: {{ mobile_img_wrapper.presentation.focal_point }}"
              />
            {%- endif -%}
            <div class="items-center justify-center bg-[#dcdcdc] w-full h-full
              {%- if mobile_img_wrapper %} hidden md:flex{% else %} flex{% endif -%}"
            >
              {% render 'placeholder-image', image_type: 'product_1' %}
            </div>
          {%- endif -%}
        </div>
        {% for block in section.blocks %}
          {% liquid
            assign block_id_for_class = block.id
            if request.visual_preview_mode
              assign block_id_for_class = block_id_for_class | replace: '=', '\='
            endif
          %}
          {% style %}
            .section--{{ section_id_for_class }} .block--{{ block_id_for_class }} {
              top: {{ block.settings.vertical_mobile_position }}%;
              left: {{ block.settings.horizontal_mobile_position }}%;
            }
            {% if block.settings.horizontal_mobile_position >= 50 %}
              .tooltips--{{ block_id_for_class }} {
                --translateX-hotspot-content: -100%;
              }
            {% endif %}
            @media screen and (min-width: 768px) {
              .section--{{ section_id_for_class }} .block--{{ block_id_for_class }} {
                top: {{ block.settings.vertical_position }}%;
                left: {{ block.settings.horizontal_position }}%;
              }
              .tooltips--{{ block_id_for_class }} {
              {% if block.settings.horizontal_position >= 50 %}
                --translateX-hotspot-content: -100%;
              {% else %}
                --translateX-hotspot-content: 0%;
              {% endif %}
            }
          {% endstyle %}
          {% liquid
            assign show_media_type = false
            if block.settings.image != blank
              assign show_media_type = 'image'
            endif
            if block.settings.icon != 'none' and block.settings.icon != 'another'
              assign show_media_type = 'icon'
            elsif block.settings.icon == 'another' and block.settings.another_icon != blank
              assign show_media_type = 'icon'
            endif
            if block.settings.custom_icon != blank
              assign show_media_type = 'custom_icon'
            endif
          %}
          <div class="product-components__hotspots hotspot-{{ section.id }} block--{{ block.id }} hotspot-{{ forloop.index }} absolute -translate-x-1/2 -translate-y-1/2"
            :class="open ? 'z-30' : 'z-20'"
            x-data="xProductComponents('{{ block.id }}')"
            x-intersect.once="init()"
            @click.outside="onClickOutSide()"
            {{ block.shopify_attributes }}
          >
            <button class="product-components__hotspots__button color-bg-gradient-[var(--gradient-background)] w-8 h-8 md:w-10 md:h-10 will-change-transform hover:scale-110 duration-300 p-2 md:p-3 rounded-full relative z-10"
              aria-label="hotspot-button"
              @click.debounce.75ms="onClickHotspot()"
            >
              <span class="absolute w-full h-full top-0 left-0 p-2 md:p-3 duration-300"
                :class="open ? 'opacity-0' : 'opacity-100 delay-150'" x-cloak
                x-transition.overlay
              >
                {% if block.settings.custom_icon_image != blank %}
                  <img 
                    src="{{ block.settings.custom_icon_image | image_url: width: 16 }}"
                    alt="{{ block.settings.custom_icon_image.alt | default: default_image_alt | escape }}"
                    {% if section.index == 1 and section.location == 'template' %}
                      loading="eager"
                      fetchpriority="high"
                      decoding="sync"
                    {% else %}
                      loading="lazy"
                    {% endif %} 
                    width="{{ block.settings.custom_icon_image.width }}"
                    height="{{ block.settings.custom_icon_image.height }}"
                    style="object-position: {{ block.settings.custom_icon_image.presentation.focal_point }}"
                    class="object-cover w-4 h-4 rounded-corners"
                  >
                {% else %}
                  {% render 'icon-all', icon: block.settings.hotspot_icon %}
                {% endif %}
              </span>
              <span class="absolute w-full h-full top-0 left-0 p-2 md:p-3 duration-300"
                :class="open ? 'rotate-45 opacity-100' : 'rotate-0 opacity-0'"
                x-transition.overlay
              >
                {%- render 'icon-all', icon: 'icon-plus' -%}
              </span>
              <span class="animate-hotspot top-0 left-0 animate-component-hotspot absolute inline-flex color-bg-gradient-[var(--gradient-background)] h-full w-full rounded-full opacity-20"></span>
            </button>
            <div class="hotspot-content-wrapper shadow-medium tooltips--{{ block.id }} max-w-[11rem] md:max-w-[15.5rem] w-max h-auto absolute left-1/2 py-4 md:py-6 color-bg-gradient-[var(--gradient-background)] duration-300
                {%- if settings.edges_type == 'rounded_corners' %} rounded-[20px]{% endif -%}"
              :class="open ? 'visible opacity-1 open' : 'invisible opacity-0'"
              x-cloak
              x-ref="content"
            >
              <div class="product-components__hotspots__content px-4 md:px-6 w-full overflow-hidden max-h-[40vh] overflow-y-auto scrollbar-body scrollbar-visible" x-cloak>
                {% if show_media_type != false %}
                  <div class="hotspot-image w-[90px] h-[90px] md:w-[140px] md:h-[140px] mx-auto overflow-hidden mb-1.5 md:mb-3
                    {%- if block.settings.media_style == 'round' %} rounded-full{% else %} rounded-corners{% endif -%}"
                  >
                    {% case show_media_type %}
                      {% when 'image' %}
                        <img
                          src="{{ block.settings.image | image_url: width: 350 }}"
                          alt="{{ block.settings.image.alt | default: default_image_alt }}"
                          sizes="(min-width: 768px) 140px, 90px"
                          srcset="
                            {{ block.settings.image | image_url: width: 50 }} 50w,
                            {{ block.settings.image | image_url: width: 100 }} 100w,
                            {{ block.settings.image | image_url: width: 150 }} 150w,
                            {{ block.settings.image | image_url: width: 200 }} 200w,
                            {{ block.settings.image | image_url: width: 250 }} 250w,
                            {{ block.settings.image | image_url: width: 300 }} 300w,
                            {{ block.settings.image | image_url: width: 400 }} 400w,
                            {{ block.settings.image | image_url: width: 500 }} 500w,
                            {{ block.settings.image | image_url: width: 600 }} 600w
                          "
                          width="{{ block.settings.image.width }}"
                          height="{{ block.settings.image.height }}"
                          class="product-components__hotspots__content__img image-{{ block.id }} inline-block h-full w-full object-cover"
                        >
                      {% when 'icon' %}
                        <div class="product-components__hotspots__content__icon icon-{{ block.id }} w-full h-full p-2.5 md:p-[25px]">
                          {% if block.settings.icon == 'another' %}
                            {% render 'icon-another', icon: block.settings.another_icon %}  
                          {% else %}
                            {% render 'icon-labels-bags', icon: block.settings.icon %}
                          {% endif %}
                        </div>
                      {% when 'custom_icon' %}
                        <div class="product-components__hotspots__content__custom-icon custom-icon-{{ block.id }} w-full h-full p-2.5 md:p-[25px]">
                          {{ block.settings.custom_icon }}
                        </div>
                    {% endcase %}
                  </div>
                {% else %}
                  <div class="w-[90px] h-[90px] md:w-[140px] md:h-[140px] mx-auto overflow-hidden mb-1.5 md:mb-3{% if block.settings.media_style == 'round' %} rounded-full{% else %} rounded-corners{% endif %}">
                    {% render 'placeholder-image', image_type: 'image' %}
                  </div>
                {% endif %}
                <div class="product-components__hotspots__content__detail flex flex-col gap-1 md:gap-2 p-break-words text-{{ block.settings.content_alignment }}">
                  <p class="product-components__hotspots__content__heading h5">
                    {{ block.settings.heading }}
                  </p>
                  <div class="product-components__hotspots__content__text rte">
                    {{ block.settings.text }}
                  </div>
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<script src="{{ 'product-components.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "t:product_components.name",
  "tag": "section",
  "class": "maximize-section section-product-components",
  "disabled_on": {
    "groups": ["footer", "header", "aside"]
  },
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "t:global.text.subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:global.text.heading",
      "default": "Product components"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:global.text.heading_size",
      "options": [
        {
          "value": "small",
          "label": "t:global.size.small"
        },
        {
          "value": "medium",
          "label": "t:global.size.medium"
        },
        {
          "value": "large",
          "label": "t:global.size.large"
        }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "default": "h2",
      "label": "t:global.text.heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        },
        {
          "value": "p",
          "label": "p"
        }
      ]
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:global.text.text",
      "default": "<p>Highlight specific product components to your customers.</p>"
    },
    {
      "type": "select",
      "id": "number_of_lines_shown",
      "label": "t:global.text.default_content_height.label",
      "info": "t:global.text.default_content_height.info",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "t:global.text.default_content_height.show_full"
        },
        {
          "value": "small",
          "label": "t:global.size.small"
        },
        {
          "value": "medium",
          "label": "t:global.size.medium"
        },
        {
          "value": "large",
          "label": "t:global.size.large"
        }
      ]
    },
    {
      "type": "text",
      "id": "read_more_label",
      "default": "Read more",
      "label": "t:global.text.read_more_label"
    },
    {
      "type": "text",
      "id": "see_less_label",
      "default": "See less",
      "label": "t:global.text.see_less_label"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:global.button.button_label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:global.button.button_link",
      "info": "t:product_components.settings.button_link_info"
    },
    {
      "type": "checkbox",
      "id": "open_new_window",
      "label": "t:global.text.open_link_new_tab",
      "default": false
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "t:global.button.style.label",
      "options": [
        {
          "value": "primary",
          "label": "t:global.button.style.primary"
        },
        {
          "value": "secondary",
          "label": "t:global.button.style.secondary"
        },
        {
          "value": "text-link",
          "label": "t:global.button.style.text_link"
        }
      ],
      "default": "primary"
    },
    {
      "type": "header",
      "content": "t:product_components.settings.product.header"
    },
    {
      "type": "product",
      "id": "section_product",
      "label": "t:global.product.product",
      "info": "t:product_components.settings.product.product_info"
    },
    {
      "type": "checkbox",
      "id": "show_product_description",
      "default": false,
      "label": "t:product_components.settings.product.show_product_description"
    },
    {
      "type": "image_picker",
      "id": "custom_image",
      "label": "t:product_components.settings.product.custom_image_desktop"
    },
    {
      "type": "image_picker",
      "id": "custom_image_mobile",
      "label": "t:product_components.settings.product.custom_image_mobile"
    },
    {
      "type": "header",
      "content": "t:global.header.section_layout"
    },
    {
      "type": "select",
      "id": "desktop_height",
      "label": "t:global.image.desktop_image_height",
      "options": [
        {
          "value": "450px",
          "label": "450px"
        },
        {
          "value": "550px",
          "label": "550px"
        },
        {
          "value": "650px",
          "label": "650px"
        },
        {
          "value": "750px",
          "label": "750px"
        },
        {
          "value": "natural",
          "label": "t:global.ratio.natural"
        }
      ],
      "default": "750px"
    },
    {
      "type": "select",
      "id": "mobile_height",
      "label": "t:global.image.mobile_image_height",
      "options": [
        {
          "value": "250px",
          "label": "250px"
        },
        {
          "value": "300px",
          "label": "300px"
        },
        {
          "value": "400px",
          "label": "400px"
        },
        {
          "value": "500px",
          "label": "500px"
        },
        {
          "value": "natural",
          "label": "t:global.ratio.natural"
        }
      ],
      "default": "250px"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "t:product_components.settings.section_layout.image_position",
      "options": [
        {
          "value": "top",
          "label": "t:global.position.top"
        },
        {
          "value": "bottom",
          "label": "t:global.position.bottom"
        }
      ],
      "default": "bottom"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "t:global.alignment.content",
      "options": [
        {
          "value": "left",
          "label": "t:global.position.left"
        },
        {
          "value": "center",
          "label": "t:global.position.center"
        },
        {
          "value": "right",
          "label": "t:global.position.right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "label": "t:global.section.section_width.label",
      "id": "section_width",
      "options": [
        {
          "label": "t:global.section.section_width.option_1",
          "value": "page-width"
        },
        {
          "label": "t:global.section.section_width.option_2",
          "value": "full-width"
        },
        {
          "label": "t:global.section.section_width.option_3",
          "value": "full-width-padded"
        }
      ],
      "default": "full-width"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:global.section.top_padding",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
