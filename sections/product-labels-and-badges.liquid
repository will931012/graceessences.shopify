{%- if section.settings.enable or request.design_mode -%}
  {%- style -%}
    {%- for block in section.blocks -%}
      {%- unless block.type == 'image-label' -%}
        .maximize-theme:not(.dark) .x-badge-{{ block.id }} .x-badge-content.x-badge-text {
          background-color:{{ block.settings.background_color }};
          background: {{ block.settings.background_gradient }};
          color:{{ block.settings.text_color }};
          {% if block.settings.border_color.alpha != 0.0 %}
            border-width: 1px;
            border-style: solid;
            border-color: {{ block.settings.border_color }};
          {% endif %}
        }
        .maximize-theme.dark .x-badge-{{ block.id }} .x-badge-content.x-badge-text {
          background-color:{{ block.settings.background_color_dark }};
          background: {{ block.settings.background_gradient_dark }};
          color:{{ block.settings.text_color_dark }};
          {% if block.settings.border_color.alpha != 0.0 %}
            border-width: 1px;
            border-style: solid;
            border-color: {{ block.settings.border_color_dark }};
          {% endif %}
        }
      {%- endunless -%}
      {% if block.settings.display_type contains "scrolling" %}
        {% if block.settings.border_color.alpha != 0.0 %}
          .maximize-theme:not(.dark) .x-badge-{{ block.id }} .x-badge-text {
            border-width: 1px;
            border-style: solid;
            border-color: {{ block.settings.border_color }};
          }
        {% endif %}
        .maximize-theme:not(.dark) .x-badge-{{ block.id }} .x-badge-text-item {
          background-color:{{ block.settings.background_color }};
          color:{{ block.settings.text_color }};
          background: {{ block.settings.background_gradient }};
          {% if block.settings.border_color.alpha != 0.0 %}
            border-width: 1px;
            border-style: solid;
            border-color: {{ block.settings.border_color }};
          {% endif %}
        }
        .maximize-theme.dark .x-badge-{{ block.id }} .x-badge-text {
          {% if block.settings.border_color_dark.alpha != 0.0 %}
            border-width: 1px;
            border-style: solid;
            border-color: {{ block.settings.border_color_dark }};
          {% endif %}
        }
        .maximize-theme.dark .x-badge-{{ block.id }} .x-badge-text-item {
          background-color:{{ block.settings.background_color_dark }};
          background: {{ block.settings.background_gradient_dark }};
          color:{{ block.settings.text_color_dark }};
          {% if block.settings.border_color.alpha != 0.0 %}
            border-width: 1px;
            border-style: solid;
            border-color: {{ block.settings.border_color_dark }};
          {% endif %}
        }
      {% endif %}
      .x-badge-{{ block.id }} {
        --h7-font-size: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.4 * 0.8 * {{ block.settings.size_mobile | divided_by: 100.0 }});
        {%  if block.settings.image != blank %}
          --width-image-label: {{ block.settings.size_mobile | divided_by: 50.0 | times: 30 }}px;
          --height-image-label: {{ block.settings.size_mobile | divided_by: 50.0 | times: 30 | divided_by: block.settings.image.aspect_ratio }}px;
        {% endif %}
      }
      @media (min-width: 768px) {
        .x-badge-{{ block.id }} {
          --h7-font-size: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.4 * {{ block.settings.size | divided_by: 100.0 }});
          {%  if block.settings.image != blank %}
            --width-image-label: {{ block.settings.size | divided_by: 50.0 | times: 30 }}px;
            --height-image-label: {{ block.settings.size | divided_by: 50.0 | times: 30 | divided_by: block.settings.image.aspect_ratio }}px;
          {% endif %}
        }
      }
    {%- endfor -%}
  {%- endstyle -%}
  {%- for block in section.blocks -%}
    {% assign list_label = "" | split: "," %}
    {% liquid
      assign position_label = block.settings.position | default: "top-left"
      if block.settings.display_type contains "scrolling"
        assign list_label = block.settings.content | newline_to_br | strip_newlines | split: '<br />'
        if block.settings.display_type == "top_scrolling"
          assign position_label = "top-left"
        else
          assign position_label ="bottom-left"
        endif
      endif
      assign icon_type = 'none'
      if block.settings.icon != 'none'
        if block.settings.custom_icon_image != blank
          assign icon_type = 'custom_icon_image'
        elsif block.settings.icon == 'another_icon' and block.settings.another_icon != blank
          assign icon_type = 'another_icon'
        else
          assign icon_type = 'icon'
        endif
      endif
      assign change_bar_every = block.settings.change_bar_every | divided_by: 4.0
    %}
    {% style %}
      .x-badge-{{ block.id }} {
        --duration : {{ change_bar_every }}s;
        --direction: normal;
      }
      
    {% endstyle %}
    {%- capture content_label -%}
      {%- if block.settings.display_type contains "scrolling" -%}
        {{- list_label | json | escape -}}
      {%- else -%}
        {{ block.settings.content 
          | newline_to_br 
          | strip_newlines 
          | split: '<br />' 
          | join: '<br />' | replace: "&", "&amp;" | replace: '"', "&#8221;" | replace: "'", "&#039;" | replace: "\", "&#8726;" -}}
      {%- endif -%}
    {%- endcapture-%}
    <div
      class="x-badges-block-data"
      x-badges-block-data='
        {
          "id": "{{ block.id }}",
          "enable": {{ section.settings.enable }},
          "type": "{{ block.type }}",
          "settings": {
            "show_on_product_card": {{ block.settings.show_on_product_card }},
            "show_on_product_page": {{ block.settings.show_on_product_page }},
            "applied_to": "{{ block.settings.applied_to }}",
            "applied_products": [{{ block.settings.applied_products | map: 'id' | join: ', ' }}],
            "applied_collections": [{{ block.settings.applied_collections | map: 'id' | join: ', ' }}],
            {% if block.settings.display_type contains "scrolling" -%}
              "list_label": true,
            {%- endif %}
            "type": "{{ block.settings.display_type | default: "default" }}",
            "background_color": "{{ block.settings.background_color }}",
            "text_color": "{{ block.settings.text_color }}",
            "image": {{ block.settings.image | json }},
            "image_alt": "{{ block.settings.image.alt }}",
            "image_aspect_ratio": {{ block.settings.image.aspect_ratio | default: 0 }},
            "size": {{ block.settings.size }},
            "size_mobile": {{ block.settings.size_mobile }},
            "opacity": {{ block.settings.opacity }},
            "position": "{{ position_label }}",
            "schedule_enabled": {{ block.settings.schedule_enabled | default: false }},
            "timezone": {{ block.settings.timezone | default: 0 }},
            "start_year": {{ block.settings.start_year | default: 0 }},
            "start_month": {{ block.settings.start_month | default: 0 }},
            "start_day": {{ block.settings.start_day | default: 0 }},
            "start_hour": {{ block.settings.start_hour | default: 0 }},
            "start_minute": {{ block.settings.start_minute | default: 0 }},
            "end_year": {{ block.settings.end_year | default: 0 }},
            "end_month": {{ block.settings.end_month | default: 0 }},
            "end_day": {{ block.settings.end_day | default: 0 }},
            "end_hour": {{ block.settings.end_hour | default: 0 }},
            "end_minute": {{ block.settings.end_minute | default: 0 }},
            "repeat": {{ block.settings.repeat | json }},
            "custom_days": {{ block.settings.custom_days | json }},
            "icon_type": "{{ icon_type }}"{% if icon_type != 'none' %},
            "custom_icon_image": {{ block.settings.custom_icon_image | json }}
            {%- endif %}
          }
        }
      '
      x-badges-icon='{%- if block.settings.icon != 'none' %}
        {%- if block.settings.custom_icon_image != blank %}
          {{- block.settings.custom_icon_image }}
        {%- elsif block.settings.another_icon != blank and block.settings.icon == 'another' %}
          {%- render 'icon-another', icon: block.settings.another_icon %}
        {%- else %}
          {% assign icon_variable = block.settings.icon | default: "none" %}
          {%- render 'icon-labels-bags', icon: icon_variable %}
        {%- endif %}
      {%- endif %}'
      x-badges-content='{{ content_label }}'
    ></div>
  {%- endfor -%}
  <script src="{{ 'labels-and-badges.js' | asset_url }}" defer></script>
  <script src="{{ 'scrolling-promotion.js' | asset_url }}" defer></script>
  {%- if request.design_mode -%}
    {%- for block in section.blocks -%}
      <div
        class="x-badges-block-preview"
        {{ block.shopify_attributes }}
      ></div>
    {%- endfor -%}
    <div
      class="modal fixed top-0 left-0 w-full h-full opacity-100 z-[100]"
      role="dialog"
      tabindex="-1"
      x-data="xPreviewBadges"
      x-show="isOpen"
      id="ProductLabelsAndBadgesContainer"
      x-cloak
      x-transition
    >
      {%- liquid
        assign ratio = 100
        if settings.pc_media_ratio != 'auto'
          assign ratio = settings.pc_media_ratio
        endif
      -%}
      <div 
        class="product-card__wrapper model-inner absolute color-bg-gradient-[var(--gradient-background)] overflow-y-auto max-w-[90%] w-96 h-auto max-h-[90%] top-1/2 left-1/2 translate-y-[-50%] translate-x-[-50%] border"
        data-is-first-load="true"
        x-ref="modalContentLabelAndBadges"
        x-intersect.full="handleFocusLabelsAndBadges('ProductLabelsAndBadgesContainer', 'ProductLabelsAndBadgesClose')"
        @keyup.escape="$store.xFocusElement.removeTrapFocus(); close();"
      >
        <div class="modal-content flex h-full relative pb-5 flex-col">
          <button
            class="modal__button-close mb-2 md:mb-4 z-30 focus:outline-0 focus-visible:outline-1"
            id="ProductLabelsAndBadgesClose"
            x-on:click="close"
          >
            <span class="button__close icon-close-large-desktop icon-close-large-mobile">{% render 'icon-all', icon: 'icon-close' %}</span>
          </button>
          {% capture list_metafield_label %}
            {% liquid
              assign metafield_label_list = settings.label_and_badge_mtf | newline_to_br | strip_newlines | split: '<br />'
              for metafield_key in metafield_label_list
                echo '{"' | append: metafield_key | append: '": "metafield"},'
              endfor
            %}
          {% endcapture %}
          {% liquid
            assign list_metafield_label = list_metafield_label | remove_last: ","
            assign list_metafield_label = "[" | append: list_metafield_label | append: "]" 
          %}
          {%- capture data_for_label -%}
            { 
              "title": "{{ 'product_labels_and_badges.preview_label' | t }}", 
              "compare_at_price": 12000, 
              "price": 8500, 
              "price_with_currency": "{% if settings.currency_code_enable %}{{ 8500 | money_with_currency | escape }}{% else %}{{ 8500 | money | escape }}{% endif %}", 
              "sale_amount": "{{- 3500 | money | strip_html -}}",
              "inventory_management": "shopify",
              "qty": 6,
              "container": "card",
              "isXBadgesPreview": true
              {% if settings.label_and_badge_mtf != blank %}
                ,"metafield_label": {{ list_metafield_label }}
              {% endif %}
            }
          {%- endcapture %}
          <div
            x-data="{ lastWindowWidth: 0 }"
            x-init="$store.xLabelsAndBadges.init()"
            x-intersect.once="
              $nextTick(() => {
                $store.xLabelsAndBadges.load($el);
              })
            "
            class="card__inner relative badges-preview-card pb-[{{ ratio }}%] mx-2 md:mx-4"
            x-labels-data="{{ data_for_label | escape }}"
          >
            <div class="xcard__media absolute flex justify-center w-full h-full">
              {% render 'placeholder-image', image_type: "product_1" %}
            </div>
          </div>
        </div>
        <div class="px-2 pb-2 md:px-4 md:pb-4">
          <div class="below-image flex flex-wrap gap-1"></div>
          <p class="mt-1 full-unstyled-link link-product-variant h5 md:h6 hover:color-text-[rgba(var(--color-button-link))] cursor-pointer duration-200 p-break-words">{{ 'product_labels_and_badges.preview_label' | t }}</p>
          <div class="mt-2.5 flex items-center flex-wrap gap-1">
            {% render 'price',
              price_wrapper: 'h4 md:h5'
            %}
            <div class="next-price empty:hidden"></div>
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}
{%- else -%}
  <script>
    document.addEventListener('alpine:init', () => {
      Alpine.store('xLabelsAndBadges', {
        load() {
          return;
        },
      });
    });
  </script>
{%- endif -%}
