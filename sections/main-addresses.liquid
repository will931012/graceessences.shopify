{% liquid
  if settings.lang_direction contains request.locale.iso_code
    assign is_rtl = true
  else
    assign is_rtl = false
  endif
%}
{% style %}
  .section--{{ section.id }} {
    padding-top: calc({{ section.settings.padding_top }}px * var(--mobile-padding-ratio));
    padding-bottom: calc({{ section.settings.padding_bottom }}px * var(--mobile-padding-ratio));
  }
  @media (min-width: 768px) {
    .section--{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}
{%- paginate customer.addresses by 20 -%}
  <div
    class="section--{{ section.id }} page-width px-5 md:px-8"
    data-customer-addresses
    x-data="xCustomerAddresses"
  >
    <div class="flex flex-col md:flex-row gap-2 md:gap-1.5 justify-between items-center">
      <h1 class="h2 text-center anm-fade-element" x-intersect.once="$el.classList.add('is-visible')">
        {{ 'customer.addresses.title' | t }}
        <span class="md:hidden">({{ customer.addresses.size }})</span>
      </h1>
      <div
        class="flex items-center flex-col md:flex-row text-center gap-y-2 gap-x-4"
        data-address
      >
        <custom-button>
          <button
            class="button button-secondary py-2.5 md:py-3"
            type="button"
            aria-controls="AddAddress"
            @click="handleAddEdit('0')"
          >
            {% assign button_label = 'customer.addresses.add_new' | t %}
            <span class="flex items-center justify-center">
              {% render 'button-label', button_label: button_label, show_button_style: 'primary' %}
            </span>
          </button>
        </custom-button>
        <a class="inline-block" href="{{ routes.account_url }}"><span class="text-link">{{ 'customer.account.return' | t }}</span></a>
      </div>
    </div>
    <div
      id="Popup__Container"
      class="pop-up-link__container popup-container"
      x-show="activeAddEditFormIds.includes('0')"
      tabindex="0"
      x-cloak
    >
      <div
        id="AddAddress"
        @click.away="handleCancel('0')"
        class="popup-content{% unless settings.show_popup_overlay %} shadow-large{% endunless %} vendor-popup__content transform-gpu md:max-h-[90vh] color-bg-gradient-[var(--gradient-background)]"
        x-transition:enter-start="opacity-0 translate-y-full"
        x-transition:enter-end="opacity-100 translate-y-0"
        x-transition:leave-end="opacity-0 translate-y-1/3"
        x-intersect.full="$store.xFocusElement.trapFocus('Popup__Container', 'ClosePopUp')"
        @keyup.escape="$store.xFocusElement.removeTrapFocus(); handleCancel('0');"
        x-show="activeAddEditFormIds.includes('0')"
      >
        <div class="modal-title-container">
          <div class="modal-title-wrapper">
            <div class="grow flex items-center">
              <p
                id="AddressNewHeading"
                class="h4 w-full font-bold"
              >
                {{ 'customer.addresses.add_new' | t }}
              </p>
            </div>
            <button
              id="ClosePopUp"
              @click="$store.xFocusElement.removeTrapFocus(); handleCancel('0');"
              @keyup.enter.prevent="$store.xFocusElement.removeTrapFocus(); handleCancel('0');"
              @keydown.enter.prevent
              class="modal-title__button-close"
            >
              <span class="button__close icon-close-large-desktop icon-close-large-mobile">{%- render 'icon-all', icon: 'icon-close' -%}</span>
            </button>
          </div>
        </div>

        <div class="popup-detail scrollbar-body scrollbar-visible md:max-h-[80vh] py-0.5 sm:pl-0.5">
          {%- form 'customer_address', customer.new_address, aria-labelledBy: 'AddressNewHeading' -%}
            <div class="max-w-[570px] mr-auto ml-auto flex gap-2.5">
              <div class="text-field__wrapper mb-2.5 w-1/2">
                <input
                  id="AddressFirstNameNew"
                  class="text-field__input"
                  type="text"
                  name="address[first_name]"
                  value="{{ form.first_name }}"
                  autocomplete="given-name"
                  placeholder="{{ 'customer.addresses.first_name' | t }}"
                >
                <label
                  class="text-field__label"
                  for="AddressFirstNameNew"
                >
                  {{ 'customer.addresses.first_name' | t }}
                </label>
              </div>
              <div class="text-field__wrapper mb-2.5 w-1/2">
                <input
                  id="AddressLastNameNew"
                  class="text-field__input"
                  type="text"
                  name="address[last_name]"
                  value="{{ form.last_name }}"
                  autocomplete="family-name"
                  placeholder="{{ 'customer.addresses.last_name' | t }}"
                >
                <label
                  class="text-field__label"
                  for="AddressLastNameNew"
                >
                  {{ 'customer.addresses.last_name' | t }}
                </label>
              </div>
            </div>
            <div class="text-field__wrapper mx-auto mb-2.5 max-w-[570px]">
              <input
                id="AddressCompanyNew"
                class="text-field__input"
                type="text"
                name="address[company]"
                value="{{ form.company }}"
                autocomplete="organization"
                placeholder="{{ 'customer.addresses.company' | t }}"
              >
              <label
                class="text-field__label"
                for="AddressCompanyNew"
              >
                {{ 'customer.addresses.company' | t }}
              </label>
            </div>
            <div class="text-field__wrapper mx-auto mb-2.5 max-w-[570px]">
              <input
                id="AddressAddress1New"
                class="text-field__input"
                type="text"
                name="address[address1]"
                value="{{ form.address1 }}"
                autocomplete="address-line1"
                placeholder="{{ 'customer.addresses.address1' | t }}"
              >
              <label
                class="text-field__label"
                for="AddressAddress1New"
              >
                {{ 'customer.addresses.address1' | t }}
              </label>
            </div>
            <div class="text-field__wrapper mx-auto mb-2.5 max-w-[570px]">
              <input
                id="AddressAddress2New"
                class="text-field__input"
                type="text"
                name="address[address2]"
                value="{{ form.address2 }}"
                autocomplete="address-line2"
                placeholder="{{ 'customer.addresses.address2' | t }}"
              >
              <label
                class="text-field__label"
                for="AddressAddress2New"
              >
                {{ 'customer.addresses.address2' | t }}
              </label>
            </div>
            <div class="text-field__wrapper mx-auto mb-2.5 max-w-[570px]">
              <input
                id="AddressCityNew"
                class="text-field__input"
                type="text"
                name="address[city]"
                value="{{ form.city }}"
                autocomplete="address-level2"
                placeholder="{{ 'customer.addresses.city' | t }}"
              >
              <label
                class="text-field__label"
                for="AddressCityNew"
              >
                {{ 'customer.addresses.city' | t }}
              </label>
            </div>
            <div class="maximize mr-auto ml-auto mb-2.5 max-w-[570px]">
              <div class="dropdown-field__wrapper">
                <select
                  id="AddressCountryNew"
                  class="dropdown-field__input"
                  name="address[country]"
                  data-default="{{ form.country }}"
                  autocomplete="country"
                >
                  {{ all_country_option_tags }}
                </select>
                <span class="block w-3 h-3 absolute top-1/2{% if is_rtl %} left-5{% else %} right-5{% endif %} -translate-y-1/2">{% render 'icon-all', icon: 'icon-caret' %}</span>
                <label
                  class="dropdown-field__label"
                  for="AddressCountryNew"
                >
                  {{- 'customer.addresses.country' | t -}}
                </label>
              </div>
            </div>
            <div
              id="AddressProvinceContainerNew"
              class="relative maximize mr-auto ml-auto mb-2.5 max-w-[570px]"
              style="display:none;"
            >
              <div class="select dropdown-field__wrapper mx-auto mb-2.5 max-w-[570px]">
                <select
                  id="AddressProvinceNew"
                  class="dropdown-field__input"
                  name="address[province]"
                  data-default="{{ form.province }}"
                  autocomplete="address-level1"
                ></select>
                <span class="block w-3 h-3 absolute top-1/2{% if is_rtl %} left-5{% else %} right-5{% endif %} -translate-y-1/2">{% render 'icon-all', icon: 'icon-caret' %}</span>
                <label
                  class="dropdown-field__label"
                  for="AddressProvinceNew"
                >
                  {{- 'customer.addresses.province' | t -}}
                </label>
              </div>
            </div>
            <div class="text-field__wrapper mx-auto mb-2.5 max-w-[570px]">
              <input
                id="AddressZipNew"
                class="text-field__input"
                type="text"
                name="address[zip]"
                value="{{ form.zip }}"
                autocapitalize="characters"
                autocomplete="postal-code"
                placeholder="{{ 'customer.addresses.zip' | t }}"
              >
              <label
                class="text-field__label"
                for="AddressZipNew"
              >
                {{ 'customer.addresses.zip' | t }}
              </label>
            </div>
            <div class="text-field__wrapper mx-auto mb-2.5 max-w-[570px]">
              <input
                id="AddressPhoneNew"
                class="text-field__input{% if is_rtl %} rtl{% endif %}"
                type="tel"
                name="address[phone]"
                value="{{ form.phone }}"
                autocomplete="tel"
                placeholder="{{ 'customer.addresses.phone' | t }}"
              >
              <label
                class="text-field__label"
                for="AddressPhoneNew"
              >
                {{ 'customer.addresses.phone' | t }}
              </label>
            </div>
            <div class="flex items-center mr-auto ml-auto mt-1 mb-8 max-w-[570px] maximize">
              <input
                id="address_default_address_new"
                class="input-checkbox{% if is_rtl %} ml-2{% else %} mr-2{% endif %} h-5 w-5 border color-border-[rgba(var(--color-text),0.12)] checked:color-bg-[rgba(var(--color-button))] relative cursor-pointer{% if settings.edges_type == 'rounded_corners' %} rounded{% else %} rounded-none{% endif %}{% if is_rtl %} text-right{% endif %}"
                type="checkbox"
                name="address[default]"
                value="1"
              >
              <label for="address_default_address_new" class="cursor-pointer">{{ 'customer.addresses.set_default' | t }}</label>
            </div>
            <div class="flex flex-col max-w-[570px] mr-auto ml-auto mt-8">
              <custom-button>
                <button class="button button-primary w-full block mr-auto ml-auto pt-2.5 pb-2.5 md:pt-3.5 md:pb-3.5">
                  {% assign button_label = 'customer.addresses.add' | t %}
                  {% render 'button-label', button_label: button_label, show_button_style: 'primary' %}
                </button>
              </custom-button>
              <custom-button>
                <button
                  class="button button-secondary w-full block pt-2.5 pb-2.5 md:pt-3.5 md:pb-3.5 mr-auto ml-auto mt-2.5"
                  type="reset"
                  @click="handleCancel('0')"
                >
                  {{- 'customer.addresses.cancel' | t -}}
                </button>
              </custom-button>
            </div>
          {%- endform -%}
        </div>
      </div>
    </div>
    <ul
      class="text-center mt-5"
      role="list"
    >
      {%- for address in customer.addresses -%}
        <li
          class="relative mt-1.5 md:mt-2.5 p-4 md:p-5 rounded-corners flex flex-col md:flex-row gap-4 md:gap-5 justify-between{% if address == customer.default_address %} color-bg-[rgba(var(--color-text-no-alpha),.06)]{% else %} border{% endif %}"
          data-address
        >
          <div
            class="anm-fade-element flex flex-col gap-2 md:gap-2.5 text-start"
            x-intersect.once="$el.classList.add('is-visible')"
          >
            <div class="flex gap-1.5 md:gap-2">
              <p class="h6 anm-fade-element" x-intersect.once="$el.classList.add('is-visible')">Address {{ forloop.index }}</p>
              {%- if address == customer.default_address -%}
                <span
                  class="default-label text-xx-small color-bg-[rgba(var(--color-text),0.06)] inline-block py-0.5 px-1.5 {% if settings.edges_type == 'rounded_corners' %}rounded-[4px]{% endif %} anm-fade-element"
                  x-intersect.once="$el.classList.add('is-visible')"
                >
                  {{ 'customer.addresses.default' | t }}
                </span>
              {%- endif -%}
            </div>
            {{ address | format_address }}
          </div>
          <div
            class="anm-fade-element flex flex-col justify-center gap-1.5 md:gap-2.5"
            x-intersect.once="$el.classList.add('is-visible')"
          >
            <button
              id="EditFormButton_{{ address.id }}"
              class="{% if address == customer.default_address %}color-text-[rgba(var(--color-highlight))]{% endif %} flex items-center gap-1.5 text-medium md:justify-end min-w-[120px]"
              type="button"
              aria-label="{{ 'customer.addresses.edit_address' | t }} {{ forloop.index }}"
              aria-controls="EditAddress_{{ address.id }}"
              @click.prevent="handleAddEdit('{{ address.id }}')"
              @keyup.enter="handleAddEdit('{{ address.id }}')"
            >
              <span class="inline-block w-4 h-5 md:w-4.5">{% render 'icon-all', icon: 'icon-edit' %}</span>
              <span>{{ 'customer.addresses.edit' | t }}</span>
            </button>
            <button
              class="{% if address == customer.default_address %}color-text-[rgba(var(--color-highlight))]{% endif %} flex items-center gap-1.5 text-medium md:justify-end min-w-[120px]"
              type="button"
              aria-label="{{ 'customer.addresses.delete' | t }} {{ forloop.index }}"
              data-target="{{ address.url }}"
              data-confirm-message="{{ 'customer.addresses.delete_confirm' | t }}"
              @click="handleDelete"
            >
              <span class="inline-block w-4 h-5 md:w-4.5">{% render 'icon-all', icon: 'icon-remove' %}</span>
              <span>{{ 'customer.addresses.delete' | t }}</span>
            </button>
          </div>
          <div
            id="Popup__Container__{{ address.id }}"
            class="pop-up-link__container popup-container"
            x-show="activeAddEditFormIds.includes('{{ address.id }}')"
            x-cloak
          >
            <div
              id="EditAddress_{{ address.id }}"
              @click.away="handleCancel('{{ address.id }}')"
              class="popup-content{% unless settings.show_popup_overlay %} shadow-large{% endunless %} vendor-popup__content transform-gpu md:max-h-[90vh] color-bg-gradient-[var(--gradient-background)]"
              x-transition:enter-start="opacity-0 translate-y-full"
              x-transition:enter-end="opacity-100 translate-y-0"
              x-transition:leave-end="opacity-0 translate-y-1/3"
              x-intersect.full="$store.xFocusElement.trapFocus('EditAddress_{{ address.id }}', 'ClosePopUp__{{ address.id }}')"
              @keyup.escape="$store.xFocusElement.removeTrapFocus(); handleCancel('{{ address.id }}')"
              x-show="activeAddEditFormIds.includes('{{ address.id }}')"
            >

              <div class="modal-title-container">
                <div class="modal-title-wrapper">
                  <div class="grow flex items-center">
                    <p class="h4 w-full text-start">{{ 'customer.addresses.edit_address' | t }}</p>
                  </div>
                  <button
                    id="ClosePopUp__{{ address.id }}"
                    @click.prevent="$store.xFocusElement.removeTrapFocus(); handleCancel('{{ address.id }}');"
                    @keyup.enter.prevent="$store.xFocusElement.removeTrapFocus(); handleCancel('{{ address.id }}');"
                    @keydown.enter.prevent
                    class="modal-title__button-close"
                    role="button"
                    aria-label="{{ 'accessibility.close' | t }}"
                  >
                    <span class="button__close icon-close-large-desktop icon-close-large-mobile">{%- render 'icon-all', icon: 'icon-close' -%}</span>
                  </button>
                </div>
              </div>
              
              <div class="popup-detail scrollbar-body scrollbar-visible md:max-h-[80vh] py-0.5 sm:pl-0.5">
                {%- form 'customer_address', address -%}
                  <div class="max-w-[570px] mr-auto ml-auto flex gap-2.5">
                    <div class="text-field__wrapper mb-2.5 w-1/2">
                      <input
                        id="AddressFirstName_{{ form.id }}"
                        class="text-field__input"
                        type="text"
                        name="address[first_name]"
                        value="{{ form.first_name }}"
                        autocomplete="given-name"
                        placeholder="{{ 'customer.addresses.first_name' | t }}"
                      >
                      <label
                        class="text-field__label"
                        for="AddressFirstName_{{ form.id }}"
                      >
                        {{ 'customer.addresses.first_name' | t }}
                      </label>
                    </div>
                    <div class="text-field__wrapper mb-2.5 w-1/2">
                      <input
                        id="AddressLastName_{{ form.id }}"
                        class="text-field__input"
                        type="text"
                        name="address[last_name]"
                        value="{{ form.last_name }}"
                        autocomplete="family-name"
                        placeholder="{{ 'customer.addresses.last_name' | t }}"
                      >
                      <label
                        class="text-field__label"
                        for="AddressLastName_{{ form.id }}"
                      >
                        {{ 'customer.addresses.last_name' | t }}
                      </label>
                    </div>
                  </div>
                  <div class="text-field__wrapper mx-auto mb-2.5 max-w-[570px]">
                    <input
                      id="AddressCompany_{{ form.id }}"
                      class="text-field__input"
                      type="text"
                      name="address[company]"
                      value="{{ form.company }}"
                      autocomplete="organization"
                      placeholder="{{ 'customer.addresses.company' | t }}"
                    >
                    <label
                      class="text-field__label"
                      for="AddressCompany_{{ form.id }}"
                    >
                      {{ 'customer.addresses.company' | t }}
                    </label>
                  </div>
                  <div class="text-field__wrapper mx-auto mb-2.5 max-w-[570px]">
                    <input
                      id="AddressAddress1_{{ form.id }}"
                      class="text-field__input"
                      type="text"
                      name="address[address1]"
                      value="{{ form.address1 }}"
                      autocomplete="address-line1"
                      placeholder="{{ 'customer.addresses.address1' | t }}"
                    >
                    <label
                      class="text-field__label"
                      for="AddressAddress1_{{ form.id }}"
                    >
                      {{ 'customer.addresses.address1' | t }}
                    </label>
                  </div>
                  <div class="text-field__wrapper mx-auto mb-2.5 max-w-[570px]">
                    <input
                      id="AddressAddress2_{{ form.id }}"
                      class="text-field__input"
                      type="text"
                      name="address[address2]"
                      value="{{ form.address2 }}"
                      autocomplete="address-line2"
                      placeholder="{{ 'customer.addresses.address2' | t }}"
                    >
                    <label
                      class="text-field__label"
                      for="AddressAddress2_{{ form.id }}"
                    >
                      {{ 'customer.addresses.address2' | t }}
                    </label>
                  </div>
                  <div class="text-field__wrapper mx-auto mb-2.5 max-w-[570px]">
                    <input
                      id="AddressCity_{{ form.id }}"
                      class="text-field__input"
                      type="text"
                      name="address[city]"
                      value="{{ form.city }}"
                      autocomplete="address-level2"
                      placeholder="{{ 'customer.addresses.city' | t }}"
                    >
                    <label
                      class="text-field__label"
                      for="AddressCity_{{ form.id }}"
                    >
                      {{ 'customer.addresses.city' | t }}
                    </label>
                  </div>
                  <div class="mr-auto ml-auto mb-2.5 max-w-[570px]">
                    <div class="select dropdown-field__wrapper">
                      <select
                        id="AddressCountry_{{ form.id }}"
                        class="dropdown-field__input"
                        name="address[country]"
                        data-address-country-select
                        data-default="{{ form.country }}"
                        data-form-id="{{ form.id }}"
                        autocomplete="country"
                      >
                        {{ all_country_option_tags }}
                      </select>
                      <span class="block w-3 h-3 absolute top-1/2{% if is_rtl %} left-5{% else %} right-5{% endif %} -translate-y-1/2">{% render 'icon-all', icon: 'icon-caret' %}</span>
                      
                      <label
                        class="dropdown-field__label"
                        for="AddressCountry_{{ form.id }}"
                      >
                        {{ 'customer.addresses.country' | t }}
                      </label>
                    </div>
                  </div>
                  <div
                    id="AddressProvinceContainer_{{ form.id }}"
                    class="mr-auto ml-auto mb-2.5 max-w-[570px]"
                    style="display:none;"
                  >
                    <div class="select dropdown-field__wrapper">
                      <select
                        id="AddressProvince_{{ form.id }}"
                        class="dropdown-field__input"
                        name="address[province]"
                        data-default="{{ form.province }}"
                        autocomplete="address-level1"
                      ></select>
                      <span class="block w-3 h-3 absolute top-1/2{% if is_rtl %} left-5{% else %} right-5{% endif %} -translate-y-1/2">{% render 'icon-all', icon: 'icon-caret' %}</span>
                      <label
                        class="dropdown-field__label"
                        for="AddressProvince_{{ form.id }}"
                      >
                        {{ 'customer.addresses.province' | t }}
                      </label>
                    </div>
                  </div>
                  <div class="text-field__wrapper mx-auto mb-2.5 max-w-[570px]">
                    <input
                      id="AddressZip_{{ form.id }}"
                      class="text-field__input"
                      type="text"
                      name="address[zip]"
                      value="{{ form.zip }}"
                      autocapitalize="characters"
                      autocomplete="postal-code"
                      placeholder="{{ 'customer.addresses.zip' | t }}"
                    >
                    <label
                      class="text-field__label"
                      for="AddressZip_{{ form.id }}"
                    >
                      {{ 'customer.addresses.zip' | t }}
                    </label>
                  </div>
                  <div class="text-field__wrapper mx-auto mb-2.5 max-w-[570px]">
                    <input
                      id="AddressPhone_{{ form.id }}"
                      class="text-field__input{% if is_rtl %} rtl{% endif %}"
                      type="tel"
                      name="address[phone]"
                      value="{{ form.phone }}"
                      autocomplete="tel"
                      placeholder="{{ 'customer.addresses.phone' | t }}"
                    >
                    <label
                      class="text-field__label"
                      for="AddressPhone_{{ form.id }}"
                    >
                      {{ 'customer.addresses.phone' | t }}
                    </label>
                  </div>
                  <div class="flex items-center mr-auto ml-auto mt-1 mb-8 max-w-[570px] maximize">
                    <input
                      id="address_default_address_{{ form.id }}"
                      class="input-checkbox rtl:ml-2 ltr:mr-2 h-5 w-5 border color-border-[rgba(var(--color-text),0.12)] checked:color-bg-[rgba(var(--color-button))] relative cursor-pointer{% if settings.edges_type == 'rounded_corners' %} rounded{% else %} rounded-none{% endif %} rtl:text-right"
                      type="checkbox"
                      name="address[default]"
                      value="1"
                    >
                    <label for="address_default_address_{{ form.id }}" class="cursor-pointer">
                      {{ 'customer.addresses.set_default' | t }}
                    </label>
                  </div>
                  <div class="flex flex-col max-w-[570px] mr-auto ml-auto mt-8">
                    <custom-button>
                      <button class="button button-primary w-full block mr-auto ml-auto pt-2.5 pb-2.5 md:pt-3.5 md:pb-3.5">
                        {% assign button_label = 'customer.addresses.update' | t %}
                        {% render 'button-label', button_label: button_label, show_button_style: 'primary' %}
                      </button>
                    </custom-button>
                    <custom-button>
                      <button
                        class="button button-secondary w-full block mr-auto ml-auto mt-2.5 pt-2.5 pb-2.5 md:pt-3.5 md:pb-3.5"
                        type="reset"
                        @click="handleCancel('{{ address.id }}')"
                      >
                        {{ 'customer.addresses.cancel' | t }}
                      </button>
                    </custom-button>
                  </div>
                {%- endform -%}
              </div>
            </div>
          </div>
        </li>
      {%- endfor -%}
    </ul>
    {%- if paginate.pages > 1 -%}
      <div class="flex justify-center mt-14">
        {% render 'pagination', paginate: paginate, paginate_type: "underline" %}
      </div>
    {%- endif -%}
  </div>
{%- endpaginate -%}
<script
  src="{{ 'customer-addresses.js' | asset_url }}"
  defer
></script>
{% schema %}
{
  "name": "t:main_addresses.name",
  "settings": [
    {
      "type": "header",
      "content": "t:global.header.section_layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
