{% liquid
  assign has_map = false
%}
{%- style -%}
  .section--{{ section.id }} {
    padding-top: calc({{ section.settings.padding_top }}px * var(--mobile-padding-ratio));
    padding-bottom: calc({{ section.settings.padding_bottom }}px * var(--mobile-padding-ratio));
  }
  @media (min-width: 768px) {
    .section--{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .maximize-theme:not(.dark) .event-day-{{ section.id }} {
    {% if section.settings.date_background_color.alpha != 0.0 %}
      --element-background: rgba({{ section.settings.date_background_color.red }} {{ section.settings.date_background_color.green }} {{ section.settings.date_background_color.blue }} / {{ section.settings.date_background_color.alpha }});
    {% endif %}
    {% if section.settings.color_date_light.alpha != 0.0 %}
      --color-text: {{ section.settings.color_date_light.red }} {{ section.settings.color_date_light.green }} {{ section.settings.color_date_light.blue }} / {{ section.settings.color_date_light.alpha }};
    {% endif %}
  }
  .dark .event-day-{{ section.id }} {
    {% if section.settings.date_background_color_dark.alpha != 0.0 %}
      --element-background: rgba({{ section.settings.date_background_color_dark.red }} {{ section.settings.date_background_color_dark.green }} {{ section.settings.date_background_color_dark.blue }} / {{ section.settings.date_background_color_dark.alpha }});
    {% endif %}
    {% if section.settings.color_date_dark.alpha != 0.0 %}
      --color-text: {{ section.settings.color_date_dark.red }} {{ section.settings.color_date_dark.green }} {{ section.settings.color_date_dark.blue }} / {{ section.settings.color_date_dark.alpha }};
    {% endif %}
  }
{%- endstyle -%}

{% render 'section-divider' %}

<div class="section--{{ section.id }} {{ section.settings.section_width }} rounded-corners-container color-{{ section.settings.color_scheme_light.id }} dark-color-{{ section.settings.color_scheme_dark.id }}">
  <div class="event-calendar__container relative mx-auto">
    <div class="event-calendar__heading heading-content-spacing flex flex-col gap-0.5">
      {%- if section.settings.heading != blank -%}
        <{{ section.settings.heading_tag }} class="heading-{{ section.settings.heading_size }} font-bold h2 block text-{{ section.settings.heading_alignment }} flex-auto p-break-words">
          {% render 'text-highlight',
            id: section.id,
            text: section.settings.heading,
            highlight_effect: section.settings.highlight_effect,
            text_transform: section.settings.text_transform
          %}
        </{{ section.settings.heading_tag }}>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <div class="event-calendar__description rte text-{{ section.settings.heading_alignment }}">
          {% render 'text-highlight',
            id: section.id,
            text: section.settings.description,
            highlight_effect: section.settings.highlight_effect,
            text_transform: section.settings.text_transform,
            allow_html: true
          %}
        </div>
      {%- endif -%}
    </div>

    <div class="event-calendar__content grid{% if section.settings.desktop_layout == "2" %} md:grid-cols-2 gap-x-7{% endif %}{% unless section.settings.border_column == "line" %} gap-y-7{% endunless %}">
      {%- for block in section.blocks -%}
        {% liquid
          if block.settings.button_label_add_calendar != blank
            assign add_to_calendar = block.settings.button_label_add_calendar
          else
            assign add_to_calendar = 'sections.event-calendar.add_to_calendar' | t
          endif

          if block.settings.ticket_button_label != blank
            assign ticket_button_label = block.settings.ticket_button_label
          else
            assign ticket_button_label = 'sections.event-calendar.buy_tickets' | t
          endif

          assign date = block.settings.month | append: block.settings.day | date: '%b %d' | append: ', ' | append: block.settings.start_year
          assign compare_date = date | date: '%s' | times: 1
          assign show_end_date = false
          assign show_end_time = false
          assign start_hour = block.settings.start_hour | times: 1
          assign start_minute = block.settings.start_minute | times: 1
          assign end_hour = block.settings.end_hour | times: 1
          assign end_minute = block.settings.end_minute | times: 1

          if section.settings.timeformat == '12'
            if start_hour == 12
              assign time_start = 12 | append: ':' | append: block.settings.start_minute | append: ' PM'
            elsif start_hour == 0
              assign time_start = 12 | append: ':' | append: block.settings.start_minute | append: ' AM'
            elsif start_hour > 12
              assign time_start = block.settings.start_hour | minus: 12
              if time_start < 10
                assign time_start = '0' | append: time_start | append: ':' | append: block.settings.start_minute | append: ' PM'
              else
                assign time_start = time_start | append: ':' | append: block.settings.start_minute | append: ' PM'
              endif
            else
              assign time_start = block.settings.start_hour | append: ':' | append: block.settings.start_minute | append: ' AM'
            endif
            if end_hour == 12
              assign time_end = 12 | append: ':' | append: block.settings.end_minute | append: ' PM'
            elsif end_hour == 0
              assign time_end = 12 | append: ':' | append: block.settings.end_minute | append: ' AM'
            elsif end_hour > 12
              assign time_end = block.settings.end_hour | minus: 12
              if time_end < 10
                assign time_end = '0' | append: time_end | append: ':' | append: block.settings.end_minute | append: ' PM'
              else
                assign time_end = time_end | append: ':' | append: block.settings.end_minute | append: ' PM'
              endif
            else
              assign time_end = block.settings.end_hour | append: ':' | append: block.settings.end_minute | append: ' AM'
            endif
          else
            assign time_start = block.settings.start_hour | append: ':' | append: block.settings.start_minute
            assign time_end = block.settings.end_hour | append: ':' | append: block.settings.end_minute
          endif

          assign end_date = block.settings.end_month | append: block.settings.end_day | date: '%b %d' | append: ', ' | append: block.settings.end_year
          assign compare_end_date = end_date | date: '%s' | times: 1
          if block.settings.show_end_date and compare_end_date > compare_date
            assign show_end_date = true
          elsif block.settings.show_end_date and compare_end_date == compare_date and end_hour > start_hour
            assign show_end_time = true
          elsif block.settings.show_end_date and end_hour == start_hour and end_minute > start_minute
            assign show_end_time = true
          endif
        %}
        {%- capture data_event_item -%}
          {
            "sectionID": "{{ section.id }}",
            "blockID": "{{ block.id }}",
            "title": "{{ block.settings.heading }}",
            "location": "{{ block.settings.location | default: '' }}",
            "details": "{{ block.settings.content | strip_html | escape | default: '' }}",
            "description": "{{ block.settings.content | default: '' | escape }}",
            "start_year": "{{ block.settings.start_year }}",
            "month": "{{ block.settings.month }}",
            "day": "{{ block.settings.day }}",
            "end_year": "{{ block.settings.end_year }}",
            "end_month": "{{ block.settings.end_month }}",
            "end_day": "{{ block.settings.end_day }}",
            "date": "{{ date }}",
            "end_date": "{{ end_date }}",
            "time_start": "{{ time_start }}",
            "time_end": "{{ time_end }}",
            "start_hour" : "{{ block.settings.start_hour }}",
            "end_hour" : "{{ block.settings.end_hour }}",
            "start_minute" : "{{ block.settings.start_minute }}",
            "end_minute" : "{{ block.settings.end_minute }}",
            "show_end_date": {{ show_end_date }},
            "show_end_time": {{ show_end_time }},
            "timezone": "{{ section.settings.timezone }}",
            "image": {% if block.settings.image != blank %}"{{ block.settings.image | image_url }}"{% else %}false{% endif %},
            "image_alt": {% if block.settings.image != blank %}"{{ block.settings.image.alt | escape }}"{% else %}""{% endif %},
            "button_label_add_calendar": "{{ add_to_calendar }}",
            "show_button_style": "{{ block.settings.show_button_style }}",
            "ticket_button_label": "{{ ticket_button_label }}",
            "offer_tickets": {{ block.settings.offer_tickets }},
            "ticket_link": "{{ block.settings.ticket_link }}",
            "ticket_button_label_style": "{{ block.settings.ticket_button_label_style }}"
          }
        {%- endcapture %}
        <div
          id="x-data-event-{{ block.id }}"
          class="event-calendar__block flex gap-2.5 lg:gap-x-5 event-{{ block.id }}{% if block.settings.image != blank %} flex flex-col lg:flex-row lg:items-start{% endif %}
            {%- if section.settings.border_column == "border" %} border border-dashed pt-5 pb-5 pl-5 pr-5{% if settings.edges_type == 'rounded_corners' %} rounded-[10px]{% endif %}{% endif -%}
            {%- if section.settings.border_column == "line" %} border-b pb-7 pt-7{% unless forloop.index > 1 %} border-t{% endunless %}{% if forloop.index == 2 and section.settings.desktop_layout == "2" %} md:border-t{% endif %}{% endif -%}
          "
          x-event-data="{{ data_event_item | escape }}"
          {{ block.shopify_attributes }}
        >
        {% assign default_image_alt = 'accessibility.default_alt' | t %}
          <div class="event-calendar__calendar relative{% if block.settings.image != blank %} w-full lg:max-w-[300px] overflow-hidden{% endif %}">
            {% if block.settings.image != blank %}
              <div
                class="event-calendar__calendar__img relative block{% if section.settings.image_ratio != "auto" %} h-0 pb-[{{ section.settings.image_ratio }}]{% endif %}{% if settings.edges_type == 'rounded_corners' %} overflow-hidden rounded-[10px]{% endif %}"
                {% if section.settings.image_ratio == 'auto' and block.settings.image != blank %}
                  style="padding-bottom: {{ 1 | divided_by: block.settings.image.aspect_ratio | times: 100 }}%;"
                {% endif %}
              >
                <img
                  class="event-calendar__calendar__img--img block max-w-full image-hover absolute top-0 left-0 h-full w-full object-cover object-center"
                  srcset="
                    {{ block.settings.image | image_url: width: 375 }} 375w,
                    {{ block.settings.image | image_url: width: 450 }} 450w,
                    {{ block.settings.image | image_url: width: 750 }} 750w,
                    {{ block.settings.image | image_url: width: 900 }} 900w,
                    {{ block.settings.image | image_url: width: 1100 }} 1100w,
                    {{ block.settings.image | image_url: width: 1500 }} 1500w,
                    {{ block.settings.image | image_url: width: 1780 }} 1780w,
                    {{ block.settings.image | image_url: width: 2000 }} 2000w,
                    {{ block.settings.image | image_url: width: 3000 }} 3000w,
                    {{ block.settings.image | image_url: width: 3840 }} 3840w
                  "
                  sizes="(min-width: 1000px) 400px, 100vw"
                  src="{{ block.settings.image | image_url: width: 3840 }}"
                  loading="lazy"
                  alt="{{ block.settings.image.alt | default: default_image_alt | escape }}"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.width | divided_by: block.settings.image.aspect_ratio }}"
                  style="object-position: {{ block.settings.image.presentation.focal_point }};"
                >
              </div>
            {% endif %}

            <div 
              class="event-calendar__calendar__content event-day-{{ section.id }} color-bg-[var(--element-background)] aspect-square flex flex-col justify-center text-center rounded-corners
              {%- if block.settings.image != blank %} absolute top-0 left-0 rtl:left-auto rtl:right-0 rtl:ml-0 rtl:mr-2 mt-2 mb-2 ml-2 pb-2 pt-2 pr-4 pl-4 lg:pb-1.5 lg:pt-1.5 lg:pl-4 lg:pr-4{% else %} pb-2.5 pt-2.5 pr-5 pl-5 lg:pb-2 lg:pt-2 lg:pl-5 lg:pr-5 border border-dashed{% endif -%}"
            >
              <p class="event-calendar__calendar__content--day whitespace-nowrap h4 color-text-[rgba(var(--color-text))]">{{ block.settings.day }}</p>
              <p class="event-calendar__calendar__content--month text-small color-text-[rgba(var(--color-text))]">{{ block.settings.month | append: block.settings.day | date: '%b' }}</p>
            </div>
          </div>
          <div class="event-calendar__info lg:w-3/4 grow flex flex-col lg:justify-start{% if block.settings.image != blank %} pt-2.5 lg:pt-0 lg:pb-0{% endif %}">
            {% if block.settings.heading != blank %}
              <div
                class="event-calendar__info__heading heading-{{ block.settings.heading_size }} title-link h3 cursor-pointer anm-fade-element" x-intersect.once="$el.classList.add('is-visible')"
                tabindex="0"
                @click.prevent="$store.xEventCalendarDetail.load($el, '{{ block.id }}'); $store.xMaximizeDrawer.handleOpen('#EventCalendarDrawer__{{ section.id }}');"
                @keyup.enter="$store.xEventCalendarDetail.load($el, '{{ block.id }}'); $store.xMaximizeDrawer.handleOpen('#EventCalendarDrawer__{{ section.id }}');"
              >
                {{ block.settings.heading }}
              </div>
            {% endif %}
            <div class="event-calendar__info__details flex flex-wrap gap-x-2.5 mt-1.5 text-small gap-y-0.5 color-text-[rgba(var(--color-heading),0.6)] {% if show_end_date %} flex-col{% endif %} anm-fade-element" x-intersect.once="$el.classList.add('is-visible')">
              <div class="event-calendar__info__start-date inline-flex items-start pl-5 rtl:pl-0 rtl:pr-5 flex-col relative">
                <span class="w-4 h-5 absolute left-0 rtl:left-auto rtl:right-0">{% render 'icon-all', icon: 'icon-clock' %}</span>
                {% if show_end_date %}
                  <div class="event-day">
                    <p>{{ date }} @ {{ time_start }} -</p>
                    <p>{{ end_date }} @ {{ time_end }}</p>
                  </div>
                {% elsif show_end_time %}
                  <span class="event-day">{{ time_start }} - {{ time_end }}</span>
                {% else %}
                  <span class="event-day">{{ time_start }}</span>
                {% endif %}
              </div>
              {% if block.settings.show_end_date and compare_end_date < compare_date and request.design_mode %}
                <p class="event-calendar__info__end-date relative event-error pl-5 rtl:pl-0 rtl:pr-5 color-text-[rgba(var(--error-message-color))]">
                  <span class="absolute left-0 rtl:left-auto rtl:right-0 top-1/2 -translate-y-1/2 w-3">{% render 'icon-all', icon: 'icon-error' %}</span>
                  <span class="cart-item__error-text text-sm p-break-words">{{ 'sections.event-calendar.message_error' | t }}</span>
                </p>
              {% endif %}
              {% if block.settings.location != blank %}
                {% assign has_map = true %}
                <div class="event-calendar__info__location flex items-start pl-5 rtl:pl-0 rtl:pr-5 relative">
                  <span class="w-4 h-4 inline-block absolute left-0 rtl:left-auto rtl:right-0">{%- render 'icon-all', icon: 'icon-location-1' -%}</span>
                  <span>{{ block.settings.location }}</span>
                </div>
              {% endif %}
            </div>
            <div class="event-calendar__info__desc mt-2.5 md:mt-3.5 rte line-clamp-4 text-small anm-fade-element" x-intersect.once="$el.classList.add('is-visible')">
              {{ block.settings.description }}
            </div>

            <div class="event-calendar__info__action flex gap-3 flex-wrap grow items-end lg:items-start lg:grow-0 mt-3.5 md:mt-5 mb-0.5">
              {% if block.settings.offer_tickets %}
                <custom-button>
                  <a
                    {% if block.settings.ticket_link == blank %}
                      role="link" aria-disabled="true"
                    {% else %}
                      href="{{ block.settings.ticket_link }}"
                    {% endif %}
                    class="event-calendar__info__ticket button button-{{ block.settings.ticket_button_label_style }} button--{{ section.id }} flex flex-row items-center empty:hidden !pl-5 !pr-5 md:pl-6 md:pr-6 pt-2.5 pb-2.5 md:pt-3 md:pb-3
                      {%- if block.settings.ticket_link == blank %} opacity-60 cursor-not-allowed{% endif -%}"
                    @click="open = !open"
                  >
                    {{ ticket_button_label }}
                  </a>
                </custom-button>
              {% endif %}
              <select-element
                class="event-calendar__info__action dropdown-large"
                data-picker-type="dropdown"
              >
                <div class="select relative" x-data="xEventCalendar({{ data_event_item | escape }})">
                  <custom-button>
                    <button
                      class="event-calendar__info__action--button select-button button button-{{ block.settings.show_button_style }} button--{{ section.id }} flex flex-row items-center empty:hidden pl-5 pr-5 md:pl-6 md:pr-6 pt-2.5 pb-2.5 md:pt-3 md:pb-3 gap-2.5"
                      @click="open = !open"
                    >
                      <span>
                        {{ add_to_calendar }}
                      </span>
                      <span class="select-arrow transition-transform w-2.5 h-2.5 flex">{% render 'icon-all', icon: 'icon-caret' %}</span>
                    </button>
                  </custom-button>
                  <div class="select-options-wrapper z-[51] max-h-64 scrollbar-visible scrollbar-body color-bg-gradient-[var(--gradient-background)] shadow-medium">
                    <ul 
                      role="listbox"
                      class="select-options"
                      aria-label="CalendarList"
                    >
                      <li 
                        class="select-option rounded-corners font-normal"
                        data-value="{{ 'sections.event-calendar.apple' | t }}"
                        data-select-value="{{ 'sections.event-calendar.apple' | t }}"
                        aria-selected="false"
                        data-type="dropdown"
                        role="option"
                        tabindex="-1"
                        data-no-instant
                        data-option-number="1"
                        id="atcb-btn-1-apple"
                        aria-label="{{ 'sections.event-calendar.apple' | t }}"
                        @click="addToCal('apple')"
                        @keydown.enter="addToCal('apple')"
                        @keydown.space="addToCal('apple')"
                      >
                        {{ 'sections.event-calendar.apple' | t }}
                      </li>
                      <li 
                        class="select-option rounded-corners font-normal"
                        data-value="{{ 'sections.event-calendar.google' | t }}"
                        data-select-value="{{ 'sections.event-calendar.google' | t }}"
                        aria-selected="false"
                        data-type="dropdown"
                        role="option"
                        tabindex="-1"
                        data-no-instant
                        data-option-number="2"
                        id="atcb-btn-1-google"
                        aria-label="{{ 'sections.event-calendar.google' | t }}"
                        @click="addToCal('google')"
                        @keydown.enter="addToCal('google')"
                        @keydown.space="addToCal('google')"
                      >
                        {{ 'sections.event-calendar.google' | t }}
                      </li>
                      <li 
                        class="select-option rounded-corners font-normal"
                        data-value="{{ 'sections.event-calendar.outlook' | t }}"
                        data-select-value="{{ 'sections.event-calendar.outlook' | t }}"
                        aria-selected="false"
                        data-type="dropdown"
                        role="option"
                        tabindex="-1"
                        data-no-instant
                        data-option-number="3"
                        id="atcb-btn-1-outlook"
                        aria-label="{{ 'sections.event-calendar.outlook' | t }}"
                        @click="addToCal('outlook')"
                        @keydown.enter="addToCal('outlook')"
                        @keydown.space="addToCal('outlook')"
                      >
                        {{ 'sections.event-calendar.outlook' | t }}
                      </li>
                      <li 
                        class="select-option rounded-corners font-normal"
                        data-value="{{ 'sections.event-calendar.yahoo' | t }}"
                        data-select-value="{{ 'sections.event-calendar.yahoo' | t }}"
                        aria-selected="false"
                        data-type="dropdown"
                        role="option"
                        tabindex="-1"
                        data-no-instant
                        data-option-number="4"
                        id="atcb-btn-1-yahoo"
                        aria-label="{{ 'sections.event-calendar.yahoo' | t }}"
                        @click="addToCal('yahoo')"
                        @keydown.enter="addToCal('yahoo')"
                        @keydown.space="addToCal('yahoo')"
                      >
                        {{ 'sections.event-calendar.yahoo' | t }}
                      </li>
                      <li 
                        class="select-option rounded-corners font-normal"
                        data-value="{{ 'sections.event-calendar.ical' | t }}"
                        data-select-value="{{ 'sections.event-calendar.ical' | t }}"
                        aria-selected="false"
                        data-type="dropdown"
                        role="option"
                        tabindex="-1"
                        data-no-instant
                        data-option-number="5"
                        id="atcb-btn-1-ical"
                        aria-label="{{ 'sections.event-calendar.ical' | t }}"
                        @click="addToCal('ical')"
                        @keydown.enter="addToCal('ical')"
                        @keydown.space="addToCal('ical')"
                      >
                        {{ 'sections.event-calendar.ical' | t }}
                      </li>
                    </ul>
                  </div>
                </div>
              </select-element>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% if has_map %}
  <script
    src="{{ 'map.js' | asset_url }}"
    defer
  ></script>
{% endif %}
{% render 'event-calendar-detail' %}
<script
  src="{{ 'event-calendar.js' | asset_url }}"
  defer
></script>
{% schema %}
{
  "name": "t:event_calendar.name",
  "tag": "section",
  "class": "maximize-section section-event-calendar",
  "disabled_on": {
    "groups": ["header", "footer", "aside"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:global.text.heading",
      "default": "Events",
      "info": "t:global.text.highlight_info"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:global.text.heading_size",
      "options": [
        {
          "value": "small",
          "label": "t:global.size.small"
        },
        {
          "value": "medium",
          "label": "t:global.size.medium"
        },
        {
          "value": "large",
          "label": "t:global.size.large"
        }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "default": "h2",
      "label": "t:global.text.heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        },
        {
          "value": "p",
          "label": "p"
        }
      ]
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "default": "center",
      "label": "t:global.alignment.heading",
      "options": [
        {
          "value": "left",
          "label": "t:global.position.left"
        },
        {
          "value": "center",
          "label": "t:global.position.center"
        },
        {
          "value": "right",
          "label": "t:global.position.right"
        }
      ]
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:event_calendar.settings.description",
      "info": "t:global.text.highlight_info"
    },
    {
      "type": "select",
      "id": "highlight_effect",
      "label": "t:global.text.highlight_effect.label",
      "options": [
        {
          "value": "underline",
          "label": "t:global.text.highlight_effect.option_1"
        },
        {
          "value": "marker",
          "label": "t:global.text.highlight_effect.option_2"
        },
        {
          "value": "text-color-change",
          "label": "t:global.text.highlight_effect.option_3"
        },
        {
          "value": "shadow",
          "label": "t:global.text.highlight_effect.option_4"
        }
      ],
      "default": "underline"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "t:global.text.transform.label",
      "options": [
        {
          "value": "none",
          "label": "t:global.text.transform.none"
        },
        {
          "value": "italic",
          "label": "t:global.text.transform.italic"
        },
        {
          "value": "uppercase",
          "label": "t:global.text.transform.uppercase"
        },
        {
          "value": "both",
          "label": "t:global.text.transform.italic_and_uppercase"
        }
      ],
      "default": "none"
