{%- paginate pages by 1 -%}
  {% liquid
    assign is_show_preorder = false
    assign is_apply_preorder = false
    assign current_variant = product.selected_or_first_available_variant
    if settings.applied_products_preorder == blank and settings.applied_collections_preorder == blank
      assign is_apply_preorder = true
    else
      assign list_product = ''
      for prod in settings.applied_products_preorder
        assign list_product = list_product | append: ';' | append: prod.id
      endfor
      for collec in settings.applied_collections_preorder
        for prod in collec.products
          assign list_product = list_product | append: ';' | append: prod.id
        endfor
      endfor
      if list_product contains product.id
        assign is_apply_preorder = true
      endif
    endif
    if is_apply_preorder
      if settings.preorder_show == 'yes'
        if current_variant.inventory_management == null
          assign is_show_preorder = true
        else
          if current_variant.inventory_quantity > 0
            assign is_show_preorder = true
          elsif current_variant.inventory_policy == 'continue' and current_variant.inventory_management != null
            assign is_show_preorder = true
          endif
        endif
      elsif settings.preorder_show == 'on_back_ordered'
        if current_variant.inventory_policy == 'continue' and current_variant.inventory_quantity < 1 and current_variant.inventory_management != null
          assign is_show_preorder = true
        endif
      endif
    endif

    assign preorder_button_label = 'products.product.pre_order' | t
    if settings.label_preorder_button_card != blank
      assign preorder_button_label = settings.label_preorder_button_card
    endif

    assign message_preorder = 'general.preorder.message_preorder' | t
    if settings.message_preorder_cart != blank
      assign message_preorder = settings.message_preorder_cart
    endif

    assign swatch_natural = false
    if settings.swatch_style == 'natural'
      assign swatch_natural = true
    endif
  %}

  {% liquid
    assign choose_option_id = section.id | append: '-' | append: product.id | append: '-' | append: paginate.current_page
    assign choose_option_element_id = 'ChooseOption-' | append: choose_option_id
    assign product_form_id = 'product-form-' | append: choose_option_id
    if request.design_mode
      assign current_time = 'now' | date: '%s'
      assign random_seed = current_time | modulo: 100
      assign product_form_id = product_form_id | append: random_seed
    endif

    if settings.lang_direction contains request.locale.iso_code
      assign is_rtl = true
    else
      assign is_rtl = false
    endif

    assign button_label = ''
    if is_show_preorder
      assign button_label = preorder_button_label
    else
      if product.selected_or_first_available_variant != null
        if current_variant.available == false
          assign button_label = 'products.product.sold_out' | t
        else
          if settings.pc_atc_button_label != blank
            assign button_label = settings.pc_atc_button_label
          else
            assign button_label = 'products.product.add_to_cart' | t
          endif
        endif
      else
        assign button_label = 'products.product.unavailable' | t
      endif
    endif
    assign atc_button_label = 'products.product.add_to_cart' | t
    if settings.pc_atc_button_label != blank
      assign atc_button_label = settings.pc_atc_button_label
    endif
  %}
  <div
    id="ChooseOptionContent"
    class="section--{{ section.id }}"
  >
    <div
      id="{{ choose_option_element_id }}"
      class="flex items-center w-full h-full border-solid border pt-7 pb-5 lg:pt-9 lg:pb-7 md:list-layout:p-8 rounded-corners"
    >
      <div
        class="current-variant hidden"
      >
        {{ product.selected_or_first_available_variant.id }}
      </div>
      <div
        id="ChooseOptionContent-{{ choose_option_id }}"
        class="choose-options-content content-center w-full h-full p-2.5 scrollbar-initial"
      >
        <div class="w-full scrollbar-body scrollbar-visible max-h-full overflow-y-auto{% if is_rtl %} rtl{% endif %}">
          <button
            @click="showOptions=false; activeElement.focus()"
            class="btn-close-choose-option absolute top-2.5 right-2.5 rtl:right-auto rtl:left-2.5 z-20 flex"
            aria-label="{{ 'accessibility.close' | t}}"
          >
            <span class="button__close icon-close-medium-desktop icon-close-small-mobile">
              {% render 'icon-all', icon: 'icon-close' %}
            </span>
          </button>
          <div class="w-full pb-1 lg:pl-0 md:pr-0 text-center{% unless is_rtl %} md:list-layout:text-left{% else %} md:list-layout:text-right{% endunless %}">
            <p
              href="{{ product.url }}"
              class="product-title mt-3 p-break-words h6"
            >
              {{ product.title | escape }}
            </p>
            {% comment %} price {% endcomment %}
            <div class="choose-option__price-wrapper mt-1.5 w-fit mx-auto md:list-layout:mx-0">
              {%- render 'price', product: product, use_variant: true, container: 'choose-option__price', price_wrapper: 'justify-center h5', disabled_default: true -%}
            </div>
            {% comment %} variant option {% endcomment %}
            {% unless product.has_only_default_variant %}
              {% if settings.pc_swatches_type != 'none' %}
                {% liquid
                  assign variant = product.selected_or_first_available_variant

                  assign text_option_name = settings.pc_swatch_text_option_name | split: ';'
                  assign swatch_option_name = settings.swatch_option_name | split: ';'
                  assign settings_show_swatch = false
                  if settings.pc_swatches_type == 'color' or settings.pc_swatches_type == 'both_text_and_color'
                    assign settings_show_swatch = true
                    assign list_swatch_option_values = settings.swatch_option_values | newline_to_br | strip_newlines | split: '<br />'
                  endif
                %}
                <div
                  class="variant-picker__wrapper flex flex-col md:list-layout:flex-row md:list-layout:gap-8 md:list-layout:flex-wrap gap-2 mt-3"
                  data-index-param="{{ paginate.current_page }}"
                >
                  <choose-option
                    data-product-url="{{ product.url }}"
                    data-product-id="{{ product.id }}"
                    data-choose-option-element-id="{{ choose_option_element_id }}"
                    class="product-card__wrapper"
                  >
                    <script
                      type="application/json"
                      data-type="current-variant-info"
                    >
                      {{ current_variant | json }}
                    </script>
                    {% if is_apply_preorder %}
                      <script
                        type="application/json"
                        data-type="current-variant-additional-info"
                        class="variant-inventory"
                      >
                        {
                          "id": {{ variant.id |  default: false }},
                          "inventory_policy": "{{ variant.inventory_policy }}",
                          "inventory_quantity": {{ variant.inventory_quantity | default: false }},
                          "inventory_management": "{{ variant.inventory_management }}"
                        }
                      </script>
                    {% endif %}
                    {% for product_option in product.options_with_values %}
                      {% liquid
                        assign show_color_swatch = false
                        if settings_show_swatch
                          if swatch_option_name contains product_option.name
                            assign show_color_swatch = "color-setting"
                          else
                            for option_value in product_option.values
                              if option_value.swatch
                                assign show_color_swatch = "category-mtf"
                                break
                              endif
                            endfor
                          endif
                        endif

                        if settings.pc_swatches_type == 'text' or settings.pc_swatches_type == 'both_text_and_color'
                          unless show_color_swatch == "color-setting"
                            if text_option_name contains product_option.name
                              assign show_color_swatch = false
                            endif
                          endunless
                        endif

                        assign product_option_position = product_option.position
                        assign product_option_index = product_option_position | minus: 1
                      %}
                      <div
                        class="variant-option__wrapper"
                        data-picker-type="{% if show_color_swatch %}swatches{% else %}button{% endif %}"
                      >
                        <legend class="flex pb-1 w-full flex-col">
                          <div class="text-small flex-auto text-center md:list-layout:text-start {% unless forloop.first %} mt-2{% endunless %}">
                            {% comment %}<span>{{ product_option.name }}<span x-text="options[{{ product_option_index }}] ? `: ${options[{{ product_option_index }}]}` : ''"></span></span>{% endcomment %}
                            <span>{{ product_option.name }}</span>:
                            <span class="seclected-value-{{ product_option.position }}">{{ product_option.selected_value }}</span>
                          </div>
                        </legend>
                        <div
                          class="variant-picker__product-option flex flex-wrap gap-1 justify-center md:list-layout:justify-start"
                          data-picker-type="swatches"
                        >
                          {% for option_value in product_option.values %}
                            {% liquid
                              assign is_selected_option = false
                              if product_option.selected_value == option_value
                                assign is_selected_option = true
                              endif

                              assign option_id = section.id | append: '-' | append: option_value.id | append: choose_option_id
                              assign data_position = product_option.position | append: '-' | append: forloop.index0 | append: '-' | append: product.id
                            %}

                            {% liquid
                              if option_value.available
                                assign option_disabled = false
                              else
                                assign option_disabled = true
                              endif
                            %}

                            {% if show_color_swatch %}
                              {% liquid
                                assign swatch_value_option = null
                                assign multi_colors = null
                                assign image_url = false

                                if show_color_swatch == "color-setting"
                                  for swatch_option in list_swatch_option_values
                                    assign swatch_item_key = swatch_option | split: ':' | first
                                    assign swatch_item_value = swatch_option | split: ':' | last | strip
                                    if swatch_item_key == option_value
                                      assign swatch_value_option = swatch_item_value
                                      break
                                    endif
                                  endfor
                                endif

                                assign swatch_value = option_value.name | downcase
                                assign swatch_option_style = 'color'
                                if option_value.swatch.image != blank
                                  assign swatch_option_style = 'image'
                                  assign image_url = option_value.swatch.image | image_url: width: 40
                                  assign swatch_value = 'url(' | append: image_url | append: ')'
                                elsif option_value.swatch.color
                                  assign swatch_value = 'rgba(' | append: option_value.swatch.color.rgba | append: ')'
                                endif

                                if swatch_value_option
                                  if swatch_value_option contains '.'
                                    assign swatch_option_style = 'image'
                                    assign image_url = swatch_value_option | file_img_url: '50x50'
                                    assign swatch_value = 'url(' | append: image_url | append: ')'
                                  else
                                    assign multi_colors = swatch_value_option | remove_first: '#' | split: '#'
                                    assign swatch_value = swatch_value_option
                                    assign swatch_option_style = 'color'
                                  endif
                                endif
                              %}
                              {% capture linear_background %}
                                {% if multi_colors.size == 3 %}
                                  linear-gradient(45deg, {{ '#' | append: multi_colors[0] }}, {{ '#' | append: multi_colors[0] }} 33.3%, {{ '#' | append: multi_colors[1] }} 33.3%, {{ '#' | append: multi_colors[1] }} 66.6%, {{ '#' | append: multi_colors[2] }} 66.6%, {{ '#' | append: multi_colors[2] }});
                                {% elsif multi_colors.size == 2 %}
                                  linear-gradient(45deg, {{ '#' | append: multi_colors[0] }}, {{ '#' | append: multi_colors[0] }} 50%, {{ '#' | append: multi_colors[1] }} 50%, {{ '#' | append: multi_colors[1] }});
                                {% endif %}
                              {% endcapture %}
                              {% liquid
                                if multi_colors.size > 1
                                  assign swatch_value = linear_background
                                  assign swatch_option_style = 'image'
                                endif
                                if settings.replace_color_with_variant_images
                                  assign variant_of_option_value = option_value.variant
                                  if variant_of_option_value.featured_media.preview_image != blank
                                    assign image_url = variant_of_option_value.featured_media.preview_image | image_url: width: 40
                                  elsif product.featured_media.preview_image != blank
                                    assign image_url = product.featured_media.preview_image | image_url: width: 40
                                  endif
                                  if image_url != blank
                                    assign swatch_option_style = 'image'
                                    assign swatch_value = 'url(' | append: image_url | append: ')'
                                  endif
                                endif

                                if forloop.first
                                  assign ratio_image = 1
                                  if swatch_option_style == 'image'
                                    assign ratio_image = 1 | divided_by: image_url.aspect_ratio
                                  endif
                                endif
                              %}
                              {%- capture inline_style -%}
                                {% if swatch_value %}
                                  {% if swatch_option_style == "color" %}
                                    --swatch-color-value: {{ swatch_value }};
                                  {% elsif swatch_option_style == "image" %}
                                    --swatch-image-value: {{ swatch_value }}; --swatch-color-value: {{ option_value.name | downcase }}
                                  {% endif %}
                                {% endif %}
                              {%- endcapture -%}
                              <input
                                class="swatch-option__value w-0 h-0 hidden variant-option {% if option_disabled %} disabled{% endif %} {% if option_value.selected %} selected{% endif %}"
                                type="radio"
                                id="{{ option_id }}"
                                name="VariantSelect-{{ product_option.name }}"
                                value="{{ option_value | escape }}"
                                form="{{ product_form_id }}"
                                aria-selected="{{ is_selected_option }}"
                                data-media-id="{{ current_variant.featured_media.id }}"
                                data-value="{{ option_value.name | escape }}"
                                data-option-position="{{ product_option_position }}"
                                data-option-value-id="{{ option_value.id }}"
                                data-type="swatches"
                              >
                              <label
                                class="swatch-option__label flex items-center color-border-[rgba(var(--color-text),0.12)] variant-option__label cursor-pointer {% unless swatch_natural %} !h-9 !w-9{% else %} swatch-option__natural{% endunless %}"
                                data-swatch-value="{{ option_value | downcase }}"
                                data-swatch-type="color"
                                style="{% if swatch_natural %}--swatch-option-ratio: {{ ratio_image }};{% endif %} {{ inline_style }}"
                                tabindex="0"
                                {% unless request.design_mode %}
                                  for="{{ option_id }}"
                                {% endunless %}
                                data-position="{{ data_position }}"
                              >
                              </label>
                            {% else %}
                              <input
                                class="swatch-option__value h-px w-px hidden variant-option {% if option_disabled %} disabled{% endif %} {% if option_value.selected %} selected{% endif %}"
                                type="radio"
                                id="{{ option_id }}"
                                value="{{ option_value | escape }}"
                                form="{{ product_form_id }}"
                                aria-selected="{{ is_selected_option }}"
                                data-option-name="{{ product_option.name | escape }}"
                                data-option-position="{{ product_option_position }}"
                                data-media-id="{{ current_variant.featured_media.id }}"
                                data-value="{{ option_value | escape }}"
                                data-option-value-id="{{ option_value.id }}"
                                data-type="buttons"
                              >
                              <label
                                class="swatch-option__label color-border-[rgba(var(--color-text),0.12)] text-small select-none cursor-pointer relative md:list-layout:text-small py-2 px-3 border border-solid overflow-hidden break-words {%  if settings.edges_type == 'rounded_corners' %} rounded{% endif %}"
                                data-swatch-type="text"
                                tabindex="0"
                                {% unless request.design_mode %}
                                  for="{{ option_id }}"
                                {% endunless %}
                                data-position="{{ data_position }}"
                              >
                                {{ option_value | escape }}
                              </label>
                            {% endif %}
                          {% endfor %}
                        </div>
                      </div>
                    {% endfor %}
                  </choose-option>
                </div>
              {% endif %}
            {% endunless %}
            {% comment %} end variant {% endcomment %}
            <div
              class="product-info__form-wrapper w-full mt-4 md:list-layout:flex md:list-layout:flex-wrap md:gap-y-2 md:list-layout:items-center md:list-layout:gap-x-4 md:list-layout:pt-3 md:list-layout:border-t"
              id="ProductForm-{{ choose_option_id }}"
              x-data="xProductForm('{{ product_form_id }}', '{{ current_variant.id }}', {{ current_variant.available | default: false }}, '{{ button_label }}', '{{ atc_button_label }}', '{{ section.id }}', '{{ choose_option_element_id }}', '{{ settings.preorder_show }}', '{{ preorder_button_label }}', {{ is_apply_preorder }} )"
              x-init="handleInitProductForm()"
            >
              <div class='w-full flex justify-center bg-clip-content mb-2 md:list-layout:mb-0'>
                <div
                  class="flex relative items-center error-message flash-message"
                  role="alert"
                  x-cloak
                  x-show="errorMessage"
                  @click.away="errorMessage=false"
                >
                  <span
                    x-ref="error_message"
                  ></span>
                </div>
              </div>
              <div class="md:list-layout:w-fit">
                {%- form 'product', product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form', x-ref: 'product_form' -%}
                  <input
                    class="product-form__variant-id w-full px-4 py-3 hidden "
                    name="id"
                    type="hidden"
                    form="{{ product_form_id }}"
                    :value="variantId"
                    :disabled="!isOptionAvailable"
                  >
                  <div class="choose-option__properties-group hidden">
                    {%- capture estimate_shipping_message -%}
                      {%- render 'estimate-shipping-message', product: product, variant: current_variant -%}
                    {%- endcapture -%}
                    {%- assign message_update = estimate_shipping_message | strip -%}
                    {% if message_update != blank and settings.estimate_show_in_cart == 'show_item' %}
                      {% liquid
                        assign name_edt = settings.name_edt
                        if settings.name_edt == blank
                          assign name_edt = 'general.estimate_delivery' | t
                        endif
                      %}
                      <input
                        type="hidden"
                        name="properties[{{ name_edt }}]"
                        value="{{ message_update }}"
                        class="choose-option__form__estimate-delivery hidden"
                        type="hidden"
                      >
                    {% endif %}

                    <input
                      type="hidden"
                      class="choose-option__form__preorder hidden"
                      name="properties[{{ 'general.preorder.name' | t }}]"
                      value="{{ message_preorder }}"
                      {% unless is_show_preorder %}
                        disabled
                      {% endunless %}
                    >
                  </div>
                  <div class="w-full flex flex-row flex-wrap gap-1">
                    {% if  settings.hide_cart == false %}
                    <div id="ChooseOptionQuantity" class="grow {% if settings.pc_mobile_atc_button_layout == 'mobile_show_atc_with_quantity' %} block {% else %} sm:hidden {% endif %}{% if settings.pc_desktop_atc_button_layout == 'desktop_show_atc_with_quantity' %} md:block {% else %} md:hidden {% endif %}">
                      {% render 'product-quantity-atc',
                        section: section,
                        current_variant: current_variant,
                        product: product,
                        product_form_id: product_form_id,
                        block_choose_option: true,
                        index_param: paginate.current_page,
                        content_center_class: 'w-full',
                        is_enabled: true
                      %}
                    </div>
                    {% endif %}
                    <div class="grow-[2]">
                      <div>
                        <custom-button>
                          <button
                            class="product-form__btn-add-to-cart button button-{{settings.pc_button_style | default: 'primary'}} px-5 py-3 h-fit w-full flex items-center justify-center relative md:list-layout:px-5.5 md:list-layout:py-3"
                            type="submit"
                            name="add"
                            aria-haspopup="dialog"
                            aria-labelledby="{{ product_form_id }}-submit title-{{ section.id }}-{{ product.id }}"
                            aria-live="polite"
                            data-sold-out-message="true"
                            :class="{'opacity-80': !isAvailableButton, 'visible': visible, 'invisible': !visible,'is-loading': isLoading}"
                            :disabled="!isAvailableButton"
                            :aria-disabled="!isAvailableButton || isLoading"
                            :tabindex="isAvailableButton ? '0' : '-1'"
                            @click.prevent="handleAddToCart($event, false, '{{ product.selected_or_first_available_variant.id }}')"
                          >
                            <span
                              class="btn__text"
                              x-text="btnText"
                              :class="{'invisible': isLoading}"
                            >
                            </span>
                            <span
                              class="inline-block w-5 h-5 animate-spin absolute left-[calc(50%-10px)]"
                              x-show="isLoading"
                              x-cloak
                            >
                              {% render 'icon-all', icon: 'icon-loading' %}
                            </span>
                          </button>
                        </custom-button>
                      </div>
                    </div>
                  </div>
                {%- endform -%}
              </div>
              <a
                href="{{ product.url }}"
                class="view_product_detail text-small relative inline-block mt-2 md:list-layout:mt-0"
              >
                <span class="text-link">{{ 'products.product.view_full_details' | t }}</span>
              </a>
              <script
                type="application/json"
                data-type="init-current-variant"
              >
                {{ current_variant | json }}
              </script>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endpaginate %}
