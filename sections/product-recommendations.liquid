{% liquid
  assign products_to_show = section.settings.products_to_show | plus: 0
  assign columns_desktop = section.settings.columns_desktop | plus: 0
  assign columns_mobile = section.settings.columns_mobile | plus: 0
  if columns_desktop == 1
    assign columns_tablet = 1
  else 
    assign columns_tablet = 2
  endif

  assign enable_desktop_slider = section.settings.enable_carousel_desktop   
  assign swiper_on_mobile = section.settings.enable_swiper_mobile
  assign enable_tablet_slider = enable_desktop_slider

  if recommendations.products_count <= columns_desktop or products_to_show <= columns_desktop
    assign enable_desktop_slider = false
  endif
  if recommendations.products_count <= columns_tablet or products_to_show <= columns_tablet
    assign enable_tablet_slider = false
  endif
  if recommendations.products_count <= columns_mobile or products_to_show <= columns_mobile
    assign swiper_on_mobile = false
  endif
%}

{% style %}
  .section--{{ section.id }} {
    padding-top: calc({{ section.settings.padding_top }}px * var(--mobile-padding-ratio));
    padding-bottom: calc({{ section.settings.padding_bottom }}px * var(--mobile-padding-ratio));
  }
  .section--{{ section.id }} .slider-container {
    --swiffy-slider-item-gap: {{ section.settings.spacing_mobile }}px;
  }
  @media (min-width: 768px) {
    .section--{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
    .section--{{ section.id }} .slider-container {
      --swiffy-slider-item-gap: {{ section.settings.spacing }}px;
    }
  }
{% endstyle %}
{% render 'section-divider' %}
<div
  class="product-recommendations__wrapper float-none section--{{ section.id }} color-{{ section.settings.color_scheme_light.id }} dark-color-{{ section.settings.color_scheme_dark.id }} {{ section.settings.section_width }} rounded-corners-container"
  x-data='xSection("{{ section.id }}", $el)'
>
  <div
    x-intersect.once.margin.200px="loading = true; $store.xProductRecommendations.load($el, '{{ section.id }}', '{{ product.id }}', {{ section.settings.products_to_show }}, 'related', true)"
    class="product-recommendations"
  >
    <div
      class="swiffy-slider slider-item-show{{ columns_mobile }} md:slider-item-show{{ columns_tablet }} lg:slider-item-show{{ columns_desktop }}"
      x-show="loading"
    >
      <div
        class="skeleton-slide__list slider-container"
        x-cloak
      >
        {%- for i in (1..columns_desktop) -%}
          <div class="skeleton-product-card slide-item">
            {% render 'skeleton-product-card', show_vendor: section.settings.show_vendor, show_rating: section.settings.show_rating %}
          </div>
        {%- endfor -%}
      </div>
    </div>

    {% if recommendations.performed and recommendations.products_count > 0 %}
      {% liquid
        assign max_product_show = 0
        for product in recommendations.products
          if product.metafields.custom.excluded_from_recommendation != true
            assign max_product_show = max_product_show | plus: 1
          endif
          if max_product_show == section.settings.products_to_show
            break
          endif
        endfor
      %}
      <div
        x-init="loading = false"
        class=""
      >
        {% if section.settings.heading != blank %}
          <{{ section.settings.heading_tag }} class="text-{{ section.settings.heading_alignment }} heading-{{ section.settings.heading_size }} block heading-content-spacing">
            {% render 'text-highlight',
              id: section.id,
              text: section.settings.heading,
              highlight_effect: section.settings.highlight_effect,
              text_transform: section.settings.text_transform
            %}
          </{{ section.settings.heading_tag }}>
        {% endif %}
        <div
          class="product-recommendation__container swiffy-slider enable-effect-hover relative slider-nav-animation slider-nav-animation-fadein slider-item-snapstart overflow-hidden
            {%- unless swiper_on_mobile %} !swiffy-slider{% endunless %}
            {%- unless enable_tablet_slider %} md:!swiffy-slider{% endunless %}
            {%- if settings.lang_direction contains request.locale.iso_code %} rtl{% endif -%}
          "
          x-intersect.once.margin.200px="
            $store.xSwiffy.load($el, {
              'effect': 'slide',
              'mediaQuery': 'min',
              'isLoop': true,
              {% if section.settings.auto_play != 0 %}
                'autoPlay': true,
                'autoPause': true,
              {% endif %}
              'speed': {{ section.settings.auto_play | times: 1000 }},
              'breakPoints':{
                '0': {
                  'slidesPerView': {{ columns_mobile }}
                },
                '768': {
                  'slidesPerView': {{ columns_tablet }}
                },
                '1024': {
                  'slidesPerView': {{ columns_desktop }}
                }
              }
            });
          "
        >
          {%- if enable_desktop_slider and recommendations.products_count > 0 -%}
            {% render 'slider-navigation-button' %}
          {%- endif -%}
          <div 
            class="slider-container anm-reveal-container
              {%- if swiper_on_mobile %} slider-item-show{{ columns_mobile }} w-full
              {%- else %} grid grid-cols-{{ columns_mobile }}{% if enable_desktop_slider %} md:grid-cols-none{% endif -%}
              {%- endif -%}
              {%- if enable_desktop_slider == false -%}
                {%- if enable_tablet_slider %} md:slider-item-show{{ columns_tablet }} md:grid-cols-none{%- else %} md:grid md:grid-cols-{{ columns_tablet }}{%- endif %} lg:grid lg:grid-cols-{{ columns_desktop -}}
              {%- else %} md:cursor-grab md:grid md:slider-item-show{{ columns_tablet }} lg:slider-item-show{{ columns_desktop -}}
              {%- endif -%}
            "
            data-mobile-gap="{{ section.settings.spacing_mobile }}px"
            data-desktop-gap="{{ section.settings.spacing }}px"
          >
            {% assign count_product_to_show = 0 %}
            {% for recommendation in recommendations.products %}
              {% if recommendation.metafields.custom.excluded_from_recommendation != true %}
                <div
                  class="{% if swiper_on_mobile or enable_tablet_slider %}slide-item{% endif %} product-recommendation__item"
                  x-intersect.once="document.dispatchEvent(new CustomEvent('maximize:animation:reveal'));"
                >
                  {% assign index_param = section.index | append: forloop.index | plus: 0 %}
                  {% render 'product-card',
                    product: recommendation,
                    is_recommendation: true,
                    show_vendor: section.settings.show_vendor,
                    show_rating: section.settings.show_rating,
                    show_quickview: section.settings.show_quick_view,
                    section_id: section.id,
                    columns_desktop: section.settings.columns_desktop,
                    column_mobile: 1,
                    index_param: index_param,
                    index: forloop.index
                  %}
                </div>
                {% assign count_product_to_show = count_product_to_show | plus: 1 %}
              {% endif %}
              {% if count_product_to_show == section.settings.products_to_show %}
                {% break %}
              {% endif %}
            {% endfor %}
          </div>
          {% render 'progress-bar',
            show_on_mobile: swiper_on_mobile,
            show_on_tablet: enable_tablet_slider
          %}
        </div>
      </div>
    {% else %}
      <div x-init="loading = false"></div>
    {% endif %}
  </div>
</div>
<script
  src="{{ 'product-recommendations.js' | asset_url }}"
  defer
></script>
<script
  src="{{ 'product-form.js' | asset_url }}"
  defer="defer"
></script>
<script
  src="{{ 'product-card.js' | asset_url }}"
  defer
></script>
{% if settings.pc_show_highlight and settings.highlight_att_enable_auto_rotate %}
  <script src="{{ 'slide-element.js' | asset_url }}" defer></script>
{% endif %}
{% schema %}
{
  "name": "t:product_recommendations.name",
  "class": "section-product-recommendations maximize-section",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:product_recommendations.settings.paragraph"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "You may also like",
      "label": "t:global.text.heading",
      "info": "t:global.text.highlight_info"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:global.text.heading_size",
      "options": [
        {
          "value": "small",
          "label": "t:global.size.small"
        },
        {
          "value": "medium",
          "label": "t:global.size.medium"
        },
        {
          "value": "large",
          "label": "t:global.size.large"
        }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "default": "h2",
      "label": "t:global.text.heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        },
        {
          "value": "p",
          "label": "p"
        }
      ]
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "default": "center",
      "label": "t:global.alignment.heading",
      "options": [
        {
          "value": "left",
          "label": "t:global.position.left"
        },
        {
          "value": "center",
          "label": "t:global.position.center"
        },
        {
          "value": "right",
          "label": "t:global.position.right"
        }
      ]
    },
    {
      "type": "select",
      "id": "highlight_effect",
      "label": "t:global.text.highlight_effect.label",
      "options": [
        {
          "value": "underline",
          "label": "t:global.text.highlight_effect.option_1"
        },
        {
          "value": "marker",
          "label": "t:global.text.highlight_effect.option_2"
        },
        {
          "value": "text-color-change",
          "label": "t:global.text.highlight_effect.option_3"
        },
        {
          "value": "shadow",
          "label": "t:global.text.highlight_effect.option_4"
        }
      ],
      "default": "underline"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "t:global.text.transform.label",
      "options": [
        {
          "value": "none",
          "label": "t:global.text.transform.none"
        },
        {
          "value": "italic",
          "label": "t:global.text.transform.italic"
        },
        {
          "value": "uppercase",
          "label": "t:global.text.transform.uppercase"
        },
        {
          "value": "both",
          "label": "t:global.text.transform.italic_and_uppercase"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4,
      "label": "t:main_product.blocks.complementary.settings.max_product_show"
    },
    {
      "type": "header",
      "content": "t:global.header.product_card"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "t:global.product.show_vendor"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "t:global.product.show_product_rating",
      "info": "t:global.product.show_product_rating_info"
    },
    {
      "type": "checkbox",
      "id": "show_quick_view",
      "default": true,
      "label": "t:global.product.show_quick_view_button"
    },
    {
      "type": "header",
      "content": "t:global.header.carousel"
    },
    {
      "type": "checkbox",
      "id": "enable_carousel_desktop",
      "default": false,
      "label": "t:global.carousel.enable_carousel_on_desktop"
    },
    {
      "type": "checkbox",
      "id": "enable_swiper_mobile",
      "default": false,
      "label": "t:global.carousel.enable_swipe_on_mobile"
    },
    {
      "type": "range",
      "id": "auto_play",
      "min": 0,
      "max": 10,
      "step": 2,
      "unit": "s",
      "label": "t:global.carousel.auto_play",
      "info": "t:global.carousel.auto_play_info",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:global.header.desktop_layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "t:global.section.number_of_columns"
    },
    {
      "type": "range",
      "id": "spacing",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12,
      "label": "t:global.section.block_spacing"
    },
    {
      "type": "header",
      "content": "t:global.header.mobile_layout"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "t:global.section.number_of_columns",
      "options": [
        {
          "value": "1",
          "label": "t:global.section.columns.1_column"
        },
        {
          "value": "2",
          "label": "t:global.section.columns.2_columns"
        }
      ]
    },
    {
      "type": "range",
      "id": "spacing_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "label": "t:global.section.block_spacing"
    },
    {
      "type": "header",
      "content": "t:global.header.section_layout"
    },
    {
      "type": "select",
      "label": "t:global.section.section_width.label",
      "id": "section_width",
      "options": [
        {
          "label": "t:global.section.section_width.option_1",
          "value": "page-width"
        },
        {
          "label": "t:global.section.section_width.option_2",
          "value": "full-width"
        },
        {
          "label": "t:global.section.section_width.option_3",
          "value": "full-width-padded"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:global.section.top_padding",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:global.section.bottom_padding",
      "default": 28
    },
    {
      "type": "checkbox",
      "id": "show_section_divider",
      "default": false,
      "label": "t:global.section.show_section_divider"
    },
    {
      "type": "header",
      "content": "t:global.header.colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme_light",
      "default": "scheme-1",
      "label": "t:global.colors.color_scheme_light"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme_dark",
      "default": "scheme-2",
      "label": "t:global.colors.color_scheme_dark"
    }
  ]
}
{% endschema %}
