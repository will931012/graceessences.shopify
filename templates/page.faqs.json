      "blocks": {
        "frequently_asked_question_n4JpLk": {
          "type": "frequently_asked_question",
          "settings": {
            "icon": "none",
            "another_icon": "",
            "heading": "1/ What products do you offer?",
            "row_content": "<p>We specialize in premium electronic products. Be it earpods, smartphones or high-end gaming gears, we got everything in stock for good prices.</p>",
            "highlight_effect": "underline",
            "text_transform": "none"
          }
        },
        "frequently_asked_question_qAEbw7": {
          "type": "frequently_asked_question",
          "settings": {
            "icon": "none",
            "another_icon": "",
            "heading": "2/ Do you offer international shipping?",
            "row_content": "<p>Yes, we offer international shipping to select countries. Shipping fees and delivery times will be calculated at checkout.</p>",
            "highlight_effect": "underline",
            "text_transform": "none"
          }
        },
        "frequently_asked_question_Adkzwf": {
          "type": "frequently_asked_question",
          "settings": {
            "icon": "none",
            "another_icon": "",
            "heading": "3/ What is your return policy?",
            "row_content": "<p>We offer a 30-day return policy on unused products in their original packaging. Visit our Returns & Exchanges page for more details.</p>",
            "highlight_effect": "underline",
            "text_transform": "none"
          }
        },
        "frequently_asked_question_7VnRrw": {
          "type": "frequently_asked_question",
          "settings": {
            "icon": "none",
            "another_icon": "",
            "heading": "4/ Do you offer product warranties?",
            "row_content": "<p>Yes, all our products come with a standard manufacturer's warranty. The length and coverage vary by product, which will be specified on the product page.</p>",
            "highlight_effect": "underline",
            "text_transform": "none"
          }
        }
      },
