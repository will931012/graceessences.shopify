    "faq_FPQbGW": {
      "type": "faq",
      "blocks": {
        "frequently_asked_question_3HmQFy": {
          "type": "frequently_asked_question",
          "settings": {
            "icon": "in-person-support",
            "another_icon": "",
            "heading": "How can I tell if a perfume is authentic?",
            "row_content": "<p>All our perfumes are 100% authentic and sourced directly from official distributors. You can verify the batch number, barcode, and bottle finish. If in doubt, contact us and we will be happy to help.</p>",
            "highlight_effect": "underline",
            "text_transform": "none"
          }
        },
        "frequently_asked_question_7gULKh": {
          "type": "frequently_asked_question",
          "settings": {
            "icon": "in-person-support",
            "another_icon": "",
            "heading": "What is the difference between EDT and EDP?",
            "row_content": "<p><strong>EDT (Eau de Toilette)</strong> has a lower concentration of essential oils (5-15%) and lasts around 4-6 hours. <strong>EDP (Eau de Parfum)</strong> has a higher concentration (15-20%) and lasts 6-8 hours. <strong>Parfum or Extrait</strong> is the most concentrated and can last more than 8 hours.</p>",
            "highlight_effect": "underline",
            "text_transform": "none"
          }
        },
        "frequently_asked_question_yPXGtn": {
          "type": "frequently_asked_question",
          "settings": {
            "icon": "in-person-support",
            "another_icon": "",
            "heading": "How long does the fragrance last?",
            "row_content": "<p>Longevity depends on the concentration type (EDT, EDP, Parfum), your skin type, and how you apply it. Spraying on pulse points (neck, wrists, behind the ears) helps extend wear. Moisturized skin retains fragrance better.</p>",
            "highlight_effect": "underline",
            "text_transform": "none"
          }
        },
        "frequently_asked_question_gmar4i": {
          "type": "frequently_asked_question",
          "settings": {
            "icon": "in-person-support",
            "another_icon": "",
            "heading": "Do you ship nationwide?",
            "row_content": "<p>Yes, we ship nationwide. Delivery times vary depending on your location. We track every order to ensure it arrives in perfect condition.</p>",
            "highlight_effect": "underline",
            "text_transform": "none"
          }
        },
        "frequently_asked_question_wQnQE3": {
          "type": "frequently_asked_question",
          "settings": {
            "icon": "in-person-support",
            "another_icon": "",
            "heading": "Can I return my purchase?",
            "row_content": "<p>We accept returns within 30 days of receiving the product, provided it is in its original packaging and unused. If you receive a damaged or incorrect item, contact us immediately and we will resolve it.</p>",
            "highlight_effect": "underline",
            "text_transform": "none"
          }
        },
        "frequently_asked_question_UHzebD": {
          "type": "frequently_asked_question",
          "settings": {
            "icon": "in-person-support",
            "another_icon": "",
            "heading": "How should I store my perfume?",
            "row_content": "<p>Store your fragrances in a cool, dry place away from direct sunlight. Heat and humidity can alter the composition of the perfume. Ideally, keep them in their original box in a drawer or cabinet.</p>",
            "highlight_effect": "underline",
            "text_transform": "none"
          }
        }
      },
