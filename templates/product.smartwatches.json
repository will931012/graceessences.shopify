nment":"left","highlight_effect":"underline","text_transform":"none"}},"highlight_feature_kz9xUd":{"type":"highlight_feature","settings":{"icon":"none","another_icon":"","heading":"Strap Colour","heading_size":"medium","text":"<p>Black<\/p>","desktop_content_alignment":"left","mobile_content_alignment":"left","highlight_effect":"underline","text_transform":"none"}},"highlight_feature_Npkm4f":{"type":"highlight_feature","settings":{"icon":"none","another_icon":"","heading":"Heart Rate Monitor","heading_size":"medium","text":"<p>Yes<\/p>","desktop_content_alignment":"left","mobile_content_alignment":"left","highlight_effect":"underline","text_transform":"none"}},"description_CRe9Pk":{"type":"description","settings":{"heading":"About this item","heading_size":"large","heading_alignment":"left","number_of_lines_shown":"none","read_more_label":"Read more","see_less_label":"See less"}},"rich_text_WxhdWa":{"type":"rich_text","settings":{"icon":"none","another_icon":"","heading":"","heading_size":"large","text":"<p>Bluetooth Call & Messaging‌ Notification: Experience seamless Bluetooth 5.3 calling with HD speaker\/mic on this smartwatch, receiving WhatsApp\/Telegram\/Facebook notifications on its 1.83\" touchscreen. The auto-wake feature activates when lifting your wrist, reducing phone reliance (Note: Message replies not supported)<br\/><br\/>Alexa Built-in Voice Control‌: Get instant news\/weather\/schedule updates, set reminders, and control smart home devices\/control music via built-in Amazon Alexa. All instantly available on your wrist. Life simplified, hands-free(requires connected smartphone)<\/p><p>1.83\"HD Touch and DIY Dials: Smartwatch let you have different touch screen watch experience, watch smart light up the screen for your use, equipped with 100+screens for you to choose, you can also DIY unique fitness tracker screen<br\/><br\/>24\/7 Health Tracking: Android smart watch has a built-in optical sensor that continuously monitors your stress, heart rate, and sleep quality. The sleep tracker provides a comprehensive quality analysis of your sleep to help you make informed decisions<br\/><br\/>100+ Sports Modes: Smart watches for women has more than 100 sports modes. Whether you are exercising outdoors or in the gym, you can set the amount of exercise and duration to conduct standardized exercise. Keeps you in the know wherever you are<br\/><br\/>IP68 Waterproof: Fitness trackers is IP68 rated waterproof, so you can wear it while washing your hands, face or daily sweating without worrying about water intrusion. (Do not use for baths, saunas, hot springs, etc.)<br\/><br\/>Multi-functional Smartwatch: Fitness tracker is equipped with basic functions such as voice assistant, weather forecast, camera and music control, customized dials, with its multifunctionality, this watch makes your every day easier, and more productive<br\/><br\/>Quality Service: Fitness watch for men and women offers 30 days return and 1 year warranty. If you have any questions about the use of the product, please feel free to communicate with us through “Click on your order at Amazon - Contact Seller”<\/p>","text_alignment":"left","highlight_effect":"underline","text_transform":"none","select_page":"","number_of_lines_shown":"none","read_more_label":"Read more","see_less_label":"See less","show_payment_icons":false,"payment_icon":"","show_border":false,"color_scheme_light":"scheme-1","color_scheme_dark":"scheme-2"}},"specifications_WqUq9M":{"type":"specifications","settings":{"heading":"Product information","heading_size":"large","text":"","text_alignment":"left","table_detail":"<p>Package Dimensions: 7.24 x 3.39 x 0.75 inches<br\/>Item Weight: 1.6 ounces<br\/>ASIN: B0F6MQM1KK<br\/>Item model number: IDW25<br\/>Batteries: 1 A batteries required. (included)<br\/>Date First Available: April 28, 2025<br\/>Manufacturer: BOOOMIC<br\/>Item Weight: 1.6 Ounces<br\/>Standing screen display size: 1.83 Inches<br\/>Memory Storage Capacity: 1 GB<br\/>Ram Memory Ins