.gift-card__header {
  text-align: center;
  padding-bottom: 1.5rem;
  padding-top: 2.5rem;
}

@media (min-width: 768px) {
  .gift-card__header {
    padding-top: 5rem;
    padding-bottom: 2rem;
  }
}

.gift-card__main {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-left: 1rem;
  padding-right: 1rem;
  gap: 1.625rem;
  padding-bottom: 2.5rem;
}

@media (min-width: 768px) {
  .gift-card__main {
    padding-bottom: 5rem;
  }
}

.gift-card__info {
  text-align: center;
}

@media (min-width: 768px) {
  .gift-card__info {
    max-width: 30rem;
  }
}

.gift-card__action {
  text-align: center;
  width: 100%;
  margin-left: auto;
  margin-right: auto;
}

@media (min-width: 768px) {
  .gift-card__action {
    max-width: 30rem;
  }
}

.gift-card__code__wrapper {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  bottom: 0.875rem;
  width: max-content;
  display: flex;
  align-items: center;
  padding-left: 1rem;
  padding-right: 1rem;
  padding-top: 0.5rem;
  padding-bottom: 0.5rem;
  background-color: rgba(var(--color-background));
  color: rgba(var(--color-secondary-button-text));
  gap: 0.5rem;
  cursor: pointer;
}

@media (min-width: 768px) {
  .gift-card__code__wrapper {
    bottom: 1.25rem;
    gap: 0.625rem;
  }
}

.gift-card__code__wrapper:not(:focus-visible) {
  outline: 1px dashed rgba(var(--color-secondary-button-text));
}

.gift-card__copy-link {
  color: inherit;
  display: flex;
  margin-left: auto;
  margin-right: auto;
  gap: 0.25rem;
  align-items: center;
}

.gift-card__info__content {
  position: relative;
  text-align: center;
  margin-left: auto;
  margin-right: auto;
  padding: 0;
}

.gift-card__qr-code {
  text-align: center;
  width: 100%;
  max-width: 9.75rem;
  margin-left: auto;
  margin-right: auto;
  outline: 1px dashed rgba(var(--color-text), 0.2);
  padding: 0.5rem;
}

.gift-card__action__number {
  text-align: center;
  margin-left: auto;
  margin-right: auto;
  width: 100%;
  padding-left: 1.25rem;
  padding-right: 1.25rem;
  padding-top: 1.625rem;
}

@media (min-width: 768px) {
  .gift-card__action__number {
    padding-left: 56px;
    padding-right: 56px;
  }
}

.gift-card__action__button {
  width: 100%;
  display: flex;
  gap: 0.25rem;
}

@media (min-width: 768px) {
  .gift-card__action__button {
    gap: 0.375rem;
  }
}

.gift-card__action__button--continue {
  line-height: normal;
  display: block;
  font-weight: 600;
  width: 50%;
  padding-left: 1rem;
  padding-right: 1rem;
  padding-top: 0.875rem;
  padding-bottom: 0.875rem;
}

.gift-card__action__button--print {
  display: block;
  font-weight: 600;
  width: 50%;
  padding-left: 1rem;
  padding-right: 1rem;
  padding-top: 0.875rem;
  padding-bottom: 0.875rem;
}

.gift-card__icon__wrapper {
  display: flex;
  align-items: center;
  min-width: 12px;
  min-height: 12px;
  height: 1em;
  width: 1em;
  position: relative;
}

.gift-card__icon {
  position: absolute;
  inset: 0;
  transition: all 0.3s ease-in-out;
  transform: translateY(100%);
  opacity: 0;
}

.gift-card__icon.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.gift-card__icon.is-hidden {
  opacity: 0;
  transform: translateY(-100%);
}

.gift-card__info__value {
  text-align: center;
  color: rgba(var(--color-price));
}

.gift-card__info__subtext {
  text-align: center;
  margin-bottom: 0.125rem;
}

@media (min-width: 768px) {
  .gift-card__info__subtext {
    margin-bottom: 0.375rem;
  }
}