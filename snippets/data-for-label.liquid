{% capture list_metafield_label %}
  {% liquid
    assign metafield_label_list = settings.label_and_badge_mtf | newline_to_br | strip_newlines | split: '<br />'
    for metafield_key in metafield_label_list
      assign list_key = metafield_key | split: "."
      assign data_metafield = current_variant.metafields[list_key[0]][list_key[1]]
      if data_metafield == blank or data_metafield.type != "single_line_text_field"
        assign data_metafield = product.metafields[list_key[0]][list_key[1]]
        if data_metafield.type != "single_line_text_field"
          assign data_metafield = ""
        endif 
      endif 
      if data_metafield
        echo '{"' | append: metafield_key | append: '": ' | append: '"' | append: data_metafield | append: '"},'
      endif
    endfor
  %}
{% endcapture %}
{% liquid
  assign list_metafield_label = list_metafield_label | remove_last: ","
  assign list_metafield_label = "[" | append: list_metafield_label | append: "]" 
%}
{ 
  "id": {{ product.id }},
  "available": {{ target.available | default: false }},
  "title": "{{ product.title | escape }}",
  "compare_at_price": {{ target.compare_at_price | default: 0 }},
  "price": {{ target.price | default: 0 }},
  "price_with_currency": "{%- if settings.currency_code_enable %}{{ target.price | money_with_currency | escape }}{% else %}{{ target.price | money | escape }}{% endif -%}",
  "sale_amount": "{{ sale_amount | money | strip_html | default: -1 }}", 
  "collections": "||{{ product.collections | map: 'id' | join: '||' }}||",
  "inventory_management": "{%- if inventory_management != blank -%}{{ inventory_management }}{%- else -%}{{- target.inventory_management | default: false -}}{%- endif -%}",
  "qty": {{ label_quantity | default: -1 }},
  "container": "{{ container }}",
  "make_content_center": {{ show_content_center | default: false }},
  {% if desktop_carousel_option %}
    "desktop_carousel_option": "{{ desktop_carousel_option }}",
  {% endif %}
  {% if desktop_carousel_position %}
    "desktop_carousel_position": "{{ desktop_carousel_position }}",
  {% endif %}
  {% if desktop_layout %}
    "desktop_layout": "{{ desktop_layout }}",
  {% endif %}
  {% if diff_day_create %}
    "diff_day_create": {{ diff_day_create }},
  {% endif %}
  {% if diff_day_publish %}
    "diff_day_publish": {{ diff_day_publish }},
  {% endif %}
  {% if label_position %}
    "label_position": "{{ label_position }}",
  {% endif %}
  "is_show_preorder": {{ is_show_preorder }}
  {% if settings.label_and_badge_mtf != blank %}
    ,"metafield_label": {{ list_metafield_label }}
  {% endif %}
}