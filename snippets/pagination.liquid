{% comment %}
    Renders a set of links for paginated results. Must be used within paginate tags.

    Usage:
    {% paginate results by 2 %}
      {% render 'pagination', paginate: paginate, anchor: '#yourID' %}
    {% endpaginate %}

    Accepts:
    - paginate: {Object}
    - anchor: {String} (optional) This can be added so that on page reload it takes you to wherever you've placed your anchor tag.
{% endcomment %}
{%  liquid 
  if settings.lang_direction contains request.locale.iso_code
    assign is_rtl = true
  else
    assign is_rtl = false
  endif
  assign count_item = paginate.current_offset | plus: products_per_page
  if count_item > paginate.items
    assign count_item = paginate.items
  endif
  if settings.edges_type == 'rounded_corners'
    assign rounded_corners = true
  endif
%}
{%- if paginate.parts.size > 0 -%}
  {% if pagination == 'click_to_load' %}
    <div x-data="xPagination('{{ section.id }}')" id="btn-pagination-{{ section.id }}" class="w-full flex flex-col items-center justify-center">
      <p class="mb-3 anm-fade-element" x-intersect.once="$el.classList.add('is-visible')">{{ 'general.global.showing_items' | t: item: count_item, total: paginate.items }}</p>
      {%- if paginate.next -%}
        <custom-button>
          <button class="button button-secondary relative pl-9 pr-9 pt-3.5 pb-3.5" @click="loadData('{{ paginate.next.url }}{{ anchor }}')">
            <span :class="loading && 'opacity-0'">{{ 'general.global.load_more' | t }}</span>
            <div class="lg:inline-block animate-spin w-4 h-4 md:w-5 md:h-5 absolute top-[calc(50%-8px)] left-[calc(50%-8px)] md:top-[calc(50%-10px)] md:left-[calc(50%-10px)]" x-show="loading" x-cloak>
              {% render 'icon-all', icon: 'icon-loading' %}
            </div>
          </button>
        </custom-button>
      {% endif %}
    </div>
  {% elsif pagination == 'infinite_scroll' %}
    <div x-data="xPagination('{{ section.id }}')" id="btn-pagination-{{ section.id }}" class="flex flex-col items-center justify-center">
      <p class="mb-3">{{ 'general.global.showing_items' | t: item: count_item, total: paginate.items }}</p>
      {%- if paginate.next -%}
        <div class="md:inline-block animate-spin w-4 h-4 md:w-5 md:h-5" x-show="loading" x-cloak>
          {% render 'icon-all', icon: 'icon-loading' %}
        </div>
        <div class="h-0.5 w-full opacity-0" x-intersect.once.margin.1000px="loadData('{{ paginate.next.url }}{{ anchor }}')"></div>
      {% endif %}
    </div>
  {% else %}
    <div class="md:max-w-[80%] flex items-center flex-wrap{% if blog_page %} justify-center md:justify-start{% endif %}{% if enable_blog_detail %} md:max-w-full justify-center border-t pt-3.5 md:pt-6 md:mt-1{% endif %} anm-fade-element" x-intersect.once="$el.classList.add('is-visible')">
      <nav class="pagination" role="navigation" aria-label="{{ 'general.pagination.label' | t }}">
        <ul class="flex items-center justify-center md:justify-start flex-wrap font-medium gap-y-0.5 gap-x-1" role="list">
          <li {% if paginate_type == 'underline' %} class="sm:self-end ltr:mr-3 rtl:ml-3 flex"{% endif %}>
            <a 
              {% if paginate.previous %}
                href="{% if paginate.current_page == 2 %}{{ paginate.previous.url | replace: "page=1&", "" | replace: "?page=1", "" | replace: "&page=1", "" }}{% else %}{{ paginate.previous.url }}{{ anchor }}{% endif %}" 
              {% else %}
                role="link"
                aria-disabled="true"
              {% endif %}
              class="{% if paginate_type == 'circle' %}md:p-4 p-3.5 block{% else %} flex block-text-button__wrapper items-center py-2 px-4{% endif %}{% unless paginate.previous %} cursor-not-allowed{% endunless %}{% if rounded_corners %} rounded-md{% endif %}" 
              aria-label="{{ 'general.pagination.previous' | t }}" 
              data-instant-allow-query-string
            >
              {% if paginate_type == 'underline' %}
                <span class="h-2 w-3 inline-block rotate-90 rtl:-rotate-90{% unless paginate.previous %} color-text-[rgba(var(--color-text),0.6)]{% endunless %}">
                  {% render 'icon-all', icon: 'icon-caret' %}
                </span>
                <p class="sm:opacity-0 sm:max-w-0 sm:whitespace-nowrap rtl:sm:mr-0 ltr:sm:ml-0 {% unless paginate.previous %}color-text-[rgba(var(--color-text),0.6)]{% endunless %} rtl:mr-2 ltr:ml-2">{{ 'general.pagination.previous' | t }}</p>
              {% else %}
                <span class="w-4 h-4 block rotate-180 rtl:rotate-0">
                  {% render 'icon-all', icon: 'icon-arrow' %}
                </span>
              {% endif %}
            </a>
          </li>
          {%- for part in paginate.parts -%}
            {% if part.title == 1 %}
              {% assign first_part = part.url | replace: "page=1&", "" | replace: "?page=1", "" | replace: "&page=1", "" %}
            {% endif %}
            {% if paginate_type == 'circle' %}
              <li class="my-1 md:w-14 md:h-14 flex items-center justify-center">
                {%- if part.is_link -%}
                  <a href="{% if part.title == 1 %}{{ first_part }}{% else %}{{ part.url }}{{ anchor }}{% endif %}" class="md:w-14 md:h-14 bg-auto bg-none w-11 h-11 color-bg-[rgba(var(--color-text),0.2)] rounded-full flex items-center justify-center" aria-label="{{ 'general.pagination.page' | t: number: part.title }}" data-instant-allow-query-string>{{ part.title }}</a>
                {%- else -%}
                  <span class="px-4 py-2">{{ part.title }}</span>
                {%- endif -%}
              </li>
            {% else %}
              <li class="flex">
                {%- if part.is_link -%}
                  <a href="{% if part.title == 1 %}{{ first_part }}{% else %}{{ part.url }}{{ anchor }}{% endif %}" class="block-text-button__wrapper py-2 px-4{% if rounded_corners %} rounded-md{% endif %}" aria-label="{{ 'general.pagination.page' | t: number: part.title }}" data-instant-allow-query-string>{{ part.title }}</a>
                {%- else -%}
                  {%- if part.title == paginate.current_page -%}
                    <p aria-disabled="true" class="block-text-button__wrapper py-2 px-4 is-active{% if rounded_corners %} rounded-md{% endif %}" aria-current="page" aria-label="{{ 'general.pagination.page' | t: number: part.title }}">{{ part.title }}</p>
                  {%- else -%}
                    <span class="py-2 px-4">{{ part.title }}</span>
                  {%- endif -%}
                {%- endif -%}
              </li>
            {% endif %}
          {%- endfor -%}
          <li {% if paginate_type == 'underline' %} class="sm:self-end ltr:ml-3 rtl:mr-3 flex"{% endif %}>
            <a 
              {% if paginate.next %}
                href="{{ paginate.next.url }}{{ anchor }}" 
              {% else %}
                role="link"
                aria-disabled="true"
              {% endif %}
              class="block-text-button__wrapper {% if paginate_type == 'circle' %}md:p-4 p-3.5 block{% if is_rtl %} rotate-180{% endif %}{% else %} flex items-center py-2 px-4{% endif %}{% unless paginate.next %} cursor-not-allowed{% endunless %}{% if rounded_corners %} rounded-md{% endif %}"
              aria-label="{{ 'general.pagination.next' | t }}" 
              data-instant-allow-query-string
            >
              {% if paginate_type == 'underline' %}
                <p class="sm:opacity-0 sm:max-w-0 sm:whitespace-nowrap rtl:sm:ml-0 ltr:sm:mr-0 {% unless paginate.next %}color-text-[rgba(var(--color-text),0.6)]{% endunless %}{% if is_rtl %} ml-2{% else %} mr-2{% endif %}">{{ 'general.pagination.next' | t }}</p>
                <span class="h-2 w-3 inline-block -rotate-90 rtl:rotate-90{% unless paginate.next %} color-text-[rgba(var(--color-text),0.6)]{% endunless %}">
                  {% render 'icon-all', icon: 'icon-caret' %}
                </span>
              {% else %}
                <span class="w-4 h-4 block rtl:rotate-180">
                  {% render 'icon-all', icon: 'icon-arrow' %}
                </span>
              {% endif %}
            </a>
          </li>
        </ul>
      </nav>
    </div>
  {% endif %}
{%- endif -%}
