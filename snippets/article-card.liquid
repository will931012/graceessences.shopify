{% comment %}
    Renders an article card for a given blog with settings to either show the image or not.

    Accepts:
    - blog: {Object} Blog object
    - article: {Object} Article object
    - add_divider: {Boolean} The setting either add the divider blog post or not.
    - loading: {Boolean} Image should be lazy loaded. Default: lazy (optional)
    - columns_desktop: {Number} Number blog of columns on desktop,
    - blog_page: {Boolean} Is it in a blog page or not?
    Usage:
    {% render 'article-card', blog: blog, article: article %}
{% endcomment %}
{%- liquid
  if columns_desktop == 1
    assign class_column_1 = " md:pt-12 md:pl-12 md:pl-12 md:pb-12"
  endif
  assign layout_card_mobile = columns_mobile
  unless disable_divider or blog_header
    assign class_divider = "md:border-b"
    assign class_spacing = "md:pb-6"
  endunless
  assign class_expert = "line-clamp-4"
  assign has_image = false
  if show_image and article.image
    assign has_image = true
    assign class_expert = "line-clamp-2"
  endif
  if blog_header
    assign class_expert = "line-clamp-2"
  endif
  assign image_desktop_width = settings.page_width | plus: 100 | divided_by: columns_desktop 
  if blog_page and columns_desktop == 1
    assign image_desktop_width = settings.page_width | plus: 100 | divided_by: 1.5
  endif
  assign show_corner_image = false
  if settings.edges_type == 'rounded_corners'
   assign show_corner_image = true
  endif

  if show_tag and article.tags.size > 0
    assign show_tag = true
  else
    assign show_tag = false
  endif

  if settings.lang_direction contains request.locale.iso_code
    assign is_rtl = true
  else
    assign is_rtl = false
  endif
-%}
{% capture element_attribute %}
  class="article--{{ section.id }}--{{ index }} article-card{{ class_slide }} {{ custom_class }} md:list-layout:flex-row gap-y-3 relative group w-full article-{{ layout_card_mobile -}} 
    {%- if show_show_more_mobile == true and index > 1 %} hidden{% else %} flex{% endif -%}
    {%- if show_show_more_desktop == true and index > columns_desktop %} md:hidden{% else %} md:!flex gap-x-4{% endif -%}
    {%- if swiper_on_mobile %} h-auto{% else %} h-full{% endif -%}
    {%- if enable_desktop_slider %} md:h-auto{% else %} md:h-full{% endif -%}
    {%- if item_secondary_background and has_image %} article-bg-{{ layout_card_mobile }}{% if show_corner_image %} rounded-[10px]{% endif %}{% elsif has_image %} {{ class_divider }}{% endif -%}
    {%- if image_desktop_top %} blog-image-desktop-top md:flex md:flex-col{% else %} blog-image-desktop-left{% if show_border %} border-b{% endif %}{% if index <= columns_desktop and show_border %} border-t{% endif %}{% endif -%}"
  {% if show_show_more_desktop or show_show_more_mobile %}:style="!show_more && { display: 'flex' }"{% endif %}
  {{ custom_attribute }}
{% endcapture %}
{% if show_in_header %}
  <a href="{{ article.url }}" {{ element_attribute }}>
{% else %}
  <div {{ element_attribute }}>
{% endif %}
  {%- if has_image -%}
    {%- if section.index == 1 and section.location == 'template' -%}
      <div class="hidden">
        {{ article.image.src | image_url: width: 1500 | image_tag: widths: '225, 375, 450, 750, 900, 1100, 1500, 1780, 2000', preload: true, loading: 'lazy' }}
      </div>
    {%- endif -%}
    {% if show_in_header %}
      <div class="article-layout-{{ layout_card_mobile }}{% unless image_desktop_top %} max-w-[40%]{% endunless %} shrink-0 block md:list-layout:lg:w-1/4 md:list-layout:w-2/5 md:list-layout:pr-7 rtl:md:list-layout:pr-0 rtl:md:list-layout:pl-7">
    {% else %}
      <a href="{{ article.url }}" class="article-layout-{{ layout_card_mobile }}{% unless image_desktop_top %} max-w-[40%]{% endunless %} shrink-0 block md:list-layout:lg:w-1/4 md:list-layout:w-2/5 md:list-layout:pr-7 rtl:md:list-layout:pr-0 rtl:md:list-layout:pl-7">
    {% endif %}
      <div class="relative overflow-hidden{% if show_corner_image %} z-10 rounded-[10px]{% endif %}{% unless image_ratio == "auto" %} pb-[{{ image_ratio }}%]{% endunless %} media-hyperlink"{% if image_ratio == "auto" %} style="height:0; padding-bottom: {{ 100 | divided_by: article.image.aspect_ratio }}%;"{% endif %}>
        <div class="w-full h-full z-0 overflow-hidden absolute top-0 left-0">
          {% if section.index == 1 and section.location == 'template' %}
            <div class="hidden">
              {{ article.image.src | image_url: width: 3840 | image_tag: widths: '225, 375, 450, 750, 900, 1100, 1500, 1780, 2000, 3000, 3840', preload: true, loading: 'lazy' }}
            </div>
          {% endif %}
          {% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
            <img
              srcset="{{ article.image.src | image_url: width: 225 }} 225w,
              {{ article.image.src | image_url: width: 375 }} 375w,
              {{ article.image.src | image_url: width: 450 }} 450w,
              {{ article.image.src | image_url: width: 750 }} 750w,
              {{ article.image.src | image_url: width: 900 }} 900w,
              {{ article.image.src | image_url: width: 1100 }} 1100w,
              {{ article.image.src | image_url: width: 1500 }} 1500w,
              {{ article.image.src | image_url: width: 1780 }} 1780w,
              {{ article.image.src | image_url: width: 2000 }} 2000w,
              {{ article.image.src | image_url }} {{ article.image.src.width }}w"
              src="{{ article.image.src | image_url: width: 1780 }}"
              alt="{{ article.image.src.alt | default: article.title | escape }}"
              sizes="(min-width: 1025px) {{ image_desktop_width }}px,
              (min-width: 1000px) calc(100vw / {{ columns_desktop }}),
              (min-width: 768px) calc((100vw - 5rem) / 2),
              calc((100vw) / {{ columns_mobile }})"
              class="w-full h-full object-cover object-center image-hover anm-image-hover"
              {% if section.index == 1 and section.location == 'template' %}
                loading="eager"
                fetchpriority="high"
                decoding="sync"
              {% else %}
                loading="lazy"
              {% endif %}  
              width="{{ article.image.width }}"
              height="{{ article.image.height }}"
            >
          {% comment %}theme-check-enable ImgLazyLoading{% endcomment %}
          </div>
      </div>
    {% if show_in_header %}
      </div>
    {% else %}
      </a>
    {% endif %}
  {%- endif -%}
  <div class="grow content-article-{{ layout_card_mobile }} md:list-layout:lg:w-3/4 md:list-layout:w-3/5{% if blog_page %} md:pb-7{% endif %}{% if blog_header or columns_mobile == '2' %} h-full{% endif %}{% if article.image == blank or show_image == false %} h-full md:h-auto md:list-layout:pt-7 content-article-spacing-{{ layout_card_mobile }}{{ class_column_1 }}{% elsif item_secondary_background %} content-article-bg-{{ layout_card_mobile }}{{ class_column }}{% else %} md:list-layout:pt-0{% if is_rtl %} content-article-default-rtl-{{ layout_card_mobile }}{% else %} content-article-default-{{ layout_card_mobile }}{% endif %} {{ class_spacing }}{% endif %}{% if show_corner_image %} rounded-[10px]{% endif %}">        
    <div class="flex justify-between flex-col h-full{% if layout_card_mobile != '2' %} text-{{ content_alignment }}{% endif %} md:text-{{ content_alignment }}{% unless show_tag and article.tags.size > 0 %}{% if show_read_more %} gap-y-4 lg:gap-y-[18px]{% endif %}{% endunless %}">
      <div> 
        {%- if show_name_blog -%}
          <p class="capitalize line-clamp-1">{{ blog.title }}</p>
        {%- endif -%}
        <p class="sub_heading--{{ section.id }} h6{% if blog_header %} text-medium{% endif %} p-break-words{% if show_name_blog %} mt-2{% endif %} {% if show_in_header %} mt-0.5{% else %} mb-1.5{% endif %}" style="--color-text: var(--color-heading);">
          {% if show_in_header %}
            <span class="color-text-[rgba(var(--color-heading))] p-break-words title-link{% if show_in_header %} {{ font_weight_class }} group-hover:link-active hover:color-text-[rgba(var(--color-link))]{% endif %} duration-200 transition">
          {% else %}
            <a href="{{ article.url }}" class="color-text-[rgba(var(--color-heading))] p-break-words title-link{% if show_in_header %} {{ font_weight_class }} group-hover:link-active hover:color-text-[rgba(var(--color-link))]{% endif %} duration-200 transition">
          {% endif %}
            {{ article.title }}
          {% if show_in_header %}
            </span>
          {% else %}
            </a>
          {% endif %}
        </p>
        {% if list_layout %}
          <div class="hidden md:list-layout:block">
            <div class="line-clamp-2 mb-3">
              {{ article.content | strip_html }}
            </div>
          </div>
        {% endif %}
        {% if show_author or show_date or show_comment_counts %}
          <div class="text-small color-text-[rgba(var(--color-heading),0.6)] tracking-wider inline-flex items-center flex-wrap{% if layout_card_mobile != '2' %} justify-{{ content_alignment }}{% endif %} md:justify-{{ content_alignment }}">
            {%- if show_author -%}
              <span class="p-break-words capitalize mr-2 rtl:ml-2 rtl:mr-0">{{ article.author }}.</span>
            {%- endif -%}
            {%- if show_date -%} 
              <span class="p-break-words{% if show_comment_counts and article.comments_count > 0 and blog.comments_enabled? %} mr-2 rtl:mr-0 rtl:ml-2{%- endif -%}">{{ article.published_at | date: '%b %d, %Y' }}</span>
            {%- endif -%}
            {%- if show_comment_counts and article.comments_count > 0 and blog.comments_enabled? -%}
              <div class="flex{% if show_author or show_date %} border-l pl-2 rtl:pl-0 rtl:pr-2 rtl:border-r rtl:border-l-0{% endif %} items-center">
                <span class="inline-block h-full icon-small pb-0.5">{% render 'icon-all', icon: 'icon-comment' %}</span>
                <span class="pl-1 rtl:pl-0 rtl:pr-1">{{ article.comments_count }}</span>
              </div>
            {%- endif -%}
          </div>
          {% endif %}
        {%- if show_excerpt and article.excerpt_or_content.size -%}
          <div>
            <div class="{% if show_in_header %} mt-1 {% else %} mt-3{% endif %} text-small p-break-words {{ class_expert }} font-normal">
              {{ article.excerpt_or_content | replace: '<a', '<a class="effect-inline"' | strip_html }}
            </div> 
          </div>
        {%- endif -%} 
      </div>
      {%- if show_tag or show_read_more -%}
        <div>
          {%- if show_tag -%}
            <ul class="article-tag text-x-small mt-2.5 md:mt-3 -ml-0.5 -mr-0.5{% if show_read_more %} mb-4{% endif %}">
              {%- for tag in article.tags -%}
                <li class="inline-block cursor-pointer ml-0.5 mr-0.5 mb-1">
                  <custom-button>
                    <a class="anm-button-secondary inline-block pl-3 pr-3 pt-1 pb-1 p-break-words color-bg-[rgba(var(--color-heading),0.06)]{% if settings.edges_type == 'rounded_corners' %} rounded{% endif %}" href="{{ blog.url }}/tagged/{{ tag | handle }}">#{{ tag }}</a>
                  </custom-button>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
          {%- if show_read_more -%}
            {% render 'button',
              button_style: 'text-link',
              button_label: button_read_more_label,
              button_link: article.url,
              open_new_window_button: block.settings.open_new_window_button,
              class: 'read-now__button button-link p-break-words inline-flex'
            %}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
{% if show_in_header %}
  </a>
{% else %}
  </div>
{% endif %}