<script>
  {%- if settings.theme_mode_enabled -%}
    const themeMode = '{{ settings.theme_mode_mode | default: 'auto' }}';
    if ((localStorage.maximize_theme == 1 && themeMode == 'switch')
      || (themeMode == 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      requestAnimationFrame(() => {
        document.documentElement.classList.add('dark');
      });
    } else if ((localStorage.maximize_theme == 0 && themeMode == 'switch')
      || (themeMode == 'auto' && window.matchMedia('(prefers-color-scheme: light)').matches)) {
      requestAnimationFrame(() => {
        document.documentElement.classList.remove('dark');
      });
    }
  {%- else -%}
    requestAnimationFrame(() => {
      localStorage.maximize_theme = 0;
      document.documentElement.classList.remove('dark');
    });
  {%- endif -%}
</script>