      endif 
      assign menu_level0_id = block.id | append: '-' | append: block.type | append: '-' | append: start_level | append: '-' | append: forloop.index

      assign show_1st_menu_image = block.settings.show_1st_menu_image
      assign collection_metafield_1st = block.settings.collection_image_metafield
      assign show_second_level_image = block.settings.show_second_level_collection_image
      assign show_2nd_level_menu_image = block.settings.show_2nd_level_menu_image
      assign collection_metafield_2nd = block.settings.collection_image_metafield_3
      assign image_ratio = block.settings.image_ratio
    %}
    <div 
      {% if is_link %}
        @click="{% if start_level > 0 %}$store.xMobileNav.scrollTop(); {% endif %}$store.xMobileNav.setActiveLink('{{ menu_level0_id }}')"
        @keyup.enter="{% if start_level > 0 %}$store.xMobileNav.scrollTop(); {% endif %}$store.xMobileNav.setActiveLink('{{ menu_level0_id }}')"
        tabindex="0"
      {% endif %} 
        class="menu-link flex items-center {% if request.path == block.settings.menu_item_link or is_active %} active{% endif %}"
      >
      {% if is_link %}
        <p class="flex-1 flex items-center cursor-pointer" {% if block.settings.open_new_window %} target="_blank"{% endif %}>
      {% else %}
        <a {% if block.settings.menu_item_link %} href="{{ block.settings.menu_item_link }}" {% else %} role="link" {% endif %} 
          class="flex-1 flex items-center cursor-pointer" 
          {% if block.settings.open_new_window %} target="_blank"{% endif %}
        >
      {% endif %}
        <span class="x-break-words py-2">
          <span>{{ block.settings.heading | escape }}</span>
        </span>
      {% if is_link %}</p>{% else %}</a>{% endif %}
      {%- if is_link -%}
        <span
          class="icon-caret-mobile w-2.5 h-auto block {% if rtl %} rotate-90 {% else %} -rotate-90{% endif %}{%- if link.child_active %} color-text-[rgba(var(--color-link))]{% endif %}"
        >
          {% render 'icon-all', icon: 'icon-caret' %}
        </span>
      {%- endif -%}
    </div>
    {% render 'mobile-drawer-menu', 
      start_level: start_level,
      menu_links: menu_links,
      menu_level0_id: menu_level0_id,
      type: block.id,
      block: block,
      show_1st_menu_image: show_1st_menu_image, 
      collection_metafield_1st: collection_metafield_1st,
      show_second_level_image: show_second_level_image, 
      show_2nd_level_menu_image: show_2nd_level_menu_image, 
      collection_metafield_2nd: collection_metafield_2nd, 
      image_ratio: image_ratio,
      is_block_menu: true
    %}
    {% comment %} {% render "mobile-categories-menu", block: block, start_level: start_level, font_weight_class: font_weight_class, menu_level1_id: menu_level1_id, is_link: is_link %} {% endcomment %}
  {% when 'button' %}
    {% unless block.settings.button_label == blank %}
      {% liquid
        if block.settings.button_style != 'text-link'
          assign class_button = 'px-2.5 py-2'
        endif
      %}
      <div class="button-menu">
        {% render 'button', button_style: block.settings.button_style, button_label: block.settings.button_label, button_link: block.settings.button_link, open_new_window_button: block.settings.open_new_window, class: class_button %}
      </div>
    {% endunless %}
  
{% endcase %}