                        </a>
                      {% endunless %}
                    </div>
                    <div class="mega-sub-container{% if rtl %} pl-0{% else %} pr-0{% endif %} mt-4 relative scrollbar-body scrollbar ltr w-full mx-auto">
                      <div class="anm-reveal-container w-full grid grid-cols-2 gap-2.5">
                        {%- assign grid_items_count = 0 -%}
