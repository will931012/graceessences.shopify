{% comment %}
  Using to render truncate text
  Accepts:
  - number_of_lines_shown: {String} Length of text shown, 
  - currentId: {String} Section id / Block Id,
  - content: {String} content,
  - see_less_label: {String} Label of "See less" button,
  - read_more_label: {String} Label of "Read more" button
  - text_alignment: {String} Text alignment
  - text_alignment_mobile: {String} Text alignment on mobile
  - disable_animation: {Boolean} Disable truncate text animation
  - class_truncate_text: {String} Class truncate text
  - highlight_effect: {String} Highlight effect
  - text_transform: {String} Text transform effect
  Usage:
  {% render 'truncate-text', 
    number_of_lines_shown: number_of_lines_shown,
    currentId: currentId, 
    content: content, 
    see_less_label: see_less_label, 
    read_more_label: read_more_label,
    text_alignment: text_alignment
    text_alignment_mobile: text_alignment_mobile
    disable_animation: disable_animation
    class_truncate_text: class_truncate_text,
    highlight_effect: highlight_effect,
    text_transform: text_transform
  %}
{% endcomment %}
{% liquid
  if settings.lang_direction contains request.locale.iso_code
    assign is_rtl = true
  else
    assign is_rtl = false
  endif

  assign max_height_mobile = "50px"
  assign max_height_desktop = "70px"
  if number_of_lines_shown == "large"
    assign max_height_mobile = "130px"
    assign max_height_desktop = "150px"
  elsif number_of_lines_shown == "medium"
    assign max_height_mobile = "90px"
    assign max_height_desktop = "100px"
  endif
%}

{% comment %} Handle highlight text in content {% endcomment %}
{% if highlight_effect != blank %}
  {% if text_transform != 'none' %}
    {% style %} 
      .highlight-text-transform-{{ currentId }} {
        {% if text_transform == 'italic' %}
          font-style: italic;
        {% elsif text_transform == 'uppercase' %}
          text-transform: uppercase;
        {% else %}
          text-transform: uppercase;
          font-style: italic;
        {% endif %}
      }
    {% endstyle %}
  {% endif %}

  {% capture icon_highlight %}
    {% if highlight_effect == "underline" %}
      <svg class="svg-highlight-{{ currentId }} text-svg-underline absolute left-[6%] top-auto bottom-0 w-4/5 h-[15%] rtl:rotate-180"    
        xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 12" fill="none" preserveAspectRatio="none"
      >
        <path d="M447.927 2.35583C338.059 -1.20265 110.867 1.8394 6.15217 2.51143C3.52318 2.5283 1.37007 4.83214 1.46495 7.41709C1.54483 9.59366 3.27775 11.2031 5.494 11.159L447.927 2.35583Z" fill="currentColor" stroke="currentColor"/>
      </svg>
    {% endif %}
  {% endcapture %}

  {% liquid 
    assign heading_highlight = '<span class="inline-block" x-data="{ isIntersecting: false, delay: DURATION.REVEAL_TRANSITION }">'
    case highlight_effect
      when 'underline'
        assign heading_highlight = heading_highlight | append:'<span class="highlight-text-transform-' | append: currentId | append: ' relative heading-highlight-underline" x-intersect.once="setTimeout(() => isIntersecting = true, delay)" :class="isIntersecting && `heading-highlight-anm-underline`">'
      when 'marker'
        assign heading_highlight = heading_highlight | append:'<span class="highlight-text-transform-' | append: currentId | append: ' heading-highlight-marker" x-intersect.once="setTimeout(() => isIntersecting = true, delay)" :class="isIntersecting && `heading-highlight-anm-marker`">'
      when 'text-color-change'
        assign heading_highlight = heading_highlight | append:'<span class="highlight-text-transform-' | append: currentId | append: ' heading-highlight-color-change" x-intersect.once="setTimeout(() => isIntersecting = true, delay)" :class="isIntersecting && `heading-highlight-anm-color-change`">'
      when 'shadow'
        assign heading_highlight = heading_highlight | append:'<span class="highlight-text-transform-' | append: currentId | append: ' heading-highlight-shadow" x-intersect.once="setTimeout(() => isIntersecting = true, delay)" :class="isIntersecting && `heading-highlight-anm-shadow`">'
    endcase

    assign icon_highlight = icon_highlight | append: "</span></span>"
  %}
  
  {% liquid
    if content contains '[' and content contains ']'
      if content contains '<a' and content contains '</a>'
        assign parts = content | split: '<a'
        for part in parts
          assign new_part = part
          if part contains '</a>' and part contains '">'
            assign a_tag_attributes = part | split: '">' | first
            if a_tag_attributes contains '[' and content contains ']'
              assign a_tag_attributes_new = a_tag_attributes | replace: '[', 'replace-to-&#91;' | replace: ']', 'replace-to-&#93;'
              assign new_part = part | replace: a_tag_attributes, a_tag_attributes_new
            endif
          endif

          if new_part != part
            assign content = content | replace: part, new_part
          endif
        endfor
      endif

      assign content = content | replace: '[', heading_highlight | replace: ']', icon_highlight
      if content contains 'replace-to-&#91;' and content contains 'replace-to-&#93;'
        assign content = content | replace: 'replace-to-&#91;', '[' | replace: 'replace-to-&#93;', ']'
      endif
    endif
  %}
{% endif %}

{% comment %} Handle read more / see less feature {% endcomment %}
{%- if number_of_lines_shown == 'small' or number_of_lines_shown == 'medium' or number_of_lines_shown == 'large' -%}
  {%- style -%}
    .line-clamp-{{ currentId }} {
      max-height: {{ max_height_mobile }};
    }
    @media (min-width: 768px) {
      .line-clamp-{{ currentId }} {
        max-height: {{ max_height_desktop }};
      }
    }
  {%- endstyle -%}
  <div class="truncate-container ltr{% unless disable_animation %} anm-fade-element{% endunless -%}" 
    {%- unless disable_animation %}x-intersect.once=" $el.classList.add('is-visible')" {% endunless -%} 
    x-data="xTruncateText"
  >
    <div class="truncate-text relative {{ class_truncate_text }} line-clamp-{{ currentId }} overflow-hidden"
      x-intersect.once="$nextTick(() => { setTruncate($el); load($el) });"
    >
      <div class="text-truncate truncate-inner relative rte{% if is_rtl %} rtl{% endif %}">
        {{ content | replace: '<iframe ', '<iframe loading="lazy" ' }}
      </div>
      <div class="gradient block" :class="expanded ? 'hidden' : 'block'"></div>
    </div>
    <template x-if="truncatable" x-show="truncatable">
      <div 
        class="flex 
        {%- if text_alignment != blank and text_alignment_mobile != blank %} justify-{{ text_alignment_mobile }} md:justify-{{ text_alignment -}}
        {%- elsif text_alignment != blank and text_alignment_mobile == blank %} justify-{{ text_alignment -}}
        {%- elsif text_alignment_mobile != blank %} justify-{{ text_alignment_mobile }} md:justify-start rtl:md:justify-end
        {%- else %} justify-start rtl:justify-end
        {%- endif -%}
      "
      >
        <div class="text-link relative inline mt-4 mb-2"
          x-init="label = '{{ read_more_label | escape }}'"
          x-transition 
          @click.prevent="truncated ? open($el, '{{ see_less_label | escape }}') : close($el, '{{ read_more_label | escape }}', '{{ quick_view }}');"
          @keydown.enter.prevent="truncated ? open($el, '{{ see_less_label | escape }}') : close($el, '{{ read_more_label | escape }}', '{{ quick_view }}');"
          @keyup.space.prevent="truncated ? open($el, '{{ see_less_label | escape }}') : close($el, '{{ read_more_label | escape }}', '{{ quick_view }}');"
          :class="truncated || 'text-link-expand'"
          x-text="label"
          tabindex="0"
          role="button"
          :aria-expanded="truncated ? 'true' : 'false'"
          style="font-family: inherit;"></div>
      </div>
    </template>
  </div>
{% else %}
  <div class="truncate-text {% unless disable_animation %} anm-fade-element{% endunless %} {{ class_truncate_text }}"
    {% unless disable_animation %} x-intersect.once="$el.classList.add('is-visible')"{% endunless %}
  >
    <div class="rte">
      {{ content | replace: '<iframe ', '<iframe loading="lazy" ' }}
    </div>
  </div>
{% endif %}