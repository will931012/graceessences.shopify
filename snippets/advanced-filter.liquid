{% comment %}
  Renders an article card for a given blog with settings to either show the image or not.

  Accepts:
  - filter_index: {Number} Number of filter to showed.
  - hide_unavaiable_filter: {Boolean} Hide unvaiable filter.
  - sorted_values: {Array} List value of filter.
  - columns_desktop: {Number} Number of column filter.
  - filter_index: {Number} Index of filter in all filters.
  - filter_type: {String} Type of filter (Above, Aside, Drawer)
  - image_ratio: {String} Image ratio of filter image.
  Usage:
  {% render 'advanced-filter', blog: blog, article: article %}
{% endcomment %}
{% liquid
  assign swiper_on_tablet = true
  assign swiper_on_mobile = true
  assign filter_count = 0
  assign show_filter_image = false
  assign max_desktop_filter = 6
  assign number_tablet_filter = 3
  assign number_mobile_filter = 2

  for value in sorted_values
    if value.display.type == 'image'
      assign show_filter_image = true
      break
    endif
  endfor

  if hide_unavaiable_filter
    for value in sorted_values
      if value.count != 0
        assign filter_count = filter_count | plus: 1
      endif
    endfor
  else
    assign filter_count = sorted_values.size
  endif

  assign is_set_desktop_columns = true
  assign columns_desktop = columns_desktop | plus: 0
  if columns_desktop <= 0
    assign columns_desktop = max_desktop_filter
    assign is_set_desktop_columns = false
  elsif columns_desktop > max_desktop_filter
    assign columns_desktop = max_desktop_filter
  endif

  if columns_desktop > filter_count
    assign columns_desktop = filter_count
  endif
%}
<div
  class="js-filter filter-advanced-{% if type == "Mobile" %}mobile{% else %}desktop{% endif %} pl-0 pr-0 {% if section.settings.enable_desktop_slider %} lg:pl-12 lg:pr-12{% endif %} {% unless filter_index == 1 %} mt-1 md:mt-3{% endunless %} mb-3 maximize mx-auto page-width{% if show_filter_image %} contain-image{% endif %}"
  data-index="{{ filter_type }}-{{ filter_index }}"
>
  {% liquid
    if filter_count <= columns_desktop
      assign enable_desktop_slider = false
    endif
    if filter_count <= number_tablet_filter
      assign swiper_on_tablet = false
    endif
    if filter_count <= number_mobile_filter
      assign swiper_on_mobile = false
    endif
  %}
  {%- style -%}
    {% if type == "Mobile" %}
      @media (max-width: 767px) {
        #AdvancedFilter-{{ type }}-{{ section.id }}-{{ filter_index }} .slider-container .slide-item {
          {% if is_set_desktop_columns %}
            width: var(--swiffy-slider-item-width);
          {% else %}
            width: clamp(16%, var(--swiffy-slider-item-width), 100%);
          {% endif %}
        }
        #AdvancedFilter-{{ type }}-{{ section.id }}-{{ filter_index }} .slider-container {
          flex-wrap: nowrap;
          {% if swiper_on_mobile %}
            --swiffy-slider-item-count: {{ number_mobile_filter }};
          {% else %}
            --swiffy-slider-item-count: {{ filter_count }};
          {% endif %}
          --swiffy-slider-item-gap: 6px;
        }
        {% if filter_count <=1 %}
          /* #AdvancedFilter-{{ type }}-{{ section.id }}-{{ filter_index }} .list-item-wrapper {
            max-width: calc(50% - (var(--swiffy-slider-item-gap, 6px) / 2))
          } */
        {% endif %}
      }
    {% endif %}
    {% if type == "Desktop" %}
      @media (min-width: 768px) and (max-width: 1023px) {
        #AdvancedFilter-{{ type }}-{{ section.id }}-{{ filter_index }} .slider-container .slide-item {
          {% if is_set_desktop_columns %}
            width: var(--swiffy-slider-item-width);
          {% else %}
            width: clamp(16%, var(--swiffy-slider-item-width), 100%);
          {% endif %}
        }
        #AdvancedFilter-{{ type }}-{{ section.id }}-{{ filter_index }} .slider-container {
          flex-wrap: nowrap;
          {% if swiper_on_tablet %}
            --swiffy-slider-item-count: {{ number_tablet_filter }};
          {% else %}
            --swiffy-slider-item-count: {{ filter_count }};
          {% endif %}
          --swiffy-slider-item-gap: 8px;
        }
        #AdvancedFilter-{{ type }}-{{ section.id }}-{{ filter_index }} .list-item-wrapper {
          max-width: calc(33.5% * {{ filter_count }})
        }
      }
      @media (min-width: 1024px){
        #AdvancedFilter-{{ type }}-{{ section.id }}-{{ filter_index }} .slider-container .slide-item {
          {% if is_set_desktop_columns %}
            width: var(--swiffy-slider-item-width);
          {% else %}
            width: clamp(16%, var(--swiffy-slider-item-width), 100%);
          {% endif %}
        }
        #AdvancedFilter-{{ type }}-{{ section.id }}-{{ filter_index }} .slider-container {
          {% if section.settings.enable_desktop_slider %}
            flex-wrap: nowrap;
          {% else %}
            flex-wrap: wrap;
          {% endif %}
          --swiffy-slider-item-gap: 8px;
          --swiffy-slider-item-count: {{ columns_desktop }};
        }
        #AdvancedFilter-{{ type }}-{{ section.id }}-{{ filter_index }} .list-item-wrapper {
          max-width: calc(33.5% * {{ columns_desktop }})
        }
      }
    {% endif %}
  {%- endstyle -%}
  <div
    id="AdvancedFilter-{{ type }}-{{ section.id }}-{{ filter_index }}"
    class="filter-advanced-{{ filter_index }} {% if show_filter_image %} contain-image{% endif %}{% if filter_count > 0 %} block webkit-text-left rtl:webkit-text-right rtl:md:webkit-text-center md:webkit-text-center{% else %} hidden{% endif %}"
  >
    <div
      {% if enable_desktop_slider or swiper_on_mobile or swiper_on_tablet %}
        class="swiffy-slider slider-item-snapstart text-left list-item-wrapper"
        x-intersect.once="
          $store.xSwiffy.load($el, {
            'mediaQuery': 'min',
            'isLoop': false,
            'isResize': true,
            'adaptWidth': true,
            'breakPoints':{
              '0': {
                'slidesPerView': {% if swiper_on_mobile %}{{ number_mobile_filter }}{% else %}{{ filter_count }}{% endif %}
              },
              '768': {
                'slidesPerView': {% if swiper_on_tablet %}{{ number_tablet_filter }}{% else %}{{ filter_count }}{% endif %}
              },
              '1024': {
                'slidesPerView': {{ columns_desktop }}
              }
            }
          });
        "
      {% else %}
        class="list-item-wrapper"
      {% endif %}
    >
      {% if section.settings.enable_desktop_slider and type != "Mobile" %}
        <button
          class="slider-nav is-visible slider-nav__button-arrow nav-disabled advanced-nav top-1/2 translate-y-1/2 md:translate-y-0 {% unless enable_desktop_slider %} lg:!hidden{% endunless %}"
          aria-label="{{ 'accessibility.prev_button' | t }}"
          x-cloak
        >
          {% render 'icon-all', icon: 'icon-nav-arrow' %}
        </button>
        <button
          class="slider-nav slider-nav-next is-visible slider-nav__button-arrow advanced-nav top-1/2 translate-y-1/2 md:translate-y-0 {% unless enable_desktop_slider %} lg:!hidden{% endunless %}"
          aria-label="{{ 'accessibility.next_button' | t }}"
          x-cloak
        >
          {% render 'icon-all', icon: 'icon-nav-arrow' %}
        </button>
      {% endif %}
      <div 
        class="slider-container scrollbar-hidden flex lg:px-0.5 lg:mx-1 lg:scroll-px-0.5
          {%- unless show_filter_image %} items-center{% endunless -%}
          {%- unless enable_desktop_slider %} lg:justify-center{% endunless -%}"
        data-mobile-gap="6px"
        data-desktop-gap="8px"    
      >
        {% if show_filter_image %}
          {% for value in sorted_values %}
            {% if hide_unavaiable_filter == false or hide_unavaiable_filter and value.count != 0 %}
              <div 
                id="Slide-{{ section.id }}-{{ forloop.index }}"
                class="group slide-item shrink-0 relative text-center"
              >
                <label
                  for="Filter-{{ filter_type }}-{{ type }}-{{ filter.label | escape | handle }}-{{ forloop.index }}"
                  class="advanced-filter__label anm-hover-button relative {% if value.count == 0 %} opacity-60 cursor-not-allowed{% else %} cursor-pointer {% if type == "Desktop" %} hover:color-text-[rgba(var(--color-heading))]{% endif %} {% endif %} rounded-corners text-small border color-border-[rgba(var(--color-text),0.2)] advanced-filter-image flex w-full h-full {% if value.display.type == 'image' %} pt-1.5 pb-1.5 md:pt-2 md:pb-2 pl-1.5 pr-1.5 {% if is_rtl %} md:pl-4 md:pr-2{% else %} md:pl-2 md:pr-4{% endif %}{% else %} px-4 py-4 {% endif %}"
                  tabindex="0"
                  @keyup.enter="$el.click()"
                >
                  <input 
                    type="checkbox"
                    id="Filter-{{ filter_type }}-{{ type }}-{{ filter.label | escape | handle }}-{{ forloop.index }}"
                    class="input-image-filter z-10 checkbox cursor-pointer {% if filter.operator == 'AND' %} filter-and{% endif %} absolute opacity-0 {% if settings.edges_type == 'rounded_corners' %} rounded{% else %} rounded-none{% endif %} disabled:pointer-events-none"
                    name="{{ value.param_name }}"
                    value="{{ value.value }}"
                    tabindex="-1"
                    {% if type == "Desktop" %}
                      :form="isDesktop && 'FacetFiltersForm'"
                    {% endif %}
                    {% if value.active %}
                      checked
                    {% endif %}
                    {% if value.count == 0 and value.active == false %}
                      disabled
                    {% elsif type == "Mobile" %}
                      :disabled="isDesktop"
                    {% endif %}
                    @change="onSubmit()"
                    @keydown.enter.prevent="$el.click()"
                  >
                  <div class="image-filter w-full md:w-full h-full flex justify-center items-center rounded-corners">
                    <div 
                      class="image-filter-{{ section.id }}-{{ filter_index }} inline-flex gap-2 md:gap-3 w-full items-center md:w-full"
                    >
                      <div
                        class="
                          w-[60px] h-[60px] md:w-[68px] md:h-[68px] relative shrink-0 inline-block overflow-hidden color-filter transition duration-200 empty:hidden
                          {% if image_ratio == 'round' %} rounded-full{% else %} rounded-corners{% endif %}
                        "
                      >
                        {%- if value.display.type == 'image' -%}
                          {% assign img_alt = value.display.value.alt | default: value.display.value %}
                          {{ value.display.value | image_url: width: 300 | image_tag: alt: img_alt, class: 'w-full h-full object-cover top-0 left-0 absolute' }}
                        {%- endif -%}
                      </div>
                      <span 
                        class="filter-label p-break-words inline-block w-full line-clamp-3
                          {%- if type == "Mobile" %} h5{% endif -%}
                          {%- if show_filter_image %} text-left rtl:text-right{% endif -%}
                        "
                        >
                          {{ value.label | escape }} ({{ value.count }})
                        </span>
                    </div>
                  </div>
                </label>
              </div>
            {% endif %}
          {% endfor %}
        {% else %}
          {% for value in sorted_values %}
            {% if hide_unavaiable_filter == false or hide_unavaiable_filter and value.count != 0 %}
              <div
                id="Slide-{{ section.id }}-{{ forloop.index }}"
                class="advanced-filter-text group slide-item shrink-0 w-full h-full relative text-center"
              >
                <label
                  for="Filter-{{ filter_type }}-{{ type }}-{{ filter.label | escape | handle }}-{{ forloop.index }}"
                  class="advanced-filter__label-text advanced-filter__label anm-hover-button rounded-corners relative text-small {% if value.count == 0 %} opacity-60 cursor-not-allowed{% else %} cursor-pointer {% if type == "Desktop" %} hover:color-text-[rgba(var(--color-heading))]{% endif %}{% endif %} w-full border color-border-[rgba(var(--color-text),0.2)] h-full inline-flex justify-center items-center px-4 py-4 fitler-not-image"
                  tabindex="0"
                  @keyup.enter="$el.click()"
                >
                  <input
                    type="checkbox"
                    id="Filter-{{ filter_type }}-{{ type }}-{{ filter.label | escape | handle }}-{{ forloop.index }}"
                    class="input-filter-checkbox hidden"
                    name="{{ value.param_name }}"
                    value="{{ value.value }}"
                    {% if type == "Desktop" %}
                      :form="window.innerWidth >= 768 && 'FacetFiltersForm'"
                    {% endif %}
                    {% if value.active %}
                      checked
                    {% endif %}
                    {% if value.count == 0 and value.active == false %}
                      disabled
                    {% elsif type == "Mobile" %}
                      :disabled="isDesktop"
                    {% endif %}
                    @change="onSubmit()"
                    @keydown.enter.prevent="$el.click()"
                  >
                  <span class="filter-label p-break-words inline-block line-clamp-3{% if type == "Mobile" %} h5{% endif %}">
                    {{ value.label | escape }} ({{ value.count }})
                  </span>
                </label>
              </div>
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>
      {% render 'progress-bar',
        show_on_mobile: swiper_on_mobile,
        show_on_tablet: swiper_on_tablet,
        container_class: "mt-2",
        is_hidden_arrow: true
      %}
    </div>
  </div>
</div>
