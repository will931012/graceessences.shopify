<div
  class="product-card__quantity-wrapper {% unless is_enabled %}opacity-40 pointer-events-none cursor-not-allowed{% endunless %} {{ content_center_class }}"
>
  <div
    class="flex flex-col gap-1.5 h-full"
    x-data="xQuantitySelectorAtc({{ product.id }}, {{ index_param | default: 1 }})"
    x-intersect.once.margin.200px="init()"
  >
    <div class="w-full h-full {% if block_choose_option %}lg:w-full{% else %}lg:w-[106px] lg:h-[44px]{% endif %} flex">
      <div
        class="flex color-text-[rgba(var(--color-heading),0.8)] w-fit items-center border color-border-[rgba(var(--color-text),0.2)]
          {%- if settings.edges_type == 'rounded_corners' %} rounded-md{% endif -%}
           {% if block_choose_option %} w-full flex justify-between {% endif %}"
      >
        <div
          class="flex justify-center items-center cursor-pointer bg-transparent select-none px-3 py-[15px]"
          :class="qty <= 1 ? 'cursor-not-allowed opacity-50 pointer-events-none' : 'cursor-pointer'"
          name="minus"
          @click.prevent="minus(1)"
          @keyup.enter="minus(1)"
          tabindex="0"
          role="button"
          aria-label="{{ "accessibility.minus" | t }}"
        >
          <span class="w-3 h-3 flex color-text-[rgba(var(--color-text))]">{% render 'icon-all', icon: 'icon-minus' %}</span>
        </div>
        <input
          class="outer-spin-button color-text-[rgba(var(--color-text))] focus:outline-none text-medium text-center bg-transparent rounded-corners py-2.5 md:py-2.5 w-8 quick-view:w-7"
          type="number"
          name="quantity"
          id="Quantity-{{ block_id }}"
          min="1"
          form="{{ product_form_id }}"
          x-model="qty"
          x-on:blur="invalid($el)"
          x-ref="quantity_input"
          aria-label="{{ "products.product.quantity.label" | t }}"
         {% unless is_enabled %}disabled{% endunless %}
        >
        <div
          class="flex justify-center items-center cursor-pointer bg-transparent select-none px-3 py-[15px]"    
          name="plus"
          @click.prevent="plus(1)"
          @keyup.enter="plus(1)"
          tabindex="0"
          role="button"
          aria-label="{{ "accessibility.plus" | t }}"
        >
          <span class="flex h-3 w-3 color-text-[rgba(var(--color-text))]">{% render 'icon-all', icon: 'icon-plus' %}</span>
        </div>
      </div>
    </div>
  </div>
</div>