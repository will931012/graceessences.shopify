{% liquid 
if settings.lang_direction contains request.locale.iso_code
  assign is_rtl = true
else
  assign is_rtl = false
endif
%}
<div 
  x-show="$store.xReOrder.show"
  x-cloak 
  class="reorder-popup popup-container">
  <div
    id="ReorderPopup__Container"
    x-show="$store.xReOrder.show" 
    class="popup-content{% unless settings.show_popup_overlay %} shadow-large{% endunless %} flex flex-col transform-gpu md:min-h-[unset] w-full page-width md:w-3/4 lg:w-3/5 max-w-[650px] pr-0 pl-0 pb-5 lg:pb-10 relative md:pl-0 md:pr-0 lg:ml-auto lg:mr-auto color-bg-gradient-[var(--gradient-background)]{% if settings.edges_type == 'rounded_corners' %} rounded-[10px]{% endif %}"
    x-intersect.full="$store.xFocusElement.trapFocus('ReorderPopup__Container', 'CloseReorderPopup__{{ block.id }}')"
    @keyup.escape="$store.xFocusElement.removeTrapFocus(); $store.xReOrder.closeReorderPopup()"
    x-transition:enter-start="opacity-0 translate-y-1/3"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 translate-y-1/3"
    @click.away="$store.xReOrder.closeReorderPopup()"
  >
    <div class="modal-title-container modal-title-padding-x">
      <div class="modal-title-wrapper">
        <div class="grow flex items-center">
          <p class="h6 text-medium">{{ 'customer.orders.order_number' | t }} <span x-text="$store.xReOrder.orderName"></span></p>
        </div>

        <button 
          @click="$store.xFocusElement.removeTrapFocus(); $store.xReOrder.closeReorderPopup()" 
          class="modal-title__button-close" 
          aria-label="button-close"
          id="CloseReorderPopup__{{ block.id }}"
        >
          <span class="button__close icon-close-large-desktop icon-close-large-mobile">
            {% render 'icon-all', icon: 'icon-close' %}
          </span>
        </button>
      </div>
    </div>
    
    <div class="px-4 md:pl-7.5 md:pr-7.5 relative overflow-y-auto overflow-x-hidden scrollbar-body max-h-[calc(85vh-96px)] md:max-h-[60vh]">
      <template x-for="(item,index) in Object.values(Alpine.store('xReOrder').itemsCart)" :key="index">
        <div class="flex relative pt-5 pb-5 border-b"
          :class="index == 0 && 'border-t'" 
          x-data="{ 
            item: JSON.parse(JSON.stringify(item))
          }">
          <div class="w-24 md:w-32 relative">
            <a x-bind:href="item.url" class="block w-full">
              <div class="relative w-full overflow-hidden float-left before:h-0 before:block before:pb-[100.0%]">
                <img
                  x-show="item.image"
                  class="absolute top-0 right-0 left-0 bottom-0 object-cover h-full w-full image-hover" 
                  :src="`${ item.image }`"
                  :alt="`${ item.image_alt }`"
                  loading="lazy" 
                  width="150"
                  height="auto"
                >
                <div class="absolute top-0 left-0 w-full h-full" x-show="!item.image">
                  {% liquid
                    assign index = 1
                    assign index = 'now' | date: '%M' | times: index | modulo: 5 | plus: 1
                    assign placeholder_product_name = 'product_' | append: index
                  %}
                  {% render 'placeholder-image', image_type: placeholder_product_name %}
                </div>
              </div>
            </a>
          </div>
          <div class="px-5 flex-1{% if is_rtl %} lg:pl-0{% else %} lg:pr-0{% endif %}">
            <div>
              <a x-bind:href="item.url" class="color-text-[rgba(var(--color-heading))] mr-0 duration-200 transition title-link p-break-words" x-text="Alpine.store('xReOrder').decodeHtmlEntities(item.title)">
              </a>
              <p class="mt-2" x-show="item.disable">{{ 'products.product.unavailable' | t }}</p>
            </div>
            <div id="LineItemError" class="hidden color-bg-[rgba(var(--error-background-color),0.2)] cart-item__error mt-2 pt-3 pb-3 pr-3.5 pl-3.5 mb-3{% if settings.edges_type == 'rounded_corners' %} rounded-md{% endif %}" role="alert">
              <p class="flex relative w-full">
                <span class="absolute left-0 rtl:left-auto rtl:right-0 top-1/2 -translate-y-1/2 w-3">{% render 'icon-all', icon: 'icon-error' %}</span>
                <span class="cart-item__error-text text-small pl-5 rtl:pl-0 rtl:pr-5"></span>
              </p>
            </div>
            <div class="cart-item__quantity mt-3"
              x-show="!item.disable"
              x-data="{
                qty: 1,
                minus(value) {
                  this.qty = parseInt(this.qty);
                  (this.qty == 0) ? this.qty = 0 : this.qty -= value;
                  Alpine.store('xReOrder').setItemsCart({...item, quantity: this.qty});
                },
                plus(value) {
                  this.qty = parseInt(this.qty);
                  this.qty += value;
                  Alpine.store('xReOrder').setItemsCart({...item, quantity: this.qty});
                },
                updateItemQty() {
                  Alpine.store('xReOrder').setItemsCart({...item, quantity: this.qty});
                },
                invalid(el) {
                  number = parseFloat(el.value);
                  if (!Number.isInteger(number) || number < 0) {
                    this.qty = 0;
                  } 
                }
              }"
              x-intersect="$nextTick(() => {
                qty = item.quantity;
              })"
            >
              <div class="flex items-center">
                <div class="relative flex w-28 h-10 border border-solid justify-between{% if settings.edges_type == 'rounded_corners' %} rounded-md{% endif %}">
                  <button
                    class="items-center w-1/3 justify-center flex no-js-hidden opacity-70 cursor-pointer"
                    name="minus" @click="minus(1)" aria-label="{{ 'accessibility.minus' | t }}"
                  >
                    {% render 'icon-all', icon: 'icon-minus', class: "w-3" %}
                  </button>
                  <input
                    :id="[`cart-qty-${ item.id }`]"
                    class="outer-spin-button w-1/3 bg-transparent text-center pt-2 pb-2 placeholder:opacity-60 focus-within:outline-none"
                    type="number"
                    name="quantity"
                    value="1"
                    x-model="qty"
                    x-on:change="updateItemQty()"
                    x-on:blur="invalid($el)"
                    min="0"
                  />
                  <button
                    class="items-center w-1/3 justify-center flex opacity-70 cursor-pointer"
                    name="plus" @click="plus(1)" aria-label="{{ 'accessibility.plus' | t }}"
                  >
                    {% render 'icon-all', icon: 'icon-plus', class: "w-3" %}
                  </button>
                </div>
              </div> 
            </div>
          </div>
        </div>
      </template>
      <div class="inline-flex gap-2 relative w-full mt-2 py-3 px-3.5 color-bg-[rgba(var(--error-background-color),0.2)]{% if settings.edges_type == 'rounded_corners' %} rounded-md{% endif %}" x-show="$store.xReOrder.errorMessage">
        <span class="w-3 min-w-[12px]">{% render 'icon-all', icon: 'icon-error' %}</span>
        <span class="cart-warning text-small"></span>
      </div>
    </div>
    <div class="px-4 md:pl-7.5 md:pr-7.5">
      <div class="inline-flex gap-2 relative w-full mt-2 py-1.5 pl-2.5 pr-5 message-success" x-show="$store.xReOrder.clearSuccess">
        <span class="min-w-[12px] w-3">{% render 'icon-all', icon: 'icon-check' %}</span>
        <span class="text-x-small">{{ 'sections.re-order.message_success' | t }}</span>
      </div>
    </div>
    <div class="px-4 md:pl-7.5 md:pr-7.5 mt-5{% if is_rtl %} text-left{% else %} text-right{% endif %}">
      <button 
        class="relative"
        :class="$store.xReOrder.disableReorder && 'opacity-50 cursor-not-allowed'"
        @click="!$store.xReOrder.disableReorder && $store.xReOrder.clearCart()"
      >
        <span class="text-link" :class="$store.xReOrder.loadingClearCart && 'opacity-0'">{{ 'sections.re-order.clear_cart' | t }}</span>
        <div class="lg:inline-block animate-spin w-4 h-4 md:w-5 md:h-5 absolute top-[calc(50%-8px)] left-[calc(50%-8px)] md:top-[calc(50%-10px)] md:left-[calc(50%-10px)]" x-show="$store.xReOrder.loadingClearCart" x-cloak>
          {% render 'icon-all', icon: 'icon-loading' %}
        </div>
      </button>
      <custom-button>
        <button 
          type="submit" 
          class="button button-primary py-2.5 px-5 lg:px-7 md:py-3 leading-normal{% if is_rtl %} mr-3{% else %} ml-3{% endif %}" 
          :class="$store.xReOrder.disableReorder && 'opacity-50 cursor-not-allowed'"
          @click.prevent="!$store.xReOrder.disableReorder && $store.xReOrder.handleAddToCart($el)"
        >
          <span :class="{ 'lg:block opacity-0 is-focus-button' : $store.xReOrder.loading }">
            {% assign button_label = 'products.product.add_all_to_cart' | t %}
            {% render 'button-label', button_label: button_label, show_button_style: 'primary' %}
          </span>
          <div class="lg:inline-block animate-spin w-4 h-4 md:w-5 md:h-5 absolute top-[calc(50%-8px)] left-[calc(50%-8px)] md:top-[calc(50%-10px)] md:left-[calc(50%-10px)]" x-show="$store.xReOrder.loading" x-cloak>
            {% render 'icon-all', icon: 'icon-loading' %}
          </div>
        </button>
      </custom-button>
    </div>
  </div>
</div>