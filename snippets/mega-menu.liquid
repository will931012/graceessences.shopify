{% liquid
  assign menu_font_weight = settings.menu_font.weight | plus: 0
  assign font_weight_class = ' font-weight-menu'
  if menu_font_weight < 600
    assign font_weight_class = ' !font-semibold'
  endif
%}
{% unless block.type == 'button' %}
  <div class="relative">
    {% case block.type %}
      {% when 'tree_menu' %}
        {% liquid
          if block.settings.menu.links != blank
            assign show_menu_content = true
          endif
          assign is_active = false
          for link_child in block.settings.menu.links
            if link_child.current or link_child.child_active
              assign is_active = true
            endif
          endfor
        %}
      {%- when 'column_menu' -%}
        {% liquid
          assign links = block.settings.menu.links
          assign position_promotion = block.settings.position_promotion

          assign image_count = 0
          if block.settings.image_1 != blank or block.settings.mobile_image_1 != blank
            assign image_count = image_count | plus: 1
          endif
          if block.settings.image_2 != blank or block.settings.mobile_image_2 != blank
            assign image_count = image_count | plus: 1
          endif

          assign grid_col = 5
          assign col_minus = 0
          assign promotion_wrapper_width = 'full'
          assign columns_desktop = 4
          if image_count > 0
            if position_promotion != 'bottom'
              if block.settings.layout_promotion == 'vertical'
                assign col_minus = col_minus | plus: 1
                assign promotion_wrapper_width = 25
              else
                assign col_minus = col_minus | plus: image_count
                assign promotion_wrapper_width = 25 | times: image_count
              endif
              assign columns_desktop = columns_desktop | plus: 1
            else
              assign columns_desktop = image_count
            endif
          endif
          assign grid_col = grid_col | minus: col_minus
          assign show_menu_content = false
          if block.settings.menu.links != blank or image_count > 0
            assign show_menu_content = true
          endif
          assign is_active = false
          for link_child in block.settings.menu.links
            if link_child.current or link_child.child_active
              assign is_active = true
            endif
          endfor
        %}
      {%- when 'product_menu' -%}
        {% liquid
          assign is_active = false
          for link_child in block.settings.menu.links
            if link_child.current or link_child.child_active
              assign is_active = true
            endif
          endfor

          assign show_menu_content = false
          if block.settings.menu.links != blank
            assign show_menu_content = true
          endif
        %}
      {%- when 'banner_menu' -%}
        {%- liquid
          assign columns_desktop = 0
          if block.settings.image_4 != blank
            assign columns_desktop = columns_desktop | plus: 1
          endif
          if block.settings.image_3 != blank
            assign columns_desktop = columns_desktop | plus: 1
          endif
          if block.settings.image_2 != blank
            assign columns_desktop = columns_desktop | plus: 1
          endif
          if block.settings.image_1 != blank
            assign columns_desktop = columns_desktop | plus: 1
          endif

          assign show_menu_content = false
          if columns_desktop > 0
            assign show_menu_content = true
          endif
        -%}
      {%- when 'blog_menu' -%}
        {%- liquid
          assign blog = false
          if block.settings.blog and block.settings.blog.articles_count > 0
            assign blog = block.settings.blog
          endif

          assign show_menu_content = false
          if blog
            assign show_menu_content = true
          endif
        -%}
      {%- when 'contact_menu' -%}
        <script
          src="{{ 'map.js' | asset_url }}"
          defer
        ></script>
        {%- liquid
          assign form_index = 1
          assign info_index = 2
          assign link = false
          if block.settings.menu_item_link != blank
            assign link = block.settings.menu_item_link
          endif
          if block.settings.show_contact_information
            assign class_information = 'w-1/3'
            assign class_map = 'w-1/3'
            assign class_form = 'w-1/3'
          else
            assign class_map = 'w-1/2'
            assign class_form = 'w-1/2'
          endif
          if block.settings.sort_order == 'options__2'
            assign class_information = class_information | append: ' order-2'
            assign class_map = class_map | append: ' order-3'
            assign class_form = class_form | append: ' order-1'
          endif
          if block.settings.sort_order == 'options__3'
            assign class_information = class_information | append: ' order-2'
            assign class_map = class_map | append: ' order-1'
            assign class_form = class_form | append: ' order-3'
            assign form_index = 2
            assign info_index = 1
          endif
          if block.settings.sort_order == 'options__4'
            assign class_information = class_information | append: ' order-1'
            assign class_map = class_map | append: ' order-3'
            assign class_form = class_form | append: ' order-2'
            assign form_index = 2
            assign info_index = 1
          endif

          assign show_menu_content = true
        -%}
      {%- when 'tabbed_menu' -%}
        {% liquid
          assign show_1st_menu_image = block.settings.show_1st_menu_image
          assign show_second_level_image = block.settings.show_second_level_collection_image
          assign show_2nd_level_menu_image = block.settings.show_2nd_level_menu_image
          assign collection_metafield = block.settings.collection_image_metafield
          assign image_ratio = block.settings.image_ratio
          assign block_menu = block.settings.menu
          if block_menu.links != blank or image_count > 0
            assign show_menu_content = true
          endif

          assign image_count = 0
          if block.settings.image_1 != blank or block.settings.mobile_image_1 != blank
            assign image_count = image_count | plus: 1
          endif
          if block.settings.image_2 != blank or block.settings.mobile_image_2 != blank
            assign image_count = image_count | plus: 1
          endif
          assign is_active = false
          for link_child in block.settings.menu.links
            if link_child.current or link_child.child_active
              assign is_active = true
            endif
          endfor
        %}
    {% endcase %}

    <a
      {% if block.settings.menu_item_link %}
        href="{{ block.settings.menu_item_link }}"
      {% else %}
        role="link"
      {% endif %}
      aria-label="{{ block.settings.heading | escape }}"
      class="link whitespace-nowrap is-focus:color-text-[rgba(var(--color-highlight))] item-spacing pl-[15px] pr-[15px] cursor-pointer x-break-words{% if show_menu_content %} menu-parent-link flex items-center{% else %} inline-block{% endif %} relative{% if is_active or request.path == block.settings.menu_item_link %} active{% endif %}"
      {% if show_menu_content %}
        x-init="$store.xHeaderMenu.isTouch && $store.xHeaderMenu.touchItem($el, 'menu')"
      {% endif %}
      {% if desktop_motion == 'click' and show_menu_content %}
        @click="
          () => {
            {% unless block.type == "tree_menu" %} firstLoad(); {% endunless %}
            $store.xHeaderMenu.selectItem($el.closest('li'), 'menu', false, $event);
          }
        "
      {% endif %}
      {% if block.settings.open_new_window %}
        target="_blank"
      {% endif %}
    >
      {% if is_highlight %}
        {% render 'highlight-menu-item', highlight_effect: section.settings.highlight_effect, menu_title: block.settings.heading, section_id: section.id %}
      {% else %}
        <span>{{ block.settings.heading | escape }}</span>
      {% endif %}
      {% if show_menu_content %}
        <span
          class="inline-block w-5 h-5 ps-2"
          tabindex="0"
          @keyup.enter="{% unless block.type == "tree_menu" %} firstLoad(); {% endunless %} $store.xHeaderMenu.handleKeyupElement($el.closest('li'));"
        >
          {%- render 'icon-all', icon: 'icon-caret' -%}
        </span>
      {% endif %}
    </a>

    {%- if block.settings.label != blank -%}
      {%- style -%}
        .color-label-{{ block.id }} {
          background: {{ block.settings.label_color }};
          color: {{ block.settings.label_text_color_light }}
        }
        .color-label-{{ block.id }}:before{
          border-top-color: {{ block.settings.label_color }};
        }
        .dark .color-label-{{ block.id }} {
          background: {{ block.settings.label_color_dark }};
          color: {{ block.settings.label_text_color_dark }}
        }
        .dark .color-label-{{ block.id }}:before {
          border-top-color: {{ block.settings.label_color_dark }};
        }
        .icon-label-{{ block.id }} {
          width: calc(var(--h7-font-size) * var(--line-height-heading));
          min-width: calc(var(--h7-font-size) * var(--line-height-heading));
          height: calc(var(--h7-font-size) * var(--line-height-heading));
        }
      {%- endstyle -%}
      <div class="color-label-{{ block.id }} gap-1 header-label__wrapper h7 z-10 max-w-full flex items-center absolute right-0 bottom-[100%] rounded-corners rounded-corners-sm shadow-showdownInset px-1.5 py-0.5 before:absolute before:w-0 before:h-0 before:border-b-8 before:border-b-transparent before:border-r-transparent before:border-r-8 before:border-t-8 before:-bottom-3 before:left-2">
        {% unless block.settings.icon == 'none' or block.settings.custom_icon_image == blank and block.settings.icon == 'another' and block.settings.another_icon == blank %}
          <span class="relative icon-label-{{ block.id }} shrink-0">
            {% if block.settings.custom_icon_image != blank %}
              <img
                src="{{ block.settings.custom_icon_image | image_url: width: 30 }}"
                alt="{{ block.settings.custom_icon_image.alt | default: block.settings.label | escape }}"
                loading="lazy"
                width="{{ block.settings.custom_icon_image.width }}"
                height="{{ block.settings.custom_icon_image.height }}"
                style="object-position: {{ block.settings.custom_icon_image.presentation.focal_point }}"
                class="object-cover absolute top-0 left-0 w-full h-full {% if settings.edges_type == 'rounded_corners' %} rounded-sm{% endif %}"
              >
            {% else %}
              {% if block.settings.icon == 'another' %}
                {% render 'icon-another', icon: block.settings.another_icon %}
              {% else %}
                {% render 'icon-labels-bags', icon: block.settings.icon %}
              {% endif %}
            {% endif %}
          </span>
        {%- endunless -%}
        <span class="x-break-words">{{ block.settings.label }}</span>
      </div>
    {%- endif -%}
  </div>
{% endunless %}

{% case block.type %}
  {% when 'tree_menu' %}
    {% assign link = block.settings.menu %}
    {% render 'tree-menu', link: link, is_link: show_menu_content, desktop_motion: desktop_motion %}
  {% when 'column_menu' %}
    {% if show_menu_content %}
      <div
        class="column-mega-menu mega-menu_list w-full transition-all mega-menu-height duration-header-menu delay-header-menu ease-in-out left-0 top-full z-20 background-header toggle-menu child absolute shadow-showdownInset"
        inert
      >
        <template x-if="isLoaded">
          <div class="h-full column-mega-menu-container py-8 {% if rtl %} pr-8{% else %} pl-8{% endif %} flex mega-menu-height overflow-y-auto scrollbar-body scrollbar-visible flex-col">
            <div
              class="column-menu__link-list h-full flex gap-5 {% if rtl %} pl-8{% else %} pr-8{% endif %} {% if position_promotion == 'left' %}flex-row-reverse{%  elsif position_promotion == "bottom" %}flex-col{% endif %}"
            >
              {%- if links != blank -%}
                {% liquid
                  if links.size < grid_col
                    assign grid_col = links.size
                  endif
                  if grid_col < 2
                    assign grid_col = 2
                  endif
                %}
                <ul class="mega-nav gap-5 w-full h-full grid grid-cols-{{ grid_col }}">
                  {%- for childlink in links -%}
                    <li
                      class="mega-menu__item relative h-full w-full"
                      style="--menu-delay-animation: {{ forloop.index | times: 100 }}ms"
                    >
                      <div class="flex gap-2.5 flex-col">
                        <div class="w-full h-full rounded-corners overflow-hidden">
                          {%- render 'menu-item-image', link: childlink, auto_fill_menu_image_with: block.settings.show_1st_menu_image, collection_metafield: block.settings.collection_image_metafield, image_ratio: block.settings.image_ratio, show_menu_content: true -%}
                        </div>
                        <a
                          href="{{ childlink.url }}"
                          class="h6 hover:color-text-[rgba(var(--color-link))] relative transition duration-200 x-break-words inline-block {% if childlink.current or childlink.child_active %}active{% endif %}"
                        >
                          <span class="{{ font_weight_class }}">
                            {{ childlink.title | escape }}
                          </span>
                        </a>
                      </div>
                      {%- if childlink.links != blank -%}
                        {% assign time_wait = forloop.index | times: 100 %}
                        <ul
                          class="list-unstyled mt-2.5 last-level-menu"
                          role="list"
                        >
                          {%- for grandchildlink in childlink.links -%}
                            <li
                              class="mega-menu__item flex items-center relative mt-1.5 font-normal"
                              style="--menu-delay-animation: {{ forloop.index | times: 50 | plus: time_wait  }}ms"
                            >
                              {% comment %} {%- render 'menu-item-image', link: grandchildlink, show_image_collection: block.settings.show_sub_image_collection, show_first_image_product: block.settings.show_sub_image_collection, class_ratio: class_image_ratio, image_left: true -%} {% endcomment %}
                              <span class="flex-1">
                                <a
                                  href="{{ grandchildlink.url }}"
                                  class="link relative transition duration-200 x-break-words inline-block {% if grandchildlink.current or request.path == grandchildlink %} active{% endif %}"
                                >
                                  {{ grandchildlink.title | escape }}
                                </a>
                              </span>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}

              {% if image_count > 0 %}
                <div class="column-menu__image-wrapper gap-5 shrink-0 h-full grid {% if block.settings.layout_promotion == "vertical" %}grid-cols-1{% else %}grid-cols-{{ image_count }} {% endif %} {% if promotion_wrapper_width == "full" %}w-full{% else %}w-[{{ promotion_wrapper_width }}%]{% endif %}">
                  {% if block.settings.image_1 != blank or block.settings.mobile_image_1 != blank %}
                    <div class="mega-menu-promotion promotion-1 w-full group h-fit">
                      {% render 'menu-promotion-block',
                        blockID: block.id,
                        desktop_image: block.settings.image_1,
                        mobile_image: block.settings.mobile_image_1,
                        image_link: block.settings.image_link_1,
                        heading: block.settings.heading_1,
                        content: block.settings.text_1,
                        block: block,
                        image_overlay_opacity: block.settings.overlay_opacity_1,
                        columns_desktop: columns_desktop,
                        text_alignment: block.settings.text_alignment_1,
                        title_size: block.settings.text_size_1,
                        text_size: block.settings.text_size_1,
                        color_scheme_light: block.settings.color_scheme_light_1,
                        color_scheme_dark: block.settings.color_scheme_dark_1,
                        enable_text_overlay: block.settings.text_overlay_1,
                        mobile_image_height: block.settings.mobile_image_height,
                        desktop_image_height: block.settings.image_height,
                        index: 1,
                        button_label: block.settings.button_label_1,
                        button_link: block.settings.button_link_1,
                        open_new_window: block.settings.open_new_window_button_1,
                        button_style: block.settings.button_style_1
                      %}
                    </div>
                  {% endif %}
                  {% if block.settings.image_2 != blank or block.settings.mobile_image_2 != blank %}
                    <div class="mega-menu-promotion  promotion-2 w-full group h-fit">
                      {% render 'menu-promotion-block',
                        blockID: block.id,
                        desktop_image: block.settings.image_2,
                        mobile_image: block.settings.mobile_image_2,
                        image_link: block.settings.image_link_2,
                        heading: block.settings.heading_2,
                        content: block.settings.text_2,
                        block: block,
                        image_overlay_opacity: block.settings.overlay_opacity_2,
                        columns_desktop: columns_desktop,
                        text_alignment: block.settings.text_alignment_2,
                        title_size: block.settings.text_size_2,
                        text_size: block.settings.text_size_2,
                        color_scheme_light: block.settings.color_scheme_light_2,
                        color_scheme_dark: block.settings.color_scheme_dark_2,
                        enable_text_overlay: block.settings.text_overlay_2,
                        mobile_image_height: block.settings.mobile_image_height,
                        desktop_image_height: block.settings.image_height,
                        index: 2,
                        button_label: block.settings.button_label_2,
                        button_link: block.settings.button_link_2,
                        open_new_window: block.settings.open_new_window_button_2,
                        button_style: block.settings.button_style_2
                      %}
                    </div>
                  {% endif %}
                </div>
              {% endif %}
            </div>
            {% unless block.settings.view_all_link == blank %}
              <div class="w-full mt-2.5 {% if rtl %} pl-8{% else %} pr-8{% endif %}">
                <div class="flex justify-center border-t rounded-corners">
                  <a
                    class="pt-4 link-hover relative w-fit color-text-[rgba(var(--color-text))] flex items-center gap-1"
                    href="{{ block.settings.view_all_link }}"
                    {% if block.settings.open_link_in_new_window %}
                      target="_blank"
                    {% endif %}
                  >
                    {{ block.settings.view_all_title | default: 'View more' }}
                    <span class="block w-2 h-2{% if rtl %} rotate-180{% endif %}">{% render 'icon-all', icon: 'icon-double-arrow' %}</span>
                  </a>
                </div>
              </div>
            {% endunless %}
          </div>
        </template>
      </div>
    {% endif %}
  {% when 'product_menu' %}
    {%- if block.settings.heading != blank and block.settings.menu.links != blank -%}
      <div
        class="product-mega-menu toggle-menu transition-all mega-menu-height duration-header-menu delay-header-menu z-10 background-header h-screen absolute mega-menu-height left-0 top-full right-0 opacity-0 overflow-hidden shadow-showdownInset"
        style="height: 0px;"
        inert
      >
        <template x-if="isLoaded">
          <div class="product-menu-list hidden w-full py-8 h-full">
            <div
              class="mega-nav {% if rtl %} pl-5 pr-8{% else %} pl-8 pr-5{% endif %} h-full"
              x-init="$store.xHeaderMenu.setHeightProductMenu($el)"
            >
              <ul class="mega-list-nav product-list-item max-h-full items-end flex-wrap overflow-y-auto scrollbar-body scrollbar-visible">
                {%- for link in block.settings.menu.links -%}
                  {%- liquid
                    assign count = 0
                    for childlink in link.links
                      if childlink.type == 'product_link'
                        assign count = count | plus: 1
                      endif
                    endfor
                    assign enable_slider = false
                    if count > 4
                      assign enable_slider = true
                    endif
                  -%}
                  <li
                    class="menu-item table color-text-[rgba(var(--color-heading))]"
                    {% if desktop_motion == 'hover' %}
                      x-on:mouseover="$store.xHeaderMenu.selectItem($el, 'menu', true); $el.classList.add('is-focus-child')"
                      @mouseleave="$el.classList.remove('is-focus-child');"
                      @focusin="$store.xHeaderMenu.selectItem($el, 'menu', true); $el.classList.add('is-focus-child');"
                      @focusout="$el.classList.remove('is-focus-child');"
                    {% else %}
                      x-on:mouseover="$el.classList.add('is-focus-child');"
                      @mouseleave="$el.classList.remove('is-focus-child');"
                      @focusin="$el.classList.add('is-focus-child');"
                      @focusout="$el.classList.remove('is-focus-child');"
                    {% endif %}
                    {%- if link.current or link.child_active %}
                      x-init="active = true;"
                    {% endif %}
                  >
                    <div class="sub-menu flex items-end z-10 relative w-[300px]">
                      <span class="flex-1">
                        <a
                          href="{{ link.url }}"
                          class="p-break-words relative z-10 border-b {% if settings.edges_type == 'rounded_corners' %} rounded-b-md{% endif %} flex items-center justify-between py-3.5 hover:color-text-[rgba(var(--color-highlight))] px-2.5 is-focus-child:effect-inline{%- if link.current or link.child_active %} flex active{% endif %}"
                          {% if count > 0 %}
                            x-init="$store.xHeaderMenu.isTouch && $store.xHeaderMenu.touchItem($el, 'menu', true)"
                          {% endif %}
                          {% if desktop_motion == 'click' and count > 0 %}
                            @click="$store.xHeaderMenu.selectItem($el.closest('li'), 'menu', true, $event);"
                          {% endif %}
                        >
                          <span class="p-break-words">{{ link.title | escape }}</span>
                          {%- if count > 0 and link.links != blank -%}
                            <span class="z-10 w-5 h-4 p-1 rounded-full block shrink-0 {% if rtl %} left-0 rotate-90{% else %} right-0 -rotate-90{% endif %}">
                              {% render 'icon-all', icon: 'icon-caret' %}
                            </span>
                          {%- endif -%}
                        </a>
                      </span>
                    </div>
                    {%- if count > 0 -%}
                      <div
                        class="toggle-menu-sub pb-8 product-mega-menu_wrapper overflow-hidden delay-header-menu {% if rtl %} ml-8{% else %} mr-8{% endif %} z-0 absolute background-header inset-0 hidden{% if forloop.first %} is-open{% endif %}"
                        x-intersect.once="document.dispatchEvent(new CustomEvent('maximize:animation:reveal'))"
                      >
                        <div class="mega-sub-container product-mega-menu__list-product anm-reveal-container max-h-full {% if rtl %} pl-0{% else %} pr-0{% endif %} relative overflow-auto h-max scrollbar-body scrollbar-visible ltr {% if rtl %} pr-[332px]{% else %} pl-[332px]{% endif %} w-full">
                          <div class="mega-sub-nav scrollbar-body scrollbar-visible pt-8 {% if rtl %} pr-5{% unless enable_slider %} rtl{% endunless %}{% else %} pl-5{% endif %}">
                            <div
                              class="order-2 w-full swiffy-slider slider-item-snapstart slider-nav-animation-fadein enable-effect-hover slider-nav-animation"
                              {% if true %}
                                x-intersect.once="
                                  $store.xSwiffy.load($el, {
                                    'mediaQuery': 'min',
                                    'breakPoints':{
                                      '768': {
                                        'slidesPerView': 4,
                                        'gap': '10px'
                                      }
                                    }
                                  });
                                "
                              {% endif %}
                            >
                              {% if count > 4 %}
                                {% render 'slider-navigation-button' %}
                              {% endif %}
                              <div class="slider-container slider-item-show4 {% if rtl %} rtl{% endif %}">
                                {%- assign grid_items_count = 0 -%}
                                {%- assign menu_child_index = block.id | append: forloop.index -%}
                                {%- for childlink in link.links -%}
                                  {% if childlink.type == 'product_link' %}
                                    {%- assign grid_items_count = grid_items_count | plus: 1 -%}
                                    {%- liquid
                                      assign card_product = childlink.object
                                      assign product_card_id = menu_child_index | append: forloop.index | append: '-desktop'
                                    -%}
                                    <div class="slide-item w-full h-full">
                                      {% render 'product-card',
                                        product: card_product,
                                        section_id: section.id,
                                        show_vendor: false,
                                        show_rating: false,
                                        class_slide: 'h-auto',
                                        index: forloop.index,
                                        columns_desktop: 5,
                                        column_mobile: 1,
                                        enable_desktop_slider: true,
                                        block_id: blockID,
                                        append_id: product_card_id,
                                        disable_color_swatch: true,
                                        index_param: forloop.index,
                                        disable_button: true,
                                        disable_estimate_delivery: true,
                                        disable_inventory_status: true,
                                        disable_highlight_attributes: true,
                                        disable_pickup_message: true
                                      %}
                                    </div>
                                  {% endif %}
                                {%- endfor -%}
                                <script
                                  src="{{ 'product-form.js' | asset_url }}"
                                  defer="defer"
                                ></script>
                                <script
                                  src="{{ 'product-card.js' | asset_url }}"
                                  defer
                                ></script>
                              </div>
                            </div>
                          </div>
                          {% if block.settings.view_all_link != blank %}
                            <div class="product-view-all-link hidden md:block pt-5 {% if rtl %} pr-5{% else %} pl-5{% endif %}">
                              <div class="border-t w-full pt-4 hidden md:flex justify-center rounded-corners px-5">
                                <a
                                  href="{{ block.settings.view_all_link }}"
                                  class="product-menu-view-all link-hover relative w-fit h7 color-text-[rgba(var(--color-text))] flex items-center gap-1{% if rtl %} rtl{% endif %}"
                                  {% if block.settings.open_new_window %}
                                    target="_blank"
                                  {% endif %}
                                >
                                  {{ block.settings.view_all_title | default: 'View more' }}
                                  <span class="block w-2 h-2{% if rtl %} rotate-180{% endif %}">{% render 'icon-all', icon: 'icon-double-arrow' %}</span>
                                </a>
                              </div>
                            </div>
                          {% endif %}
                        </div>
                      </div>
