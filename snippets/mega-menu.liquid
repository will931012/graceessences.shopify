  {% when 'tabbed_menu' %}
    {% if show_menu_content %}
      <div
        class="tabbed-mega-menu__container left-0 opacity-0 toggle-menu absolute z-30 background-header w-full top-full align-start shadow-showdownInset transition-all delay-header-menu duration-header-menu ease-in-out"
        inert
      >
        <template x-if="isLoaded">
          {% liquid
            assign grid_col = 4
            assign col_minus = 0
            assign promotion_wrapper_width = 'full'
            if show_2nd_level_menu_image != 'none'
              if show_second_level_image == 'next'
                assign col_minus = col_minus | plus: 1
              endif
            endif
            assign columns_desktop = 3
            if image_count > 0
              if block.settings.position_promotion != 'bottom'
                if block.settings.layout_promotion == 'vertical'
                  assign col_minus = col_minus | plus: 1
                  assign promotion_wrapper_width = 25
                else
                  assign col_minus = col_minus | plus: image_count
                  assign promotion_wrapper_width = 25 | times: image_count
                endif
                assign columns_desktop = columns_desktop | plus: image_count
              else
                if block.settings.layout_promotion == 'vertical'
                  assign columns_desktop = 2
                else
                  assign columns_desktop = image_count | plus: 1
                endif
              endif
            endif
            assign grid_col = grid_col | minus: col_minus
          %}
          <div
            class="tabbed-mega-menu__list md:p-8 {% if rtl %} md:pl-0 {% else %} md:pr-0{% endif %} w-full mega-menu-height overflow-y-auto scrollbar-body scrollbar-visible flex gap-7.5"
            x-data="
              {
                activeIndex: 1,
                activeIndexes: [1],
                touchItem(el, currentIndex) {
                  el.addEventListener('touchend', (e) => {
                    if (this.activeIndex === currentIndex) {
                      window.location.replace(el.getAttribute('href'));
                    } else {
                      e.preventDefault();
                      this.activeIndex = currentIndex
                    }
                  });
                },
              }
            "
            x-init="
              $watch('activeIndex', (value) => {
                if (value !== null && !activeIndexes.includes(value)) {
                  activeIndexes.push(value);
                }
              })
            "
          >
            <div class="menu-tab flex flex-col justify-start w-[340px]">
              <div class="w-full {% if rtl %} pr-2.5{% else %} pl-2.5{% endif %}">
                <div class="w-full flex items-center justify-between gap-2.5 px-2.5 pb-4 {% if settings.edges_type == 'rounded_corners' %} rounded-b-md{% endif %} border-b-2 color-border-[rgba(var(--color-border-header))]">
                  <p class="h5">{{ block.settings.heading }}</p>
                  {% unless block.settings.view_all_link == blank %}
                    <a
                      href="{{ block.settings.view_all_link }}"
                      {% if block.settings.open_link_in_new_window %}
                        target="_blank"
                      {% endif %}
                      class="view-all-linl link-hover shrink-0 max-w-[40%]"
                    >
                      <span class="h7 color-text-[rgba(var(--color-text-header))]">{{ block.settings.view_all_title | default: 'View more' }}</span> <span class="w-2 h-2 inline-block ml-1.5 rtl:ml-0 rtl:mr-1.5 mt-0.5 rtl:rotate-180">{% render 'icon-all', icon: 'icon-double-arrow' %}</span>
                    </a>
                  {% endunless %}
                </div>
              </div>
              <ul class="tabbed-mega-menu-list -scale-x-100 overflow-y-auto scrollbar-body scrollbar {% if rtl %} pl-2{% else %} pr-2{% endif %}">
                {% for link in block_menu.links %}
                  {% liquid
                    assign has_child_link = false
                    if link.links != blank
                      assign has_child_link = true
                    endif
                  %}
                  <li
                    class="menu-item w-full {% if settings.edges_type == 'rounded_corners' %} rounded-b-md{% endif %} border-b -scale-x-100"
                    {% if desktop_motion == 'hover' %}
                      @mouseover="activeIndex = {{ forloop.index }}; $el.classList.add('is-focus-child');"
                      @mouseleave="$el.classList.remove('is-focus-child');"
                      @focusin="$el.classList.add('is-focus-child');"
                      @focusout="$el.classList.remove('is-focus-child');"
                    {% else %}
                      @mouseover="$el.classList.add('is-focus-child');"
                      @mouseleave="$el.classList.remove('is-focus-child');"
                      @focusin="$el.classList.add('is-focus-child');"
                      @focusout="$el.classList.remove('is-focus-child');"
                    {% endif %}
                  >
                    <div
                      class="sub-menu px-2.5 py-3.5 flex items-center rounded-corners gap-2.5 cursor-pointer"
                      {% if desktop_motion == 'click' and link.links != blank %}
                        @click="
                          () => {
                            if (activeIndex === {{ forloop.index }}) {
                              return;
                            };
                            $event.preventDefault();
                            activeIndex = {{ forloop.index }};
                          }
                        "
                      {% endif %}
                    >
                      {%- render 'menu-item-image', link: link, auto_fill_menu_image_with: show_1st_menu_image, collection_metafield: collection_metafield, image_ratio: 0, custom_class: '!w-10 h-10 rounded-corners-md', show_menu_content: true, minimal_image: true -%}
                      <span class="flex-1">
                        <a
                          href="{{ link.url }}"
                          class="link relative x-break-words w-full color-text-[rgba(var(--color-heading))] flex items-center justify-between gap-2.5 {% if link.current or link.child_active %}active{% endif %} {% if has_child_link %} flex items-center{% else %} inline-block{% endif %}"
                          {% if has_child_link %}
                            x-init="$store.xHeaderMenu.isTouch && touchItem($el, {{ forloop.index }})"
                          {% endif %}
                        >
                          <span>{{ link.title | escape }}</span>
                          {%- if link.links != blank -%}
                            <span
                              class="icon-child z-10 w-5 h-5 p-1 rounded-full block align-end -rotate-90 rtl:rotate-90 shrink-0"
                              tabindex="0"
                              @keyup.enter="activeIndex = {{ forloop.index }}; "
                            >
                              {%- render 'icon-all', icon: 'icon-caret' -%}
                            </span>
                          {%- endif -%}
                        </a>
                      </span>
                    </div>
                  </li>
                {% endfor %}
              </ul>
            </div>
            <div class="tabbed-menu_content flex-1 flex w-full gap-5 {% if rtl %} pl-8{% else %} pr-8{% endif %} overflow-y-auto scrollbar-body overflow-x-hidden scrollbar-visible {% if block.settings.position_promotion == 'left' %}md:flex-row-reverse{%  elsif block.settings.position_promotion == "bottom" %}md:flex-col{% endif %}">
              <div class="tabbed-menu_menu-list h-max w-full relative">
                {% for link in block_menu.links %}
                  {% liquid
                    assign has_child_link = false
                    if link.links != blank
                      assign has_child_link = true
                    endif
                  %}
                  {% if has_child_link %}
                    <div
                      class="tabbed-mega-menu mega-menu_list h-full rounded-r-[10px] child top-0 bottom-0 left-0 w-full right-0"
                      :class="[activeIndex === {{ forloop.index }} ? 'is-open relative' : 'invisible absolute', activeIndexes.includes({{ forloop.index }}) ? 'block' : 'hidden']"
                    >
                      {% liquid
                        assign child_grid_col = grid_col
                        if link.links.size < grid_col
                          assign child_grid_col = link.links.size
                        endif
                        if child_grid_col < 2
                          assign child_grid_col = 2
                        endif
                      %}
                      <ul class="grid w-full h-max md:gap-5 grid-cols-{{ child_grid_col }}">
                        {% for childlink in link.links %}
                          {%- liquid
                            assign has_child_link = false
                            if childlink.links != blank
                              assign has_child_link = true
                            endif
                          -%}
                          <li
                            class="mega-menu__item flex w-full h-full gap-2.5 {% if show_second_level_image == 'above' %}flex-col{% endif %}"
                            style="--menu-delay-animation: {{ forloop.index | times: 100 }}ms"
                          >
                            {% capture image_item %}
                              {% render 'menu-item-image', link: childlink, auto_fill_menu_image_with: show_2nd_level_menu_image, collection_metafield: collection_metafield, image_ratio: image_ratio, custom_class: 'rounded-corners', show_menu_content: true %}
                            {% endcapture %}
                            {% assign image_item = image_item | strip %}
                            {% unless image_item contains 'Liquid syntax error' %}
                              {% if image_item != blank and show_second_level_image != 'none' %}
                                <div class="w-full h-fit empty:hidden">
                                  {{ image_item }}
                                </div>
                              {% endif %}
                            {% endunless %}
                            <div class="w-full h-full">
                              <div class="h6">
                                <a
                                  href="{{ childlink.url }}"
                                  class="flex items-center p-break-words hover:color-text-[rgba(var(--color-highlight))] {{ font_weight_class }} {% if childlink.current or childlink.child_active %} active{% endif %}"
                                >
                                  {{ childlink.title }}
                                </a>
                              </div>
                              {% if childlink.links != blank %}
                                <ul class="last-level-menu mt-2.5 font-normal">
                                  {% assign time_wait = forloop.index | times: 100 %}
                                  {% for grandchildlink in childlink.links %}
                                    <li
                                      class="mega-menu__item font-normal mt-1.5"
                                      style="--menu-delay-animation: {{ forloop.index | times: 50 | plus: time_wait  }}ms"
                                    >
                                      <a
                                        class="link p-break-words {% if grandchildlink.current or request.path == grandchildlink %} active{% endif %}"
                                        href="{{ grandchildlink.url }}"
                                      >
                                        {{- grandchildlink.title -}}
                                      </a>
                                    </li>
                                  {% endfor %}
                                </ul>
                              {% endif %}
                            </div>
                          </li>
                        {% endfor %}
                      </ul>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
              {% if image_count > 0 %}
                <div class="tabbed-menu_media grid {% if block.settings.layout_promotion == "vertical" %}grid-cols-1{% else %}grid-cols-{{ image_count }}{% endif %} gap-5 {% if promotion_wrapper_width == "full" %}w-full{% else %}w-[{{ promotion_wrapper_width }}%]{% endif %}">
                  {% if block.settings.image_1 != blank or block.settings.mobile_image_1 != blank %}
                    <div class="mega-menu-promotion promotion-1 w-full group h-fit">
                      {% render 'menu-promotion-block',
                        blockID: block.id,
                        desktop_image: block.settings.image_1,
                        mobile_image: block.settings.mobile_image_1,
                        image_link: block.settings.image_link_1,
                        heading: block.settings.heading_1,
                        content: block.settings.text_1,
                        block: block,
                        image_overlay_opacity: block.settings.overlay_opacity_1,
                        columns_desktop: columns_desktop,
                        text_alignment: block.settings.text_alignment_1,
                        title_size: block.settings.text_size_1,
                        text_size: block.settings.text_size_1,
                        color_scheme_light: block.settings.color_scheme_light_1,
                        color_scheme_dark: block.settings.color_scheme_dark_1,
                        enable_text_overlay: block.settings.text_overlay_1,
                        mobile_image_height: block.settings.mobile_image_height,
                        desktop_image_height: block.settings.image_height,
                        index: 1,
                        button_label: block.settings.button_label_1,
                        button_link: block.settings.button_link_1,
                        open_new_window: block.settings.open_new_window_button_1,
                        button_style: block.settings.button_style_1
                      %}
                    </div>
                  {% endif %}
                  {% if block.settings.image_2 != blank or block.settings.mobile_image_2 != blank %}
                    <div class="mega-menu-promotion promotion-2 w-full group h-fit">
                      {% render 'menu-promotion-block',
                        blockID: block.id,
                        desktop_image: block.settings.image_2,
                        mobile_image: block.settings.mobile_image_2,
                        image_link: block.settings.image_link_2,
                        heading: block.settings.heading_2,
                        content: block.settings.text_2,
                        block: block,
                        image_overlay_opacity: block.settings.overlay_opacity_2,
                        columns_desktop: columns_desktop,
                        text_alignment: block.settings.text_alignment_2,
                        title_size: block.settings.text_size_2,
                        text_size: block.settings.text_size_2,
                        color_scheme_light: block.settings.color_scheme_light_2,
                        color_scheme_dark: block.settings.color_scheme_dark_2,
                        enable_text_overlay: block.settings.text_overlay_2,
                        mobile_image_height: block.settings.mobile_image_height,
                        desktop_image_height: block.settings.image_height,
                        index: 2,
                        button_label: block.settings.button_label_2,
                        button_link: block.settings.button_link_2,
                        open_new_window: block.settings.open_new_window_button_2,
                        button_style: block.settings.button_style_2
                      %}
                    </div>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          </div>
        </template>
      </div>
    {% endif %}
  {% when 'button' %}
    {% unless block.settings.button_label == blank %}
      {% liquid
        if block.settings.button_style != 'text-link'
          assign class_button = 'px-2.5 py-2'
        endif
      %}
      <div class="button-menu leading-[0] {% if forloop.last %} {% if rtl %} pr-[15px] {% else %} pl-[15px] {% endif %}{% else %} pl-[15px] pr-[15px]{% endif %}">
        {% render 'button', button_style: block.settings.button_style, button_label: block.settings.button_label, button_link: block.settings.button_link, open_new_window_button: block.settings.open_new_window, class: class_button %}
      </div>
    {% endunless %}
{% endcase %}
