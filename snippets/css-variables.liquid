        --color-text: {{ settings.highlight_att_text_light.red }} {{ settings.highlight_att_text_light.green }} {{ settings.highlight_att_text_light.blue }} / {{ settings.highlight_att_text_light.alpha }};
        --color-text-no-alpha: {{ settings.highlight_att_text_light.red }} {{ settings.highlight_att_text_light.green }} {{ settings.highlight_att_text_light.blue }};
        color: rgba(var(--color-text));
      }
    {% endif %}
    {% if settings.highlight_att_text_dark.alpha != blank and settings.highlight_att_text_dark.alpha != 0.0 %}
      .dark .product-card__highlight-attributes__rotate {
        --color-text: {{ settings.highlight_att_text_dark.red }} {{ settings.highlight_att_text_dark.green }} {{ settings.highlight_att_text_dark.blue }} / {{ settings.highlight_att_text_dark.alpha }};
        --color-text-no-alpha: {{ settings.highlight_att_text_dark.red }} {{ settings.highlight_att_text_dark.green }} {{ settings.highlight_att_text_dark.blue }};
        color: rgba(var(--color-text));
      }
    {% endif %}
  {% endif %}

  {% if settings.img_hover_anm == 'zoom_out' %}
    @media (min-width: 1024px) {
    .media-hyperlink .anm-image-hover {
      transition: transform var(--image-transition-duration) ease-out;
      will-change: transform; 
    }

    .media-hyperlink:hover .anm-image-hover {
      transform: scale(var(--image-hover-scale));
    }
  }
  {% endif %}
{% endstyle -%}