{%- liquid
  assign color_schemes_light = settings.color_schemes_light | append: ""
  assign color_schemes_light = settings.color_schemes | where: "id", color_schemes_light | first
  assign color_schemes_dark = settings.color_schemes_dark | append: ""
  assign color_schemes_dark = settings.color_schemes | where: "id", color_schemes_dark | first
-%}

{%- style %}
  /* Font size */
  :root {
    --heading-font-family: {{ settings.heading_font.family }}, {{ settings.heading_font.fallback_families }};
    --heading-font-style: {{ settings.heading_font.style }};
    --heading-font-weight: {{ settings.heading_font.weight }};
    --heading-base-size: 2rem;
    --heading-font-scale: {{ settings.heading_font_size | times: 0.01 }};
    --heading-text-transform: {{ settings.heading_text_tranform }};
    --subheading-base-size: 14px;

    --rating-star-size: {{ settings.body_font_size | times: 0.00945 }}rem;
  
    --menu-font-family: {{ settings.menu_font.family }}, {{ settings.menu_font.fallback_families }};
    --menu-font-style: {{ settings.menu_font.style }};
    --menu-font-weight: {{ settings.menu_font.weight }};
    --menu-letter-spacing: {{ settings.menu_letter_spacing }}px;
    
    --body-font-scale: {{ settings.body_font_size | times: 0.01 }};
    --body-base-size: 0.875rem;
    --body-font-family: {{ settings.body_font.family }}, {{ settings.body_font.fallback_families }};
    --body-font-style: {{ settings.body_font.style }};
    --body-font-weight: {{ settings.body_font.weight }};
    --button-font: {{ settings.button_font.family }}, {{ settings.button_font.fallback_families }};
    --button-font-style: {{ settings.button_font.style }};
    --button-font-weight: {{ settings.button_font.weight }};
    --button-font-size: {{ settings.button_font_size | times: 0.01 | times: 2 | times: 0.45 | times: 0.8 }}rem;
    --shopify-accelerated-checkout-button-border-radius: {% if settings.edges_type == 'rounded_corners' %}6px{% else %}0{% endif %};
    --button-border-radius: {% if settings.edges_type == 'rounded_corners' %}6px{% else %}0{% endif %};

    --mobile-padding-ratio: 0.5;
    --page-width: {{ settings.page_width | default: 1440 }}px;

    --rounded-corners: 10px;

    --padding-content-page-width: 16px;
    --padding-content-full-width: 16px;
    --padding-content-full-width-padded: 16px;
    --full-width-padded: 16px;

    --total-padding-page-width: 64px;
    --total-padding-full-width: 64px;
    --total-padding-full-width-padded: 128px;

    --text-animation-duration: 700ms;
    --drawer-transition-duration: 500ms;
    --card-animation-duration: 400ms;
    --reveal-transition-duration: 500ms;
    --header-menu-transition-duration: 300ms;
    --header-menu-transition-delay: 150ms;
    --menu-promotion-duration: 1000ms;
    --menu-item-delay-transition: 450ms;
    --transition-slideshow-content: 500ms;
    --button-animation-duration: 500ms;
    --popup-animation-duration: 500ms;
    --choose-option-animation-duration: 300ms;
    --dropdown-animation-duration: 150ms;
    --text-link-and-title-link-animation-duration: 400ms;
    
    --fade-element-translate-y: 20px;
    --flow-card-duration: 500ms;
    --announcement-height: 0px;
    --top-header: 0px;
    --segmented-banner-animation-duration-mobile: 1000ms;
    --segmented-banner-animation-duration-desktop: 1600ms;
    --product-info-media-width: 100%;
    --line-height-heading: 1.4;
    --line-height-body: 1.6;
    --line-height-button: 1.4;
    --border-radius-popup: {% if settings.edges_type == 'rounded_corners' %}10px{% else %}0{% endif %};
    --border-radius-drawer: {% if settings.edges_type == 'rounded_corners' %}10px{% else %}0{% endif %};
    --border-radius-countdown-timer: {% if settings.edges_type == 'rounded_corners' %}6px{% else %}0{% endif %};
    --progress-bar-active-width: 20%;
    --border-radius-checkbox: {% if settings.edges_type == 'rounded_corners' %}4px{% else %}0{% endif %};
    --padding-bottom-product-template-block: 16px;
    --spacing-between-heading-and-content: 16px;
    --pad-top-m: 0px;
    --pad-right-m: 0px;
    --pad-left-m: 0px;
    --pad-bottom-m: 0px;
    --pad-top: 0px;
    --pad-right: 0px;
    --pad-left: 0px;
    --pad-bottom: 0px;
    --block-width: 1.0;
    --image-hover-scale: 1.2;
    --image-transition-duration: 500ms;
  }

  :root, #x-header-container header {
    --h1-font-size: calc(var(--heading-base-size) * var(--heading-font-scale) * 1.75 * 0.55);
    --h2-font-size: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.65);
    --h3-font-size: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.75 * 0.75);
    --h4-font-size: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.65 * 0.75);
    --h5-font-size: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.55 * 0.75);
    --h6-font-size: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.45 * 0.8);
    --h7-font-size: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.4 * 0.8);
    --heading-font-size-small: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.85 * 0.7);
    --heading-font-size-medium: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.85);
    --heading-font-size-large: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.85 * 1.2);
    --heading-font-size-extra-large: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.85 * 2.5);

    --subheading-font-size-small: calc(var(--subheading-base-size) * var(--heading-font-scale) * 0.9 * 0.9);
    --subheading-font-size-medium: calc(var(--subheading-base-size) * var(--heading-font-scale) * 0.9);
    --subheading-font-size-large: calc(var(--subheading-base-size) * var(--heading-font-scale) * 1.2 * 0.9);

    --body-font-size: calc(var(--body-base-size) * var(--body-font-scale) * 0.9);
    --body-font-size-small: calc(var(--body-base-size) * var(--body-font-scale) * 0.9 * 0.9);
    --body-font-size-x-small: calc(var(--body-base-size) * var(--body-font-scale) * 0.8 * 0.9);
    --body-font-size-xx-small: calc(var(--body-base-size) * var(--body-font-scale) * 0.7 * 0.9);
    --body-font-size-large: calc(var(--body-base-size) * var(--body-font-scale) * 1.2 * 0.9);
    --announcement-bar-font-size-countdown-timer: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.5 * 0.9);
  }
  :root #x-header-container header,
  :root #x-header-container header *:before {
    --body-font-scale: {{ settings.menu_font_size | times: 0.01}};
    --heading-font-scale: {{ settings.menu_font_size | times: 0.01 }};
  }
  .block-title-size {
    --heading-font-size-small: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.45 * 0.85);
    --heading-font-size-medium: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.55 * 0.85);
    --heading-font-size-large: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.8 * 0.85);
  }
  @media (min-width: 768px){
    :root, #x-header-container header {
      --h1-font-size: calc(var(--heading-base-size) * var(--heading-font-scale) * 1.75);
      --h2-font-size: calc(var(--heading-base-size) * var(--heading-font-scale));
      --h3-font-size: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.75);
      --h4-font-size: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.65);
      --h5-font-size: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.55);
      --h6-font-size: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.45);
      --h7-font-size: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.4);
      --heading-font-size-small: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.7);
      --heading-font-size-medium: calc(var(--heading-base-size) * var(--heading-font-scale));
      --heading-font-size-large: calc(var(--heading-base-size) * var(--heading-font-scale) * 1.2);
      --heading-font-size-extra-large: calc(var(--heading-base-size) * var(--heading-font-scale) * 2.5);

      --subheading-font-size-small: calc(var(--subheading-base-size) * var(--heading-font-scale) * 0.9);
      --subheading-font-size-medium: calc(var(--subheading-base-size) * var(--heading-font-scale));
      --subheading-font-size-large: calc(var(--subheading-base-size) * var(--heading-font-scale) * 1.2);

      --body-font-size: calc(var(--body-base-size) * var(--body-font-scale));
      --body-font-size-small: calc(var(--body-base-size) * var(--body-font-scale) * 0.9);
      --body-font-size-x-small: calc(var(--body-base-size) * var(--body-font-scale) * 0.8);
      --body-font-size-xx-small: calc(var(--body-base-size) * var(--body-font-scale) * 0.7);
      --body-font-size-large: calc(var(--body-base-size) * var(--body-font-scale) * 1.2);
      --announcement-bar-font-size-countdown-timer: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.5);

      --product-info-media-width: 50%;
    }

    :root {
      --button-font-size: {{ settings.button_font_size | times: 0.01 | times: 2 | times: 0.45 }}rem;
      --padding-content-page-width: 32px;
      --padding-content-full-width: 32px;
      --padding-content-full-width-padded: 32px;
      --full-width-padded: 32px;
      --border-radius-popup: {% if settings.edges_type == 'rounded_corners' %}20px{% else %}0{% endif %};
      --border-radius-drawer: {% if settings.edges_type == 'rounded_corners' %}20px{% else %}0{% endif %};
      --padding-bottom-product-template-block: 20px;
      --spacing-between-heading-and-content: 26px;
      --page-width {{ settings.page_width }}px;
      --max-width-block-text: 950px;
      --max-width-page-content: 950px;
    }

    .block-title-size {
      --heading-font-size-small: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.45);
      --heading-font-size-medium: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.55);
      --heading-font-size-large: calc(var(--heading-base-size) * var(--heading-font-scale) * 0.8);
    }
  }
  /* Colors */
  :root,
  *:before, .color-scheme-theme {
    --color-background: {{ color_schemes_light.settings.background.red }} {{ color_schemes_light.settings.background.green }} {{ color_schemes_light.settings.background.blue }} / {{ color_schemes_light.settings.background.alpha }};
    --color-background-no-alpha: {{ color_schemes_light.settings.background.red }} {{ color_schemes_light.settings.background.green }} {{ color_schemes_light.settings.background.blue }};
    {% if color_schemes_light.settings.background_gradient != blank %}
      --gradient-background: {{ color_schemes_light.settings.background_gradient }};
      --gradient-background-no-alpha: {{ color_schemes_light.settings.background_gradient }};
    {% else %}
      --gradient-background: {{ color_schemes_light.settings.background }};
      --gradient-background-no-alpha: rgb({{ color_schemes_light.settings.background.rgb }});
    {% endif %}
    --color-highlight: {{ color_schemes_light.settings.heading_highlight.red }} {{ color_schemes_light.settings.heading_highlight.green }} {{ color_schemes_light.settings.heading_highlight.blue }} / {{ color_schemes_light.settings.heading_highlight.alpha }};
    --color-highlight-no-alpha: {{ color_schemes_light.settings.heading_highlight.red }} {{ color_schemes_light.settings.heading_highlight.green }} {{ color_schemes_light.settings.heading_highlight.blue }};
    --color-link: {{ color_schemes_light.settings.heading_highlight.red }} {{ color_schemes_light.settings.heading_highlight.green }} {{ color_schemes_light.settings.heading_highlight.blue }} / {{ color_schemes_light.settings.heading_highlight.alpha }};
    --color-link-no-alpha: {{ color_schemes_light.settings.heading_highlight.red }} {{ color_schemes_light.settings.heading_highlight.green }} {{ color_schemes_light.settings.heading_highlight.blue }};
    --color-heading: {{ color_schemes_light.settings.heading.red }} {{ color_schemes_light.settings.heading.green }} {{ color_schemes_light.settings.heading.blue }} / {{ color_schemes_light.settings.heading.alpha }};
    --color-heading-no-alpha: {{ color_schemes_light.settings.heading.red }} {{ color_schemes_light.settings.heading.green }} {{ color_schemes_light.settings.heading.blue }};
    --color-text: {{ color_schemes_light.settings.text.red }} {{ color_schemes_light.settings.text.green }} {{ color_schemes_light.settings.text.blue }} / {{ color_schemes_light.settings.text.alpha }};
    --color-text-no-alpha: {{ color_schemes_light.settings.text.red }} {{ color_schemes_light.settings.text.green }} {{ color_schemes_light.settings.text.blue }};
    --color-line-and-border: {{ color_schemes_light.settings.line_and_border_color.red }} {{ color_schemes_light.settings.line_and_border_color.green }} {{ color_schemes_light.settings.line_and_border_color.blue }} / {{ color_schemes_light.settings.line_and_border_color.alpha }};
    --color-line-and-border-no-alpha: {{ color_schemes_light.settings.line_and_border_color.red }} {{ color_schemes_light.settings.line_and_border_color.green }} {{ color_schemes_light.settings.line_and_border_color.blue }};
    --color-vendor: {{ color_schemes_light.settings.heading.red }} {{ color_schemes_light.settings.heading.green }} {{ color_schemes_light.settings.heading.blue }} / 0.4;
    --color-vendor-no-alpha: {{ color_schemes_light.settings.heading.red }} {{ color_schemes_light.settings.heading.green }} {{ color_schemes_light.settings.heading.blue }};
    
    --color-button: {{ color_schemes_light.settings.button.red }} {{ color_schemes_light.settings.button.green }} {{ color_schemes_light.settings.button.blue }} / {{ color_schemes_light.settings.button.alpha }};
    --color-button-no-alpha: {{ color_schemes_light.settings.button.red }} {{ color_schemes_light.settings.button.green }} {{ color_schemes_light.settings.button.blue }};
    --color-button-text: {{ color_schemes_light.settings.button_label.red }} {{ color_schemes_light.settings.button_label.green }} {{ color_schemes_light.settings.button_label.blue }} / {{ color_schemes_light.settings.button_label.alpha }};
    --color-button-text-no-alpha: {{ color_schemes_light.settings.button_label.red }} {{ color_schemes_light.settings.button_label.green }} {{ color_schemes_light.settings.button_label.blue }};
    --color-button-hover: {{ color_schemes_light.settings.button_hover.red }} {{ color_schemes_light.settings.button_hover.green }} {{ color_schemes_light.settings.button_hover.blue }} / {{ color_schemes_light.settings.button_hover.alpha }};
    --color-button-hover-no-alpha: {{ color_schemes_light.settings.button_hover.red }} {{ color_schemes_light.settings.button_hover.green }} {{ color_schemes_light.settings.button_hover.blue }};
    --color-button-text-hover: {{ color_schemes_light.settings.button_label_hover.red }} {{ color_schemes_light.settings.button_label_hover.green }} {{ color_schemes_light.settings.button_label_hover.blue }} / {{ color_schemes_light.settings.button_label_hover.alpha }};
    --color-button-text-hover-no-alpha: {{ color_schemes_light.settings.button_label_hover.red }} {{ color_schemes_light.settings.button_label_hover.green }} {{ color_schemes_light.settings.button_label_hover.blue }};
    --color-secondary-button: {{ color_schemes_light.settings.secondary_button.red }} {{ color_schemes_light.settings.secondary_button.green }} {{ color_schemes_light.settings.secondary_button.blue }} / {{ color_schemes_light.settings.secondary_button.alpha }};
    --color-secondary-button-no-alpha: {{ color_schemes_light.settings.secondary_button.red }} {{ color_schemes_light.settings.secondary_button.green }} {{ color_schemes_light.settings.secondary_button.blue }};
    --color-secondary-button-text: {{ color_schemes_light.settings.secondary_button_label_color.red }} {{ color_schemes_light.settings.secondary_button_label_color.green }} {{ color_schemes_light.settings.secondary_button_label_color.blue }} / {{ color_schemes_light.settings.secondary_button_label_color.alpha }};
    --color-secondary-button-text-no-alpha: {{ color_schemes_light.settings.secondary_button_label_color.red }} {{ color_schemes_light.settings.secondary_button_label_color.green }} {{ color_schemes_light.settings.secondary_button_label_color.blue }};
    --color-secondary-button-hover: {{ color_schemes_light.settings.secondary_button_hover.red }} {{ color_schemes_light.settings.secondary_button_hover.green }} {{ color_schemes_light.settings.secondary_button_hover.blue }} / {{ color_schemes_light.settings.secondary_button_hover.alpha }};
    --color-secondary-button-hover-no-alpha: {{ color_schemes_light.settings.secondary_button_hover.red }} {{ color_schemes_light.settings.secondary_button_hover.green }} {{ color_schemes_light.settings.secondary_button_hover.blue }};
    --color-secondary-button-text-hover: {{ color_schemes_light.settings.secondary_button_label_hover.red }} {{ color_schemes_light.settings.secondary_button_label_hover.green }} {{ color_schemes_light.settings.secondary_button_label_hover.blue }} / {{ color_schemes_light.settings.secondary_button_label_hover.alpha }};
    --color-secondary-button-text-hover-no-alpha: {{ color_schemes_light.settings.secondary_button_label_hover.red }} {{ color_schemes_light.settings.secondary_button_label_hover.green }} {{ color_schemes_light.settings.secondary_button_label_hover.blue }};
    --color-button-link: {{ color_schemes_light.settings.link_button_color.red }} {{ color_schemes_light.settings.link_button_color.green }} {{ color_schemes_light.settings.link_button_color.blue }} / {{ color_schemes_light.settings.link_button_color.alpha }};
    --color-button-link-no-alpha: {{ color_schemes_light.settings.link_button_color.red }} {{ color_schemes_light.settings.link_button_color.green }} {{ color_schemes_light.settings.link_button_color.blue }};
    --button-padding-y-mobile: 10px;
    --button-padding-x-mobile: 26px;
    --button-padding-y-desktop: 12px;
    --button-padding-x-desktop: 33px;
    --input-border-radius: 0.25rem;

    --error-background-color: {{ settings.color_background_error.red }} {{ settings.color_background_error.green }} {{ settings.color_background_error.blue }} / {{ settings.color_background_error.alpha }};
    --error-background-color-no-alpha: {{ settings.color_background_error.red }} {{ settings.color_background_error.green }} {{ settings.color_background_error.blue }};
    --error-message-color: {{ settings.color_error_message.red }} {{ settings.color_error_message.green }} {{ settings.color_error_message.blue }} / {{ settings.color_error_message.alpha }};
    --error-message-color-no-alpha: {{ settings.color_error_message.red }} {{ settings.color_error_message.green }} {{ settings.color_error_message.blue }};
    --success-background-color: {{ settings.color_background_success.red }} {{ settings.color_background_success.green }} {{ settings.color_background_success.blue }} / {{ settings.color_background_success.alpha }};
    --success-background-color-no-alpha: {{ settings.color_background_success.red }} {{ settings.color_background_success.green }} {{ settings.color_background_success.blue }};
    --success-message-color: {{ settings.color_success_message.red }} {{ settings.color_success_message.green }} {{ settings.color_success_message.blue }} / {{ settings.color_success_message.alpha }};
    --success-message-color-no-alpha: {{ settings.color_success_message.red }} {{ settings.color_success_message.green }} {{ settings.color_success_message.blue }};
    --color-price: {{ settings.price.red }} {{ settings.price.green }} {{ settings.price.blue }} / {{ settings.price.alpha }};
    --color-price-no-alpha: {{ settings.price.red }} {{ settings.price.green }} {{ settings.price.blue }};
    --color-sale-price: {{ settings.sale_price.red }} {{ settings.sale_price.green }} {{ settings.sale_price.blue }} / {{ settings.sale_price.alpha }};
    --color-sale-price-no-alpha: {{ settings.sale_price.red }} {{ settings.sale_price.green }} {{ settings.sale_price.blue }};
    --rating-color: {{ settings.color_ratings.red }} {{ settings.color_ratings.green }} {{ settings.color_ratings.blue }} / {{ settings.color_ratings.alpha }};
    --rating-color-no-alpha: {{ settings.color_ratings.red }} {{ settings.color_ratings.green }} {{ settings.color_ratings.blue }};
    --color-in-stock: {{ settings.color_in_stock.red }} {{ settings.color_in_stock.green }} {{ settings.color_in_stock.blue }} / {{ settings.color_in_stock.alpha }};
    --color-in-stock-no-alpha: {{ settings.color_in_stock.red }} {{ settings.color_in_stock.green }} {{ settings.color_in_stock.blue }};
    --color-low-stock: {{ settings.color_low_stock.red }} {{ settings.color_low_stock.green }} {{ settings.color_low_stock.blue }} / {{ settings.color_low_stock.alpha }};
    --color-low-stock-no-alpha: {{ settings.color_low_stock.red }} {{ settings.color_low_stock.green }} {{ settings.color_low_stock.blue }};
    --color-out-of-stock: {{ settings.color_out_of_stock.red }} {{ settings.color_out_of_stock.green }} {{ settings.color_out_of_stock.blue }} / {{ settings.color_out_of_stock.alpha }};
    --color-out-of-stock-no-alpha: {{ settings.color_out_of_stock.red }} {{ settings.color_out_of_stock.green }} {{ settings.color_out_of_stock.blue }};

    --color-overlay: {{ settings.overlay_background.red }} {{ settings.overlay_background.green }} {{ settings.overlay_background.blue }} / {{ settings.overlay_background.alpha }};
    --color-overlay-no-alpha: {{ settings.overlay_background.red }} {{ settings.overlay_background.green }} {{ settings.overlay_background.blue }};
    --color-border-footer: {{ settings.footer_line_and_border_color.red }} {{ settings.footer_line_and_border_color.green }} {{ settings.footer_line_and_border_color.blue }} / {{ settings.footer_line_and_border_color.alpha }};
    --color-border-footer-no-alpha: {{ settings.footer_line_and_border_color.red }} {{ settings.footer_line_and_border_color.green }} {{ settings.footer_line_and_border_color.blue }};
    --color-pulse-speech: {{ settings.colors_speech.red }} {{ settings.colors_speech.green }} {{ settings.colors_speech.blue }} / {{ settings.colors_speech.alpha }};
    --color-pulse-speech-no-alpha: {{ settings.colors_speech.red }} {{ settings.colors_speech.green }} {{ settings.colors_speech.blue }};
    {%- if settings.breadcrumbs_background_color.alpha != 0.0 -%}
      --color-breadcrumb-background: {{ settings.breadcrumbs_background_color.red }} {{ settings.breadcrumbs_background_color.green }} {{ settings.breadcrumbs_background_color.blue }} / {{ settings.breadcrumbs_background_color.alpha }};
      --color-breadcrumb-background-no-alpha: {{ settings.breadcrumbs_background_color.red }} {{ settings.breadcrumbs_background_color.green }} {{ settings.breadcrumbs_background_color.blue }};
    {%- endif -%}
    {%- if settings.breadcrumbs_text_color.alpha != 0.0 -%}
      --color-breadcrumb-text: {{ settings.breadcrumbs_text_color.red }} {{ settings.breadcrumbs_text_color.green }} {{ settings.breadcrumbs_text_color.blue }} / {{ settings.breadcrumbs_text_color.alpha }};
      --color-breadcrumb-text-no-alpha: {{ settings.breadcrumbs_text_color.red }} {{ settings.breadcrumbs_text_color.green }} {{ settings.breadcrumbs_text_color.blue }};
    {%- else -%}
      --color-breadcrumb-text: {{ color_schemes_light.settings.text.red }} {{ color_schemes_light.settings.text.green }} {{ color_schemes_light.settings.text.blue }} / {{ color_schemes_light.settings.text.alpha }};
      --color-breadcrumb-text-no-alpha: {{ color_schemes_light.settings.text.red }} {{ color_schemes_light.settings.text.green }} {{ color_schemes_light.settings.text.blue }};
    {%- endif -%}
    {%- if settings.breadcrumbs_text_link_color.alpha != 0.0 -%}
