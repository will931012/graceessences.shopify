{% liquid
  assign settings = block.settings

  assign mobile_h_flex = settings.mobile_horizontal_alignment
  if mobile_h_flex == 'left'
    assign mobile_h_flex = 'start'
  elsif mobile_h_flex == 'right'
    assign mobile_h_flex = 'end'
  endif

  assign desktop_h_flex = settings.desktop_horizontal_alignment
  if desktop_h_flex == 'left'
    assign desktop_h_flex = 'start'
  elsif desktop_h_flex == 'right'
    assign desktop_h_flex = 'end'
  endif
%}

{% liquid
  assign number_of_gap = block.blocks.size | minus: 1 
  if number_of_gap < 0
    assign number_of_gap = 0
  endif
%}

{% liquid
  assign group_link_target = '_self'
  if settings.open_new_window
    assign group_link_target = '_blank'
  endif
%}

{% style %}
  .block-{{ block.id }} {
    {% if settings.width == 'fit' %}
      width: fit-content;
      --block-width: fit-content;
    {% elsif settings.width == 'custom' %}
      width: {{ settings.mobile_group_width }}%;
      --block-width: {{ settings.mobile_group_width  | divided_by: 100.0 }};
    {% endif %}
    --pad-top: {{ block.settings.desktop_padding_top }}px;
    --pad-bottom: {{ block.settings.desktop_padding_bottom }}px;
    --pad-left: {{ block.settings.desktop_padding_left }}px;
    --pad-right: {{ block.settings.desktop_padding_right }}px;
    --pad-top-m: {{ block.settings.mobile_padding_top }}px;
    --pad-bottom-m: {{ block.settings.mobile_padding_bottom }}px;
    --pad-left-m: {{ block.settings.mobile_padding_left }}px;
    --pad-right-m: {{ block.settings.mobile_padding_right }}px;
    align-self: {{ settings.mobile_vertical_alignment }};
    align-items: {{ settings.mobile_vertical_alignment }};
  }
  @media (max-width: 767px) {
    .group-content-{{ block.id }} {
      flex-direction: {% if settings.mobile_direction == 'col' %}column{% else %}row{% endif %};
      {% if settings.mobile_direction == 'col' %}
        align-items: {{ mobile_h_flex }};
      {% else %}
        justify-content: {{ mobile_h_flex }};
      {% endif %}
      text-align: {{ settings.mobile_horizontal_alignment }};
      gap: calc({{ settings.gap }}px * var(--mobile-padding-ratio));
      padding: {{ settings.inner_padding_vertical_mobile }}px {{ settings.inner_padding_horizontal_mobile }}px;
    }
    {% if settings.mobile_direction == 'col' %}
      .group-content-{{ block.id }} > .maximize-block {
        flex: 0 0 calc((100% - {{ number_of_gap }} * var(--mobile-padding-ratio) * {{ section.settings.gap }}px) * var(--block-width));
      }
    {% endif %}
  }

  @media (min-width: 768px) {
    .block-{{ block.id }} {
      align-self: {{ settings.desktop_vertical_alignment }};
      align-items: {{ settings.desktop_vertical_alignment }};
      {% if settings.width == 'custom' %}
        width: {{ settings.desktop_group_width }}%;
        --block-width: {{ settings.desktop_group_width  | divided_by: 100.0 }};
      {% endif %}
    }
    .group-content-{{ block.id }} {
      flex-direction: {% if settings.desktop_direction == 'col' %}column{% else %}row{% endif %};
      {% if settings.desktop_direction == 'col' %}
        align-items: {{ desktop_h_flex }};
      {% else %}
        justify-content: {{ desktop_h_flex }};
      {% endif %}
      text-align: {{ settings.desktop_horizontal_alignment }};
      gap: {{ settings.gap }}px;
      padding: {{ settings.inner_padding_vertical_desktop }}px {{ settings.inner_padding_horizontal_desktop }}px;
    }
    {% if settings.desktop_direction == 'col' %}
      .group-content-{{ block.id }} > .maximize-block {
        flex: 0 0 calc((100% - {{ number_of_gap }} * {{ section.settings.gap }}px) * var(--block-width));
      }
    {% endif %}
  }
{% endstyle %}

<div
  class="block-group block-padding block-{{ block.id }} maximize-block rounded-corners color-{{ settings.color_scheme_light }} dark-color-{{ settings.color_scheme_dark }} h-full relative flex
  {%- if settings.group_link != blank %} cursor-pointer{% endif -%}"
  data-block-id="{{ block.id }}"
  {% if settings.group_link != blank %}
    data-group-href="{{ settings.group_link | escape }}"
    data-group-target="{{ group_link_target }}"
    @click="$el.dataset.groupHref && !$event.target.closest('a, button') && window.open($el.dataset.groupHref, $el.dataset.groupTarget, 'noopener,noreferrer')"
    @keyup.enter="$el.dataset.groupHref && !$event.target.closest('a, button') && window.open($el.dataset.groupHref, $el.dataset.groupTarget, 'noopener,noreferrer')"
    tabindex="0"
    role="link"
    aria-label="{{ settings.group_link | escape }}"
  {% endif %}
  {{ block.shopify_attributes }}
>
  <div class="block-group__content group-content-{{ block.id }} w-full h-fit flex rounded-corners
    {%- if settings.show_border_mobile %} sm:border color-border-[rgba(var(--color-line-and-border))]{% endif -%}{%- if settings.show_border %} md:border border-solid color-border-[rgba(var(--color-line-and-border))]{% endif -%}">
    {% content_for 'blocks' %}
  </div>

</div>

{% schema %}
{
  "name": "Group",
  "tag": null,
  "blocks": [
    {
      "type": "subheading"
    },
    {
      "type": "heading"
    },
    {
      "type": "text"
    },
    {
      "type": "button"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "video"
    },
    {
      "type": "_group"
    },
    {
      "type": "counter"
    },
    {
      "type": "countdown-timer"
    },
    {
      "type": "_items-list"
    },
    {
      "type": "table-of-information"
    },
    {
      "type": "email-signup"
    },
    {
      "type": "payment-methods"
    },
    {
      "type": "social-sharing"
    },
    {
      "type": "page"
    },
    {
      "type": "estimate-delivery-time"
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "label": "Desktop",
      "id": "desktop_direction",
      "options": [
        {
          "label": "Vertical",
          "value": "col"
        },
        {
          "label": "Horizontal",
          "value": "row"
        }
      ],
      "default": "col"
    },
    {
      "type": "select",
      "label": "Mobile",
      "id": "mobile_direction",
      "options": [
        {
          "label": "Vertical",
          "value": "col"
        },
        {
          "label": "Horizontal",
          "value": "row"
        }
      ],
      "default": "col"
    },
    {
      "type": "header",
      "content": "Alignment"
    },
    {
      "type": "paragraph",
      "content": "Vertical alignment"
    },
    {
      "type": "select",
      "id": "desktop_vertical_alignment",
      "label": "Desktop",
      "options": [
        {
          "value": "start",
          "label": "t:global.position.top"
        },
        {
          "value": "center",
          "label": "t:global.position.center"
        },
        {
          "value": "end",
          "label": "t:global.position.bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "mobile_vertical_alignment",
      "label": "Mobile",
      "options": [
        {
          "value": "start",
          "label": "t:global.position.top"
        },
        {
          "value": "center",
          "label": "t:global.position.center"
        },
        {
          "value": "end",
          "label": "t:global.position.bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "paragraph",
      "content": "Horizontal alignment"
    },
    {
      "type": "text_alignment",
      "id": "desktop_horizontal_alignment",
      "label": "Desktop",
      "default": "left"
    },
    {
      "type": "text_alignment",
      "id": "mobile_horizontal_alignment",
      "label": "Mobile",
      "default": "left"
    },
    {
      "type": "header",
      "content": "Size"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "options": [
        {
          "value": "fit",
          "label": "Fit"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "fit"
    },
    {
      "type": "range",
      "id": "desktop_group_width",
      "min": 5,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Desktop width",
      "default": 100,
      "visible_if": "{{ block.settings.width == 'custom' }}"
    },
    {
      "type": "range",
      "id": "mobile_group_width",
      "min": 5,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Mobile width",
      "default": 100,
      "visible_if": "{{ block.settings.width == 'custom' }}"
    },
    {
      "type": "header",
      "content": "Link"
    },
    {
      "type": "url",
      "id": "group_link",
      "label": "Link"
    },
    {
      "type": "checkbox",
      "id": "open_new_window",
      "default": false,
      "label": "t:global.text.open_link_new_tab"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Gap",
      "default": 0
    },
    {
      "type": "header",
      "content": "Inner Spacing"
    },
    {
      "type": "select",
      "id": "device_inner_padding",
      "label": "t:global.header.choose_device",
      "info": "Desktop and Mobile settings are configured separately.",
      "options": [
        {
          "value": "desktop",
          "label": "t:global.section.desktop"
        },
        {
          "value": "mobile",
          "label": "t:global.section.mobile"
        }
      ],
      "default": "desktop"
    },
    {
      "type": "range",
      "id": "inner_padding_vertical_desktop",
      "label": "Vertical",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ block.settings.device_inner_padding == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "inner_padding_horizontal_desktop",
      "label": "Horizontal",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ block.settings.device_inner_padding == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "inner_padding_vertical_mobile",
      "label": "Vertical",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ block.settings.device_inner_padding == 'mobile' }}"
    },
    {
      "type": "range",
      "id": "inner_padding_horizontal_mobile",
      "label": "Horizontal",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ block.settings.device_inner_padding == 'mobile' }}"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "select",
      "id": "spacing_choose_device",
      "label": "Choose device",
      "options": [
        {
          "value": "desktop",
          "label": "Desktop"
        },
        {
          "value": "mobile",
          "label": "Mobile"
        }
      ],
      "default": "desktop",
      "info": "Desktop and Mobile settings are configured separately."
    },
    {
      "type": "range",
      "id": "desktop_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "desktop_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "desktop_padding_left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Left",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "desktop_padding_right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Right",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'mobile' }}"
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'mobile' }}"
    },
    {
      "type": "range",
      "id": "mobile_padding_left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Left",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'mobile' }}"
    },
    {
      "type": "range",
      "id": "mobile_padding_right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Right",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'mobile' }}"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "checkbox",
      "id": "show_border_mobile",
      "label": "Show border (mobile)",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_border",
      "label": "Show border (desktop)",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme_light",
      "default": "scheme-1",
      "label": "t:global.colors.color_scheme_light"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme_dark",
      "default": "scheme-2",
      "label": "t:global.colors.color_scheme_dark"
    }
  ],
  "presets": [
    {
      "name": "Group",
      "category": "Layout"
    }
  ]
}
{% endschema %}
