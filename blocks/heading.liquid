{% if block.settings.heading != blank %}
  {% style %}
    .block-{{ block.id }} {
      --pad-top: {{ block.settings.desktop_padding_top }}px;
      --pad-bottom: {{ block.settings.desktop_padding_bottom }}px;
      --pad-left: {{ block.settings.desktop_padding_left }}px;
      --pad-right: {{ block.settings.desktop_padding_right }}px;
      --pad-top-m: {{ block.settings.mobile_padding_top }}px;
      --pad-bottom-m: {{ block.settings.mobile_padding_bottom }}px;
      --pad-left-m: {{ block.settings.mobile_padding_left }}px;
      --pad-right-m: {{ block.settings.mobile_padding_right }}px;
      {% if block.settings.heading_size == 'custom' %}
        font-size: {{ block.settings.mobile_font_size }}px;
        line-height: {{ block.settings.line_height }}%;
      {% endif %}
    }
    {% if block.settings.heading_size == 'custom' %}
      @media (min-width: 768px) {
        .block-{{ block.id }} {
          font-size: {{ block.settings.desktop_font_size }}px;
          line-height: {{ block.settings.line_height }}%;
        }
      }
    {% endif %}
  {% endstyle %}

  <{{ block.settings.heading_tag }} 
    class="maximize-block block-heading block-padding block-{{ block.id }} p-break-words heading-{{ block.settings.heading_size }} color-text-[rgba(var(--color-heading))]"
    data-block-id="{{ block.id }}" 
    {{ block.shopify_attributes }}
  >
    {% render 'text-highlight',
      id: block.id,
      text: block.settings.heading,
      highlight_effect: block.settings.highlight_effect,
      text_transform: block.settings.text_transform,
      disable_animation_fade: false,
      custom_class: ''
    %}
  </{{ block.settings.heading_tag }}>
{% endif %}

{% schema %}
{
  "name": "Heading",
  "tag": null,
  "settings": [
   {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Heading"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "default": "h2",
      "label": "t:global.text.heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        },
        {
          "value": "p",
          "label": "p"
        }
      ]
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Font size",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "medium"
    },
    {
      "type": "range",
      "id": "desktop_font_size",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Desktop font size",
      "default": 32,
      "visible_if": "{{ block.settings.heading_size == 'custom' }}"
    },
    {
      "type": "range",
      "id": "mobile_font_size",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile font size",
      "default": 32,
      "visible_if": "{{ block.settings.heading_size == 'custom' }}"
    },
    {
      "type": "range",
      "id": "line_height",
      "min": 100,
      "max": 300,
      "step": 5,
      "unit": "%",
      "label": "Line height",
      "default": 140,
      "visible_if": "{{ block.settings.heading_size == 'custom' }}"
    },
    {
      "type": "header",
      "content": "Highlight",
      "info": "t:global.text.highlight_info"
    },
    {
      "type": "select",
      "id": "highlight_effect",
      "label": "t:global.text.highlight_effect.label",
      "options": [
        {
          "value": "underline",
          "label": "t:global.text.highlight_effect.option_1"
        },
        {
          "value": "marker",
          "label": "t:global.text.highlight_effect.option_2"
        },
        {
          "value": "text-color-change",
          "label": "t:global.text.highlight_effect.option_3"
        },
        {
          "value": "shadow",
          "label": "t:global.text.highlight_effect.option_4"
        }
      ],
      "default": "underline"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "t:global.text.transform.label",
      "options": [
        {
          "value": "none",
          "label": "t:global.text.transform.none"
        },
        {
          "value": "italic",
          "label": "t:global.text.transform.italic"
        },
        {
          "value": "uppercase",
          "label": "t:global.text.transform.uppercase"
        },
        {
          "value": "both",
          "label": "t:global.text.transform.italic_and_uppercase"
        }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "select",
      "id": "spacing_choose_device",
      "label": "Choose device",
      "options": [
        {
          "value": "desktop",
          "label": "Desktop"
        },
        {
          "value": "mobile",
          "label": "Mobile"
        }
      ],
      "default": "desktop",
      "info": "Desktop and Mobile settings are configured separately."
    },
    {
      "type": "range",
      "id": "desktop_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "desktop_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "desktop_padding_left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Left",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "desktop_padding_right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Right",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'mobile' }}"
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'mobile' }}"
    },
    {
      "type": "range",
      "id": "mobile_padding_left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Left",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'mobile' }}"
    },
    {
      "type": "range",
      "id": "mobile_padding_right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Right",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'mobile' }}"
    }
  ],
  "presets": [
    {
      "name": "Heading",
      "category": "Basic"
    }
  ]
}
{% endschema %}
