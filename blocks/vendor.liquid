{% liquid
  assign product = closest.product
  assign link_vendor = block.settings.link_vendor
  assign vendor_handle = product.vendor | handleize
%}
{% style %}
  .block-{{ block.id }} {
    --pad-top: {{ block.settings.desktop_padding_top }}px;
    --pad-bottom: {{ block.settings.desktop_padding_bottom }}px;
    --pad-left: {{ block.settings.desktop_padding_left }}px;
    --pad-right: {{ block.settings.desktop_padding_right }}px;
    --pad-top-m: {{ block.settings.mobile_padding_top }}px;
    --pad-bottom-m: {{ block.settings.mobile_padding_bottom }}px;
    --pad-left-m: {{ block.settings.mobile_padding_left }}px;
    --pad-right-m: {{ block.settings.mobile_padding_right }}px;
  }
{% endstyle %}
<div
  class="block-vendor block-{{ block.id }} block-padding maximize-block w-full p-break-words inline-block color-text-[rgba(var(--color-text),0.6)] text-medium"
  data-block-id="{{ block.id }}"
  {{ block.shopify_attributes }}
>
  {% if product != blank %}
    {% if link_vendor %}
      <p class="block-vendor__link title-link anm-fade-element  {% if collections[vendor_handle] != empty %} inline{% endif %}" x-intersect.once="$el.classList.add('is-visible')">
        {% if collections[vendor_handle] != empty %}
          <a
            href="{{ routes.collections_url }}/{{ collections[vendor_handle].handle }}"
            {% if block.settings.open_new_tab %}
              target="_blank"
            {% endif %}
          >
            {{ collections[vendor_handle].title }}
          </a>
        {% else %}
          {% if block.settings.open_new_tab %}
            {{ product.vendor | link_to_vendor | replace: '<a', '<a target="_blank"' }}
          {% else %}
            {{ product.vendor | link_to_vendor }}
          {% endif %}
        {% endif %}
      </p>
    {% elsif product.metafields.custom.vendor_detail_page != blank or block.settings.select_page != blank %}
      <div x-data="xProductDrawer">
        <a
          id="VendorDetail__OpenButton"
          class="block-vendor__link title-link relative cursor-pointer w-fit anm-fade-element"
          x-intersect.once="$el.classList.add('is-visible')"
          @click.prevent="openDrawer('#VendorDrawer__Wrapper__{{ block.id }}')"
          tabindex="0"
          href="#"
        >
          {{ product.vendor | escape }}
        </a>
        <template x-teleport="body">
          <div
            id="VendorDrawer__Wrapper__{{ block.id }}"
            x-show="isShowDrawer"
            x-cloak
            class="drawer__wrapper vendor-drawer__wrapper color-{{ section.settings.color_scheme_light.id }} dark-color-{{ section.settings.color_scheme_dark.id }}"
            tabindex="0"
            style="background: transparent;"
          >
            <div
              id="VendorDrawer__Overlay__{{ block.id }}"
              class="drawer__overlay"
              x-show="isShowDrawer"
              @click.prevent="closeDrawer(true)"
            ></div>
            <div
              x-show="isShowDrawer"
              class="drawer__container vendor-drawer__container outline-none"
              tabindex="0"
              x-cloak
              x-transition:enter-start="opacity-0 transform translate-y-full md:translate-y-0 rtl:md:-translate-x-1/3 ltr:md:translate-x-1/3"
              x-transition:enter-end="opacity-100 transform translate-y-0 md:translate-x-0"
              x-transition:leave-end="opacity-0 transform translate-y-full md:translate-y-0 rtl:md:-translate-x-1/3 ltr:md:translate-x-1/3"
              x-intersect.full="$store.xFocusElement.trapFocus('VendorDrawer__Wrapper__{{ block.id }}', 'CloseVendorDrawer__{{ block.id }}')"
              @keyup.escape="closeDrawer()"
            >
              <div class="modal-title-container modal-title-padding-x pb-1 md:pb-2">
                <div class="modal-title-wrapper">
                  <div class="grow flex items-center">
                    {%- if product.metafields.custom.vendor_detail_page.value.title != blank -%}
                      <p class="h3" >
                        {{ product.metafields.custom.vendor_detail_page.value.title | escape }}
                      </p>
                    {%- else -%}
                      <p class="h3">
                        {{ block.settings.select_page.title | escape }}
                      </p>
                    {%- endif -%}
                  </div>
                  <button
                    id="CloseVendorDrawer__{{ block.id }}"
                    @click="closeDrawer()"
                    class="modal-title__button-close"
                  >
                    <span class="button__close icon-close-large-desktop icon-close-large-mobile">{%- render 'icon-all', icon: 'icon-close' -%}</span>
                  </button>
                </div>
              </div>
              <div class="vendor-drawer__content drawer__content scrollbar-visible scrollbar-body">
                {% if product.metafields.custom.vendor_detail_page.value != blank %}
                  <div class="rte">{{ product.metafields.custom.vendor_detail_page.value.content }}</div>
                {% else %}
                  {% if block.settings.select_page.content != blank %}
                    <div class="rte">{{ block.settings.select_page.content | replace: '<meta charset="UTF-8">' }}</div>
                  {% endif %}
                {% endif %}
              </div>
            </div>
          </div>
        </template>
      </div>
    {% else %}
      {% if block.settings.link != blank %}
        <a
          class="block-vendor__link title-link anm-fade-element"
          x-intersect.once="$el.classList.add('is-visible')"
          href="{{ block.settings.link }}"
          {% if block.settings.open_new_tab %}
            target="_blank"
          {% endif %}
        >
          {{- product.vendor | escape -}}
        </a>
      {% else %}
        <p class="anm-fade-element" x-intersect.once="$el.classList.add('is-visible')">
          {{ product.vendor | escape }}
        </p>
      {% endif %}
    {% endif %}
  {% else %}
    <span>{{ 'products.product.vendor' | t }}</span>
  {% endif %}
</div>
{% schema  %}
{
  "name": "t:main_product.blocks.vendor.block_name",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:main_product.blocks.vendor.settings.paragraph_1"
    },
    {
      "type": "paragraph",
      "content": "t:main_product.blocks.vendor.settings.paragraph_2"
    },
    {
      "type": "paragraph",
      "content": "t:main_product.blocks.vendor.settings.paragraph_3"
    },
    {
      "type": "checkbox",
      "id": "link_vendor",
      "label": "t:main_product.blocks.vendor.settings.link_vendor",
      "default": false
    },
    {
      "type": "page",
      "id": "select_page",
      "label": "t:main_product.blocks.vendor.settings.select_page"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:global.text.link"
    },
    {
      "type": "checkbox",
      "id": "open_new_tab",
      "label": "t:global.text.open_link_new_tab",
      "default": false
    },
    {
      "type": "header",
      "content": "t:global.section.padding"
    },
    {
      "type": "select",
      "id": "device_padding",
      "label": "t:global.header.choose_device",
      "info": "Desktop and Mobile settings are configured separately.",
      "options": [
        {
          "value": "desktop",
          "label": "t:global.section.desktop"
        },
        {
          "value": "mobile",
          "label": "t:global.section.mobile"
        }
      ],
      "default": "desktop"
    },
    {
      "type": "range",
      "id": "desktop_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:global.position.top",
      "default": 0,
      "visible_if": "{{ block.settings.device_padding == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "desktop_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:global.position.bottom",
      "default": 0,
      "visible_if": "{{ block.settings.device_padding == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "desktop_padding_left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:global.position.left",
      "default": 0,
      "visible_if": "{{ block.settings.device_padding == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "desktop_padding_right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:global.position.right",
      "default": 0,
      "visible_if": "{{ block.settings.device_padding == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:global.position.top",
      "default": 0,
      "visible_if": "{{ block.settings.device_padding == 'mobile' }}"
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:global.position.bottom",
      "default": 0,
      "visible_if": "{{ block.settings.device_padding == 'mobile' }}"
    },
    {
      "type": "range",
      "id": "mobile_padding_left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:global.position.left",
      "default": 0,
      "visible_if": "{{ block.settings.device_padding == 'mobile' }}"
    },
    {
      "type": "range",
      "id": "mobile_padding_right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:global.position.right",
      "default": 0,
      "visible_if": "{{ block.settings.device_padding == 'mobile' }}"
    }
  ],
  "presets": [
    {
      "name": "t:main_product.blocks.vendor.block_name",
      "category": "t:global.product.product"
    }
  ]
}
{% endschema %}
