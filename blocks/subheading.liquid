{% if block.settings.subheading != blank %}
  {% style %}
    .block-{{ block.id }} {
      {% if block.settings.subheading_size == 'custom' %}
        font-size: {{ block.settings.mobile_font_size }}px;
        line-height: {{ block.settings.line_height }}%;
      {% endif %}
      --pad-top: {{ block.settings.desktop_padding_top }}px;
      --pad-bottom: {{ block.settings.desktop_padding_bottom }}px;
      --pad-left: {{ block.settings.desktop_padding_left }}px;
      --pad-right: {{ block.settings.desktop_padding_right }}px;
      --pad-top-m: {{ block.settings.mobile_padding_top }}px;
      --pad-bottom-m: {{ block.settings.mobile_padding_bottom }}px;
      --pad-left-m: {{ block.settings.mobile_padding_left }}px;
      --pad-right-m: {{ block.settings.mobile_padding_right }}px;
    }
    {% if block.settings.subheading_size == 'custom' %}
      @media screen and (min-width: 768px) {
        .block-{{ block.id }} {
          font-size: {{ block.settings.desktop_font_size }}px;
          line-height: {{ block.settings.line_height }}%;
        }
      }
    {% endif %}
  {% endstyle %}

  <p 
    class="block-subheading block-padding maximize-block block-{{ block.id }} anm-fade-element subheading subheading-{{ block.settings.subheading_size }} p-break-words"
    x-intersect.once="$el.classList.add('is-visible')"
    data-block-id="{{ block.id }}"
    {{ block.shopify_attributes }}
  >
    {% render 'text-highlight',
      id: block.id,
      text: block.settings.subheading,
      highlight_effect: block.settings.highlight_effect,
      text_transform: block.settings.text_transform,
      custom_class: ''
    %}
  </p>
{% endif %}

{% schema %}
{
  "name": "Subheading",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Subheading"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "subheading_size",
      "label": "Font size",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "medium"
    },
    {
      "type": "range",
      "id": "desktop_font_size",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Desktop font size",
      "default": 16,
      "visible_if": "{{ block.settings.subheading_size == 'custom' }}"
    },
    {
      "type": "range",
      "id": "mobile_font_size",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile font size",
      "default": 16,
      "visible_if": "{{ block.settings.subheading_size == 'custom' }}"
    },
    {
      "type": "range",
      "id": "line_height",
      "min": 100,
      "max": 300,
      "step": 5,
      "unit": "%",
      "label": "Line height",
      "default": 140,
      "visible_if": "{{ block.settings.subheading_size == 'custom' }}"
    },
    {
      "type": "header",
      "content": "Highlight",
      "info": "t:global.text.highlight_info"
    },
    {
      "type": "select",
      "id": "highlight_effect",
      "label": "t:global.text.highlight_effect.label",
      "options": [
        {
          "value": "underline",
          "label": "t:global.text.highlight_effect.option_1"
        },
        {
          "value": "marker",
          "label": "t:global.text.highlight_effect.option_2"
        },
        {
          "value": "text-color-change",
          "label": "t:global.text.highlight_effect.option_3"
        },
        {
          "value": "shadow",
          "label": "t:global.text.highlight_effect.option_4"
        }
      ],
      "default": "underline"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "t:global.text.transform.label",
      "options": [
        {
          "value": "none",
          "label": "t:global.text.transform.none"
        },
        {
          "value": "italic",
          "label": "t:global.text.transform.italic"
        },
        {
          "value": "uppercase",
          "label": "t:global.text.transform.uppercase"
        },
        {
          "value": "both",
          "label": "t:global.text.transform.italic_and_uppercase"
        }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "select",
      "id": "spacing_choose_device",
      "label": "Choose device",
      "options": [
        {
          "value": "desktop",
          "label": "Desktop"
        },
        {
          "value": "mobile",
          "label": "Mobile"
        }
      ],
      "default": "desktop",
      "info": "Desktop and Mobile settings are configured separately."
    },
    {
      "type": "range",
      "id": "desktop_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "desktop_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "desktop_padding_left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Left",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "desktop_padding_right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Right",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'mobile' }}"
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'mobile' }}"
    },
    {
      "type": "range",
      "id": "mobile_padding_left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Left",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'mobile' }}"
    },
    {
      "type": "range",
      "id": "mobile_padding_right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Right",
      "default": 0,
      "visible_if": "{{ block.settings.spacing_choose_device == 'mobile' }}"
    }
  ],
  "presets": [
    {
      "name": "Subheading",
      "category": "Basic"
    }
  ]
}
{% endschema %}
